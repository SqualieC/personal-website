---
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Map — SqualieC</title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <style>
    :root {
      --bg:      #0c1729;
      --bg-soft: #122036;
      --card:    #1a2f54;
      --text:    #eef5ff;
      --muted:   #b8ceee;
      --accent:  #28edc4;
      --accent2: #ff6b38;
      --poi:     #a78bfa;
      --trip:    #facc15;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      width: 100%;
      overflow: hidden;
      font-family: 'Inter', 'Segoe UI', sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    #map {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    /* ── Leaflet overrides ── */
    .leaflet-control-zoom a {
      background: var(--bg-soft) !important;
      color: var(--muted) !important;
      border-color: color-mix(in srgb, var(--muted), transparent 65%) !important;
    }
    .leaflet-control-zoom a:hover { color: var(--text) !important; }
    .leaflet-control-attribution {
      background: color-mix(in srgb, var(--bg), transparent 15%) !important;
      color: var(--muted) !important;
      font-size: 0.65rem !important;
    }
    .leaflet-control-attribution a { color: var(--muted) !important; }
    .leaflet-popup-content-wrapper {
      background: var(--bg-soft) !important;
      color: var(--text) !important;
      border: 1px solid color-mix(in srgb, var(--muted), transparent 65%) !important;
      border-radius: 10px !important;
      box-shadow: 0 4px 24px rgba(0,0,0,0.4) !important;
      font-family: 'Inter', sans-serif !important;
      font-size: 0.82rem !important;
    }
    .leaflet-popup-tip { background: var(--bg-soft) !important; }

    /* ── Auth overlay ── */
    #auth-overlay {
      position: absolute;
      inset: 0;
      z-index: 1000;
      background: rgba(12, 23, 41, 0.82);
      backdrop-filter: blur(8px);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .auth-box {
      background: var(--bg-soft);
      border: 1px solid color-mix(in srgb, var(--muted), transparent 60%);
      border-radius: 16px;
      padding: 1.75rem;
      width: min(380px, 90vw);
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }

    .auth-box h2 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.15rem; }

    .auth-box .site-link {
      font-size: 0.8rem;
      color: var(--muted);
      text-decoration: none;
      margin-bottom: 0.5rem;
    }
    .auth-box .site-link:hover { color: var(--text); }

    .field {
      border: 1px solid color-mix(in srgb, var(--muted), transparent 55%);
      border-radius: 10px;
      padding: 0.52rem 0.8rem;
      font-size: 0.93rem;
      background: color-mix(in srgb, var(--bg), transparent 10%);
      color: var(--text);
      outline: none;
      width: 100%;
      font-family: inherit;
    }
    .field:focus { border-color: var(--accent); }
    .field::placeholder { color: color-mix(in srgb, var(--muted), transparent 40%); }

    .btn-accent {
      background: var(--accent);
      color: var(--bg);
      border: none;
      border-radius: 10px;
      padding: 0.58rem 1.2rem;
      font-size: 0.93rem;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      align-self: flex-start;
      transition: filter 0.12s;
    }
    .btn-accent:hover { filter: brightness(1.08); }
    .btn-accent:disabled { opacity: 0.5; cursor: not-allowed; }

    .btn-ghost {
      background: transparent;
      border: 1px solid color-mix(in srgb, var(--muted), transparent 58%);
      color: var(--muted);
      border-radius: 8px;
      padding: 0.4rem 0.85rem;
      font-size: 0.85rem;
      font-family: inherit;
      cursor: pointer;
      transition: border-color 0.12s, color 0.12s;
    }
    .btn-ghost:hover { color: var(--text); border-color: var(--muted); }

    #auth-msg { font-size: 0.82rem; color: var(--muted); min-height: 1em; }
    #auth-msg.err { color: #f87171; }

    /* ── Side panel ── */
    #panel {
      position: absolute;
      top: 14px;
      left: 14px;
      z-index: 500;
      width: 240px;
      background: color-mix(in srgb, var(--bg-soft), transparent 8%);
      border: 1px solid color-mix(in srgb, var(--muted), transparent 68%);
      border-radius: 16px;
      backdrop-filter: blur(14px);
      display: flex;
      flex-direction: column;
      max-height: calc(100dvh - 28px);
      overflow: hidden;
    }

    .panel-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.7rem 0.9rem 0.55rem;
      border-bottom: 1px solid color-mix(in srgb, var(--muted), transparent 80%);
      flex-shrink: 0;
    }

    .panel-title {
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .panel-top-right {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .icon-btn {
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      font-size: 0.8rem;
      padding: 2px 4px;
      border-radius: 4px;
      font-family: inherit;
      transition: color 0.12s;
      text-decoration: none;
    }
    .icon-btn:hover { color: var(--text); }

    /* ── Tab bar ── */
    .tab-bar {
      display: flex;
      border-bottom: 1px solid color-mix(in srgb, var(--muted), transparent 80%);
      flex-shrink: 0;
    }

    .tab {
      flex: 1;
      background: none;
      border: none;
      color: var(--muted);
      font-size: 0.75rem;
      font-weight: 600;
      font-family: inherit;
      padding: 0.5rem 0.25rem;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      transition: color 0.12s, border-color 0.12s;
    }
    .tab:hover { color: var(--text); }
    .tab.active { color: var(--accent); border-bottom-color: var(--accent); }

    /* ── Tab contents ── */
    .tab-content {
      display: flex;
      flex-direction: column;
      flex: 1;
      overflow: hidden;
      min-height: 0;
    }

    .panel-section {
      padding: 0.55rem 0.9rem;
      border-bottom: 1px solid color-mix(in srgb, var(--muted), transparent 88%);
      flex-shrink: 0;
    }

    .panel-label {
      font-size: 0.67rem;
      color: color-mix(in srgb, var(--muted), transparent 30%);
      text-transform: uppercase;
      letter-spacing: 0.07em;
      margin-bottom: 0.3rem;
    }

    .panel-select {
      background: color-mix(in srgb, var(--bg), transparent 5%);
      border: 1px solid color-mix(in srgb, var(--muted), transparent 68%);
      border-radius: 7px;
      color: var(--text);
      font-size: 0.8rem;
      font-family: inherit;
      padding: 0.28rem 0.5rem;
      width: 100%;
      cursor: pointer;
      outline: none;
    }
    .panel-select:focus { border-color: var(--accent); }

    .scrollable-list {
      overflow-y: auto;
      flex: 1;
      padding: 0.3rem 0;
    }

    /* ── Device rows ── */
    .device-row {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      padding: 0.48rem 0.9rem;
      cursor: pointer;
      transition: background 0.1s;
      user-select: none;
    }
    .device-row:hover { background: color-mix(in srgb, var(--muted), transparent 92%); }

    .device-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      flex-shrink: 0;
      transition: opacity 0.15s, box-shadow 0.15s;
      box-shadow: 0 0 6px currentColor;
    }

    .device-info { flex: 1; min-width: 0; }

    .device-name {
      font-size: 0.8rem;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      color: var(--text);
      transition: color 0.15s;
    }

    .device-meta { font-size: 0.68rem; color: var(--muted); margin-top: 1px; }

    .device-row.hidden-layer .device-dot  { opacity: 0.2; box-shadow: none; }
    .device-row.hidden-layer .device-name { color: color-mix(in srgb, var(--muted), transparent 30%); }

    .device-del {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 20px;
      height: 20px;
      border-radius: 4px;
      color: color-mix(in srgb, var(--muted), transparent 40%);
      cursor: pointer;
      opacity: 0;
      transition: opacity 0.15s, color 0.15s, background 0.15s;
    }
    .device-row:hover .device-del { opacity: 1; }
    .device-del:hover {
      color: #f87171;
      background: color-mix(in srgb, #f87171, transparent 88%);
    }

    /* ── Trip rows ── */
    .trip-row {
      display: flex;
      align-items: flex-start;
      gap: 0.55rem;
      padding: 0.52rem 0.9rem;
      cursor: pointer;
      transition: background 0.1s;
      user-select: none;
      border-bottom: 1px solid color-mix(in srgb, var(--muted), transparent 92%);
    }
    .trip-row:hover { background: color-mix(in srgb, var(--muted), transparent 92%); }
    .trip-row.selected { background: color-mix(in srgb, var(--trip), transparent 90%); }

    .trip-active-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 6px var(--accent);
      flex-shrink: 0;
      margin-top: 4px;
      animation: pulse 1.5s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    .trip-info { flex: 1; min-width: 0; }
    .trip-device {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .trip-date { font-weight: 400; color: var(--muted); }
    .trip-meta { font-size: 0.68rem; color: var(--muted); margin-top: 2px; line-height: 1.4; }

    /* ── Panel footer ── */
    .panel-footer {
      padding: 0.55rem 0.9rem;
      border-top: 1px solid color-mix(in srgb, var(--muted), transparent 80%);
      flex-shrink: 0;
    }

    .add-btn {
      background: transparent;
      border: 1px dashed color-mix(in srgb, var(--muted), transparent 60%);
      border-radius: 8px;
      color: var(--muted);
      cursor: pointer;
      font-size: 0.78rem;
      font-family: inherit;
      padding: 0.4rem;
      width: 100%;
      transition: border-color 0.14s, color 0.14s;
    }
    .add-btn:hover { border-color: var(--accent); color: var(--accent); }

    /* ── Storage info ── */
    #storage-info {
      padding: 0.45rem 0.9rem 0.5rem;
      border-top: 1px solid color-mix(in srgb, var(--muted), transparent 88%);
      font-size: 0.67rem;
      color: color-mix(in srgb, var(--muted), transparent 25%);
      line-height: 1.6;
      flex-shrink: 0;
    }

    /* ── Dialogs ── */
    .dialog-overlay {
      position: absolute;
      inset: 0;
      z-index: 600;
      background: rgba(12, 23, 41, 0.7);
      backdrop-filter: blur(6px);
      display: none;
      align-items: center;
      justify-content: center;
    }
    .dialog-overlay.open { display: flex; }

    .dialog-box {
      background: var(--bg-soft);
      border: 1px solid color-mix(in srgb, var(--muted), transparent 60%);
      border-radius: 16px;
      padding: 1.5rem;
      width: min(360px, 90vw);
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
    }
    .dialog-box h3 { font-size: 0.95rem; font-weight: 700; }

    .dialog-row {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    .dialog-actions {
      display: flex;
      gap: 0.5rem;
      justify-content: flex-end;
      margin-top: 0.1rem;
    }

    .dialog-msg { font-size: 0.78rem; color: var(--muted); min-height: 1em; }

    #new-device-key-block {
      background: color-mix(in srgb, var(--bg), transparent 5%);
      border: 1px solid color-mix(in srgb, var(--muted), transparent 70%);
      border-radius: 10px;
      padding: 0.8rem;
      font-size: 0.75rem;
      display: none;
      flex-direction: column;
      gap: 0.45rem;
    }
    #new-device-key-block.show { display: flex; }

    .key-url {
      color: var(--accent);
      word-break: break-all;
      font-family: 'SFMono-Regular', Consolas, monospace;
      font-size: 0.68rem;
      line-height: 1.45;
    }

    .copy-btn {
      background: color-mix(in srgb, var(--card), transparent 10%);
      border: 1px solid color-mix(in srgb, var(--muted), transparent 65%);
      border-radius: 6px;
      color: var(--text);
      cursor: pointer;
      font-size: 0.72rem;
      font-family: inherit;
      padding: 0.28rem 0.6rem;
      align-self: flex-start;
      transition: border-color 0.12s;
    }
    .copy-btn:hover { border-color: var(--accent); }

    /* ── POI add banner ── */
    #poi-banner {
      position: absolute;
      top: 14px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 500;
      background: color-mix(in srgb, var(--poi), transparent 10%);
      border: 1px solid var(--poi);
      border-radius: 999px;
      padding: 0.4rem 1rem;
      font-size: 0.78rem;
      font-weight: 600;
      color: #fff;
      display: none;
      align-items: center;
      gap: 0.75rem;
      white-space: nowrap;
      backdrop-filter: blur(8px);
    }
    #poi-banner.active { display: flex; }

    #poi-cancel-banner {
      background: none;
      border: 1px solid rgba(255,255,255,0.4);
      color: #fff;
      border-radius: 999px;
      padding: 0.15rem 0.6rem;
      font-size: 0.72rem;
      font-family: inherit;
      cursor: pointer;
    }
    #poi-cancel-banner:hover { background: rgba(255,255,255,0.1); }

    /* ── Status bar ── */
    #status-bar {
      position: absolute;
      bottom: 16px;
      right: 14px;
      z-index: 500;
      background: color-mix(in srgb, var(--bg-soft), transparent 10%);
      border: 1px solid color-mix(in srgb, var(--muted), transparent 70%);
      border-radius: 999px;
      padding: 0.25rem 0.75rem;
      font-size: 0.7rem;
      color: var(--muted);
      backdrop-filter: blur(10px);
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: color-mix(in srgb, var(--muted), transparent 30%);
      flex-shrink: 0;
    }
    #status-bar.live .status-dot { background: var(--accent); box-shadow: 0 0 4px var(--accent); }
    #status-bar.live { color: var(--text); }

    /* ── Empty state ── */
    .empty-msg {
      padding: 0.7rem 0.9rem;
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.5;
    }

    /* ── Map crosshair cursor when placing POI ── */
    .map-placing { cursor: crosshair !important; }
    .map-placing .leaflet-interactive { cursor: crosshair !important; }
  </style>
</head>
<body>

<div id="map"></div>

<!-- Auth overlay -->
<div id="auth-overlay">
  <div class="auth-box">
    <a href="/" class="site-link">← squalie.cc</a>
    <h2>Map</h2>
    <input id="auth-email" class="field" type="email" placeholder="Email" autocomplete="email" />
    <input id="auth-password" class="field" type="password" placeholder="Password" autocomplete="current-password" />
    <button id="auth-login-btn" class="btn-accent">Log In</button>
    <p id="auth-msg"></p>
  </div>
</div>

<!-- Side panel -->
<div id="panel" style="display:none">
  <div class="panel-top">
    <span class="panel-title">Map</span>
    <div class="panel-top-right">
      <a href="/" class="icon-btn">← Home</a>
      <button class="icon-btn" id="logout-btn">Log out</button>
    </div>
  </div>

  <div class="tab-bar">
    <button class="tab active" data-tab="devices">Devices</button>
    <button class="tab" data-tab="trips">Trips</button>
    <button class="tab" data-tab="places">Places</button>
  </div>

  <!-- Devices tab -->
  <div id="tab-devices" class="tab-content">
    <div class="panel-section">
      <div class="panel-label">History</div>
      <select id="history-select" class="panel-select">
        <option value="1">Last 1 hour</option>
        <option value="6">Last 6 hours</option>
        <option value="24" selected>Last 24 hours</option>
        <option value="72">Last 3 days</option>
        <option value="168">Last 7 days</option>
      </select>
    </div>
    <div id="device-list" class="scrollable-list"></div>
    <div id="storage-info"></div>
    <div class="panel-footer">
      <button id="add-device-btn" class="add-btn">+ Add Device</button>
    </div>
  </div>

  <!-- Trips tab -->
  <div id="tab-trips" class="tab-content" style="display:none">
    <div id="trip-list" class="scrollable-list"></div>
  </div>

  <!-- Places tab -->
  <div id="tab-places" class="tab-content" style="display:none">
    <div id="poi-list" class="scrollable-list"></div>
    <div class="panel-footer">
      <button id="add-poi-btn" class="add-btn">+ Add Place</button>
    </div>
  </div>
</div>

<!-- POI add banner -->
<div id="poi-banner">
  Click on the map to place a point of interest
  <button id="poi-cancel-banner">Cancel</button>
</div>

<!-- Add device dialog -->
<div id="add-device-dialog" class="dialog-overlay">
  <div class="dialog-box">
    <h3>Add Device</h3>
    <input id="new-device-name" class="field" type="text" placeholder="Name (e.g. iPhone, Car)" />
    <div id="new-device-key-block">
      <div class="panel-label">Overland / HTTP endpoint</div>
      <div id="new-device-url" class="key-url"></div>
      <button class="copy-btn" id="copy-url-btn">Copy URL</button>
      <div class="panel-label" style="margin-top:0.2rem">Secret key — keep private</div>
      <div id="new-device-key" class="key-url"></div>
    </div>
    <p id="dialog-msg" class="dialog-msg"></p>
    <div class="dialog-actions">
      <button class="btn-ghost" id="dialog-cancel-btn">Close</button>
      <button class="btn-accent" id="dialog-create-btn">Create</button>
    </div>
  </div>
</div>

<!-- Add POI dialog -->
<div id="add-poi-dialog" class="dialog-overlay">
  <div class="dialog-box">
    <h3>Add Place</h3>
    <input id="poi-name-input" class="field" type="text" placeholder="Name (e.g. Home, Work)" />
    <div class="dialog-row">
      <input id="poi-radius-input" class="field" type="number" min="50" max="5000" placeholder="Radius" value="100" style="width:110px;flex-shrink:0" />
      <span style="font-size:0.8rem;color:var(--muted)">meters radius</span>
    </div>
    <p id="poi-dialog-msg" class="dialog-msg"></p>
    <div class="dialog-actions">
      <button class="btn-ghost" id="poi-cancel-dialog-btn">Cancel</button>
      <button class="btn-accent" id="poi-create-btn">Save Place</button>
    </div>
  </div>
</div>

<!-- Status bar -->
<div id="status-bar">
  <div class="status-dot"></div>
  <span id="status-text">Connecting…</span>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/WPnI=" crossorigin=""></script>
<script is:inline>
(function () {
  const WORKER     = 'https://squalie-account.squaliekid55.workers.dev';
  const TOKEN_KEY  = 'squalie-token';
  const EMAIL_KEY  = 'squalie-email';
  const COLORS     = ['#28edc4','#ff6b38','#60a5fa','#f472b6','#a78bfa','#facc15','#34d399','#fb923c'];
  const REFRESH_MS = 30_000;

  let map, token;
  let devices = [], layersByDevice = {}, hiddenDevices = new Set(), historyHours = 24;
  let trips = [], selectedTripId = null, tripRouteLayer = null;
  let pois = [], poiLayers = {};
  let addingPoi = false, pendingPoiLatLng = null;
  let mapFitted = false;
  let activeTab = 'devices';

  function getToken() { return localStorage.getItem(TOKEN_KEY); }

  // ── Auth ──────────────────────────────────────────────────────────────────
  async function login() {
    const email = document.getElementById('auth-email').value.trim();
    const pass  = document.getElementById('auth-password').value;
    const btn   = document.getElementById('auth-login-btn');
    if (!email || !pass) { setAuthMsg('Enter email and password.', true); return; }
    btn.disabled = true;
    setAuthMsg('Connecting…', false);
    try {
      const res  = await fetch(`${WORKER}/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password: pass }),
      });
      const data = await res.json();
      if (!res.ok) { setAuthMsg(data.error || 'Login failed.', true); btn.disabled = false; return; }
      localStorage.setItem(TOKEN_KEY, data.token);
      localStorage.setItem(EMAIL_KEY, data.email);
      initMap();
    } catch {
      setAuthMsg('Connection failed.', true);
      btn.disabled = false;
    }
  }

  function setAuthMsg(msg, isErr) {
    const el = document.getElementById('auth-msg');
    el.textContent = msg;
    el.className = isErr ? 'err' : '';
  }

  function logout() {
    const t = getToken();
    if (t) fetch(`${WORKER}/logout`, { method: 'POST', headers: { 'Authorization': 'Bearer ' + t } }).catch(() => {});
    localStorage.removeItem(TOKEN_KEY);
    localStorage.removeItem(EMAIL_KEY);
    location.reload();
  }

  // ── Map init ──────────────────────────────────────────────────────────────
  function initMap() {
    document.getElementById('auth-overlay').style.display = 'none';
    document.getElementById('panel').style.display = 'flex';
    token = getToken();

    map = L.map('map', { zoomControl: false }).setView([39.5, -98.35], 4);
    L.control.zoom({ position: 'bottomright' }).addTo(map);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors © <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 19,
    }).addTo(map);

    map.on('click', function (e) {
      if (!addingPoi) return;
      pendingPoiLatLng = e.latlng;
      document.getElementById('poi-name-input').value = '';
      document.getElementById('poi-radius-input').value = '100';
      document.getElementById('poi-dialog-msg').textContent = '';
      document.getElementById('poi-create-btn').disabled = false;
      document.getElementById('add-poi-dialog').classList.add('open');
      setTimeout(() => document.getElementById('poi-name-input').focus(), 50);
    });

    // Tabs
    document.querySelectorAll('.tab').forEach(btn => {
      btn.addEventListener('click', function () {
        activeTab = this.dataset.tab;
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        document.getElementById('tab-devices').style.display = activeTab === 'devices' ? 'flex' : 'none';
        document.getElementById('tab-trips').style.display   = activeTab === 'trips'   ? 'flex' : 'none';
        document.getElementById('tab-places').style.display  = activeTab === 'places'  ? 'flex' : 'none';
        if (activeTab === 'trips') loadTrips();
        if (activeTab === 'places') loadPois();
      });
    });

    document.getElementById('history-select').addEventListener('change', function () {
      historyHours = parseInt(this.value);
      refresh();
    });

    document.getElementById('logout-btn').addEventListener('click', logout);
    document.getElementById('add-device-btn').addEventListener('click', openAddDeviceDialog);
    document.getElementById('dialog-cancel-btn').addEventListener('click', closeAddDeviceDialog);
    document.getElementById('dialog-create-btn').addEventListener('click', createDevice);
    document.getElementById('copy-url-btn').addEventListener('click', function () {
      navigator.clipboard.writeText(document.getElementById('new-device-url').textContent).then(() => {
        this.textContent = 'Copied!';
        setTimeout(() => { this.textContent = 'Copy URL'; }, 2000);
      });
    });

    document.getElementById('add-poi-btn').addEventListener('click', startAddPoi);
    document.getElementById('poi-cancel-banner').addEventListener('click', cancelAddPoi);
    document.getElementById('poi-cancel-dialog-btn').addEventListener('click', cancelAddPoi);
    document.getElementById('poi-create-btn').addEventListener('click', createPoi);
    document.getElementById('poi-name-input').addEventListener('keydown', e => { if (e.key === 'Enter') createPoi(); });

    refresh();
    setInterval(refresh, REFRESH_MS);
  }

  // ── Data refresh ──────────────────────────────────────────────────────────
  async function refresh() {
    setStatus(false, 'Refreshing…');
    try {
      const res = await fetch(`${WORKER}/gps/devices`, {
        headers: { 'Authorization': 'Bearer ' + token },
      });
      if (res.status === 401) { logout(); return; }
      devices = await res.json();
      renderDeviceList();
      await Promise.all(devices.map(loadTrack));
      if (!mapFitted) { fitMap(); mapFitted = true; }
      loadStats();
      if (activeTab === 'trips') loadTrips();
      if (activeTab === 'places') loadPois();
      else loadPois(); // always keep POI markers fresh
      setStatus(true, 'Live · ' + new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }));
    } catch {
      setStatus(false, 'Error — retrying…');
    }
  }

  async function loadTrack(device) {
    try {
      const res = await fetch(`${WORKER}/gps/history?deviceId=${device.id}&hours=${historyHours}`, {
        headers: { 'Authorization': 'Bearer ' + token },
      });
      renderTrack(device, await res.json());
    } catch {}
  }

  // ── Trips ─────────────────────────────────────────────────────────────────
  async function loadTrips() {
    try {
      const res = await fetch(`${WORKER}/gps/trips?limit=50`, {
        headers: { 'Authorization': 'Bearer ' + token },
      });
      trips = await res.json();
      renderTripList();
    } catch {}
  }

  function renderTripList() {
    const list = document.getElementById('trip-list');
    list.innerHTML = '';
    if (!trips.length) {
      list.innerHTML = '<div class="empty-msg">No trips yet.<br>Move more than 50 m to start one.</div>';
      return;
    }
    trips.forEach(trip => {
      const isActive = !trip.ended_at;
      const dist = trip.distance_meters
        ? (trip.distance_meters / 1609.34).toFixed(2) + ' mi'
        : '—';
      const dur = trip.duration_seconds
        ? fmtDuration(trip.duration_seconds)
        : (isActive ? 'Active' : '—');
      const speeds = trip.avg_speed_mph
        ? `${Math.round(trip.avg_speed_mph)} avg / ${Math.round(trip.max_speed_mph)} max mph`
        : '';
      const date = new Date(trip.started_at * 1000).toLocaleDateString('en-US', {
        month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit',
      });

      const row = document.createElement('div');
      row.className = 'trip-row' + (trip.id === selectedTripId ? ' selected' : '');

      if (isActive) {
        const dot = document.createElement('div');
        dot.className = 'trip-active-dot';
        row.appendChild(dot);
      }

      const info = document.createElement('div');
      info.className = 'trip-info';
      info.innerHTML = `
        <div class="trip-device">${esc(trip.device_name)} <span class="trip-date">${date}</span></div>
        <div class="trip-meta">${dist} · ${dur}${speeds ? '<br>' + speeds : ''}</div>
      `;
      row.appendChild(info);

      row.addEventListener('click', () => selectTrip(trip));
      list.appendChild(row);
    });
  }

  async function selectTrip(trip) {
    selectedTripId = trip.id;
    renderTripList();

    if (tripRouteLayer) { map.removeLayer(tripRouteLayer); tripRouteLayer = null; }

    try {
      const res = await fetch(`${WORKER}/gps/trips/${trip.id}/positions`, {
        headers: { 'Authorization': 'Bearer ' + token },
      });
      const pts = await res.json();
      if (!pts.length) return;

      const latlngs = pts.map(p => [p.lat, p.lon]);
      tripRouteLayer = L.featureGroup();

      L.polyline(latlngs, { color: '#facc15', weight: 4, opacity: 0.9, zIndex: 600 }).addTo(tripRouteLayer);

      // Start dot (green)
      L.circleMarker(latlngs[0], {
        radius: 6, color: '#0c1729', weight: 2,
        fillColor: '#22c55e', fillOpacity: 1,
      }).addTo(tripRouteLayer);

      // End dot
      if (latlngs.length > 1) {
        const endColor = trip.ended_at ? '#f87171' : '#facc15';
        const dist = trip.distance_meters ? (trip.distance_meters / 1609.34).toFixed(2) + ' mi' : '—';
        const dur  = trip.duration_seconds ? fmtDuration(trip.duration_seconds) : '—';
        const popup = `<b>${esc(trip.device_name)}</b><br>${dist} · ${dur}`
          + (trip.avg_speed_mph ? `<br>${Math.round(trip.avg_speed_mph)} avg / ${Math.round(trip.max_speed_mph)} max mph` : '');
        L.circleMarker(latlngs[latlngs.length - 1], {
          radius: 6, color: '#0c1729', weight: 2,
          fillColor: endColor, fillOpacity: 1,
        }).bindPopup(popup).addTo(tripRouteLayer);
      }

      tripRouteLayer.addTo(map);
      try { map.fitBounds(tripRouteLayer.getBounds(), { padding: [44, 44], maxZoom: 16 }); } catch {}
    } catch {}
  }

  // ── POIs ─────────────────────────────────────────────────────────────────
  async function loadPois() {
    try {
      const res = await fetch(`${WORKER}/gps/pois`, {
        headers: { 'Authorization': 'Bearer ' + token },
      });
      pois = await res.json();
      renderPoiList();
      renderPoiMarkers();
    } catch {}
  }

  function renderPoiMarkers() {
    Object.values(poiLayers).forEach(g => map.removeLayer(g));
    poiLayers = {};
    pois.forEach(poi => {
      const group = L.featureGroup();
      L.circle([poi.lat, poi.lon], {
        radius: poi.radius,
        color: '#a78bfa',
        fillColor: '#a78bfa',
        fillOpacity: 0.12,
        weight: 1.5,
        dashArray: '4 4',
      }).addTo(group);
      L.marker([poi.lat, poi.lon], { icon: makePoiIcon() })
        .bindPopup(`<b>${esc(poi.name)}</b><br>Radius: ${poi.radius} m`)
        .addTo(group);
      group.addTo(map);
      poiLayers[poi.id] = group;
    });
  }

  function makePoiIcon() {
    const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18">
      <polygon points="9,1 11.2,6.8 17,7.6 12.8,11.6 14,17.2 9,14.2 4,17.2 5.2,11.6 1,7.6 6.8,6.8"
        fill="#a78bfa" stroke="#0c1729" stroke-width="1.2" stroke-linejoin="round"/>
    </svg>`;
    return L.divIcon({ html: svg, className: '', iconSize: [18, 18], iconAnchor: [9, 9], popupAnchor: [0, -10] });
  }

  function renderPoiList() {
    const list = document.getElementById('poi-list');
    list.innerHTML = '';
    if (!pois.length) {
      list.innerHTML = '<div class="empty-msg">No places saved yet.<br>Add one to mark a location.</div>';
      return;
    }
    pois.forEach(poi => {
      const row = document.createElement('div');
      row.className = 'device-row';
      row.innerHTML = `
        <div class="device-dot" style="background:#a78bfa;color:#a78bfa;border-radius:2px;transform:rotate(45deg)"></div>
        <div class="device-info">
          <div class="device-name">${esc(poi.name)}</div>
          <div class="device-meta">${poi.radius} m radius</div>
        </div>
        <span class="device-del" title="Remove place">
          <svg width="8" height="8" viewBox="0 0 8 8" fill="none">
            <path d="M1 1l6 6M7 1L1 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </span>
      `;

      row.addEventListener('click', function (e) {
        if (e.target.closest('.device-del')) return;
        if (poiLayers[poi.id]) {
          map.fitBounds(poiLayers[poi.id].getBounds(), { padding: [40, 40], maxZoom: 16 });
        }
      });

      row.querySelector('.device-del').addEventListener('click', async function (e) {
        e.stopPropagation();
        if (!confirm(`Remove "${poi.name}"?`)) return;
        await fetch(`${WORKER}/gps/pois/${poi.id}`, {
          method: 'DELETE', headers: { 'Authorization': 'Bearer ' + token },
        });
        loadPois();
      });

      list.appendChild(row);
    });
  }

  function startAddPoi() {
    addingPoi = true;
    document.getElementById('poi-banner').classList.add('active');
    document.getElementById('map').classList.add('map-placing');
  }

  function cancelAddPoi() {
    addingPoi = false;
    pendingPoiLatLng = null;
    document.getElementById('poi-banner').classList.remove('active');
    document.getElementById('map').classList.remove('map-placing');
    document.getElementById('add-poi-dialog').classList.remove('open');
  }

  async function createPoi() {
    if (!pendingPoiLatLng) return;
    const name   = document.getElementById('poi-name-input').value.trim();
    const radius = Math.min(5000, Math.max(50, parseInt(document.getElementById('poi-radius-input').value) || 100));
    const btn    = document.getElementById('poi-create-btn');
    const msg    = document.getElementById('poi-dialog-msg');
    if (!name) { msg.textContent = 'Enter a name.'; return; }
    btn.disabled = true;
    try {
      const res = await fetch(`${WORKER}/gps/pois`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ name, lat: pendingPoiLatLng.lat, lon: pendingPoiLatLng.lng, radius }),
      });
      if (!res.ok) { msg.textContent = 'Failed to save.'; btn.disabled = false; return; }
      cancelAddPoi();
      loadPois();
    } catch {
      msg.textContent = 'Connection failed.';
      btn.disabled = false;
    }
  }

  // ── Device rendering ─────────────────────────────────────────────────────
  function colorFor(i) { return COLORS[i % COLORS.length]; }

  function renderTrack(device, points) {
    const idx    = devices.findIndex(d => d.id === device.id);
    const color  = colorFor(idx);
    const hidden = hiddenDevices.has(device.id);

    if (layersByDevice[device.id]) {
      layersByDevice[device.id].forEach(l => map.removeLayer(l));
    }
    layersByDevice[device.id] = [];
    if (hidden || !points.length) return;

    const latlngs = points.map(p => [p.lat, p.lon]);
    const line = L.polyline(latlngs, { color, weight: 3, opacity: 0.75 }).addTo(map);
    layersByDevice[device.id].push(line);

    const last   = points[points.length - 1];
    const ageSec = Math.floor(Date.now() / 1000) - last.timestamp;
    const bat    = device.battery != null ? `<br>Battery: ${Math.round(device.battery * 100)}%` : '';
    const spd    = last.speed != null && last.speed > 0.5
      ? `<br>Speed: ${(last.speed * 2.237).toFixed(1)} mph` : '';

    const marker = L.marker([last.lat, last.lon], { icon: makeDeviceIcon(color) })
      .addTo(map)
      .bindPopup(`<b>${esc(device.name)}</b><br>${fmtAge(ageSec)}${bat}${spd}`);
    layersByDevice[device.id].push(marker);
  }

  function makeDeviceIcon(color) {
    const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="30" viewBox="0 0 22 30">
      <circle cx="11" cy="11" r="9" fill="${color}" stroke="#0c1729" stroke-width="2"/>
      <polygon points="11,30 5,17 17,17" fill="${color}"/>
      <circle cx="11" cy="11" r="4" fill="#0c1729"/>
    </svg>`;
    return L.divIcon({ html: svg, className: '', iconSize: [22, 30], iconAnchor: [11, 30], popupAnchor: [0, -30] });
  }

  async function loadStats() {
    try {
      const res   = await fetch(`${WORKER}/gps/stats`, { headers: { 'Authorization': 'Bearer ' + token } });
      const rows  = await res.json();
      const el    = document.getElementById('storage-info');
      if (!rows.length) { el.textContent = ''; return; }
      const total  = rows.reduce((s, r) => s + r.total_points, 0);
      const oldest = rows.reduce((m, r) => Math.min(m, r.oldest), Infinity);
      const span   = oldest < Infinity ? Math.ceil((Date.now() / 1000 - oldest) / 86400) : 0;
      el.textContent = `${total.toLocaleString()} points stored · ${span}d history`;
    } catch {}
  }

  function fitMap() {
    const pts = [];
    Object.values(layersByDevice).forEach(layers =>
      layers.forEach(l => {
        if (l.getLatLngs) { const ll = l.getLatLngs(); if (Array.isArray(ll)) ll.forEach(p => pts.push(p)); }
        else if (l.getLatLng) pts.push(l.getLatLng());
      })
    );
    if (pts.length) {
      try { map.fitBounds(L.latLngBounds(pts), { padding: [44, 44], maxZoom: 16 }); } catch {}
    }
  }

  function renderDeviceList() {
    const list = document.getElementById('device-list');
    list.innerHTML = '';
    if (!devices.length) {
      list.innerHTML = '<div class="empty-msg">No devices yet.<br>Add one below to start tracking.</div>';
      return;
    }
    devices.forEach((d, i) => {
      const color  = colorFor(i);
      const hidden = hiddenDevices.has(d.id);
      const age    = d.last_seen ? fmtAge(Math.floor(Date.now() / 1000) - d.last_seen) : 'never';
      const bat    = d.battery != null ? ` · ${Math.round(d.battery * 100)}%` : '';

      const row = document.createElement('div');
      row.className = 'device-row' + (hidden ? ' hidden-layer' : '');
      row.innerHTML = `
        <div class="device-dot" style="background:${color};color:${color}"></div>
        <div class="device-info">
          <div class="device-name">${esc(d.name)}</div>
          <div class="device-meta">${age}${bat}</div>
        </div>
        <span class="device-del" title="Remove device">
          <svg width="8" height="8" viewBox="0 0 8 8" fill="none">
            <path d="M1 1l6 6M7 1L1 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </span>
      `;

      row.addEventListener('click', function (e) {
        if (e.target.closest('.device-del')) return;
        hiddenDevices.has(d.id) ? hiddenDevices.delete(d.id) : hiddenDevices.add(d.id);
        renderDeviceList();
        devices.forEach(dev => {
          (layersByDevice[dev.id] || []).forEach(l => map.removeLayer(l));
          layersByDevice[dev.id] = [];
        });
        Promise.all(devices.map(loadTrack));
      });

      row.querySelector('.device-del').addEventListener('click', async function (e) {
        e.stopPropagation();
        if (!confirm(`Remove "${d.name}" and all its history?`)) return;
        await fetch(`${WORKER}/gps/devices/${d.id}`, {
          method: 'DELETE', headers: { 'Authorization': 'Bearer ' + token },
        });
        refresh();
      });

      list.appendChild(row);
    });
  }

  // ── Add device dialog ─────────────────────────────────────────────────────
  function openAddDeviceDialog() {
    document.getElementById('new-device-name').value = '';
    document.getElementById('new-device-key-block').className = '';
    document.getElementById('dialog-msg').textContent = '';
    document.getElementById('dialog-create-btn').disabled = false;
    document.getElementById('dialog-create-btn').textContent = 'Create';
    document.getElementById('add-device-dialog').classList.add('open');
    setTimeout(() => document.getElementById('new-device-name').focus(), 50);
  }

  function closeAddDeviceDialog() {
    document.getElementById('add-device-dialog').classList.remove('open');
    refresh();
  }

  async function createDevice() {
    const name = document.getElementById('new-device-name').value.trim();
    const btn  = document.getElementById('dialog-create-btn');
    const msg  = document.getElementById('dialog-msg');
    if (!name) { msg.textContent = 'Enter a device name.'; return; }
    btn.disabled = true;
    btn.textContent = 'Creating…';
    try {
      const res  = await fetch(`${WORKER}/gps/devices`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ name }),
      });
      const data = await res.json();
      if (!res.ok) { msg.textContent = data.error || 'Failed.'; btn.disabled = false; btn.textContent = 'Create'; return; }
      const url = `${WORKER}/gps/track?key=${data.device_key}`;
      document.getElementById('new-device-url').textContent = url;
      document.getElementById('new-device-key').textContent = data.device_key;
      document.getElementById('new-device-key-block').className = 'show';
      msg.textContent = 'Device created. Copy the URL for Overland.';
      btn.textContent = 'Done';
    } catch {
      msg.textContent = 'Connection failed.';
      btn.disabled = false;
      btn.textContent = 'Create';
    }
  }

  // ── Utilities ─────────────────────────────────────────────────────────────
  function fmtAge(s) {
    if (s < 60)    return `${s}s ago`;
    if (s < 3600)  return `${Math.floor(s / 60)}m ago`;
    if (s < 86400) return `${Math.floor(s / 3600)}h ago`;
    return `${Math.floor(s / 86400)}d ago`;
  }

  function fmtDuration(s) {
    if (s < 60)    return `${s}s`;
    if (s < 3600)  return `${Math.floor(s / 60)}m`;
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    return m > 0 ? `${h}h ${m}m` : `${h}h`;
  }

  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function setStatus(live, text) {
    const bar = document.getElementById('status-bar');
    bar.className = live ? 'live' : '';
    document.getElementById('status-text').textContent = text;
  }

  // ── Boot ──────────────────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', function () {
    document.getElementById('auth-login-btn').addEventListener('click', login);
    document.getElementById('auth-email').addEventListener('keydown', e => {
      if (e.key === 'Enter') document.getElementById('auth-password').focus();
    });
    document.getElementById('auth-password').addEventListener('keydown', e => {
      if (e.key === 'Enter') login();
    });
    document.getElementById('new-device-name').addEventListener('keydown', e => {
      if (e.key === 'Enter') createDevice();
    });

    if (getToken()) initMap();
  });
})();
</script>
</body>
</html>
