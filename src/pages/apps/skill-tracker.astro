---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Skill Tracker | SqualieC"
  description="Track time across skills and watch a 3D shape evolve. Weekly, yearly, and lifetime views."
>
  <section class="hero hero-surface">
    <p class="eyebrow">Personal Tool</p>
    <h1>Skill Tracker</h1>
    <p class="lead">Log time across skills and watch your shape grow. Requires the local backend to be running.</p>
  </section>

  <section class="tracker-shell">

    <!-- ── Blob viewer ──────────────────────────────────────────── -->
    <div class="blob-panel">
      <canvas id="blobCanvas"></canvas>
      <!-- CSS2DRenderer injects its own overlay div here at runtime -->

      <div class="period-tabs">
        <button class="period-tab active" data-period="today">Today</button>
        <button class="period-tab" data-period="week">This Week</button>
        <button class="period-tab" data-period="year">This Year</button>
        <button class="period-tab" data-period="lifetime">Lifetime</button>
      </div>

      <div id="noDataMsg" class="no-data-msg" hidden>
        No time logged yet — start a session to build your shape.
      </div>
    </div>

    <!-- ── Control panel ────────────────────────────────────────── -->
    <aside class="control-panel">

      <div class="conn-header">
        <div class="conn-status">
          <span id="connDot" class="conn-dot"></span>
          <span id="connLabel">Not connected</span>
        </div>
        <button id="settingsToggle" class="icon-btn" title="Backend settings">⚙</button>
      </div>

      <div id="settingsPanel" class="settings-panel">
        <span class="settings-label">Backend URL</span>
        <div class="settings-row">
          <input id="apiUrlInput" class="settings-input" type="url" placeholder="http://localhost:8000" />
          <button id="connectBtn" class="btn-sm">Connect</button>
        </div>
        <p class="settings-hint">Run <code>start.bat</code> inside <code>SkillTracker/backend/</code>, then click Connect.</p>
      </div>

      <div id="activeBanner" class="active-banner" hidden>
        <span class="conn-dot active pulse"></span>
        <span id="activeCatName">—</span>
        <span id="activeClock" class="active-clock">00:00:00</span>
      </div>

      <div class="cp-card">
        <h3 class="cp-card-title">Log Time</h3>
        <select id="categorySelect" class="cp-select">
          <option value="">Select a skill…</option>
        </select>
        <button id="timerBtn" class="timer-btn" disabled>
          <span id="timerBtnLabel">▶ Start</span>
        </button>
      </div>

      <div class="cp-card">
        <h3 class="cp-card-title">Skills</h3>
        <ul id="categoryList" class="cat-list"></ul>
        <div class="add-cat-row">
          <input id="newCatName" class="cp-input" placeholder="New skill…" maxlength="32" />
          <button id="addCatBtn" class="btn-sm">Add</button>
        </div>
      </div>

    </aside>
  </section>

  <section class="history-section">
    <h2 class="section-title" style="margin-bottom:0.75rem">Recent Sessions</h2>
    <div id="historyList" class="history-list"></div>
  </section>
</Layout>

<style>
  /* ── Layout ──────────────────────────────────────────────────── */
  .tracker-shell {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 1.25rem;
    margin: 1.5rem 0;
    align-items: start;
  }

  /* ── Blob panel ──────────────────────────────────────────────── */
  .blob-panel {
    position: relative;
    aspect-ratio: 1;
    background: var(--bg-soft);
    border-radius: 1.5rem;
    /* No overflow:hidden — border-radius on the canvas clips the 3D content
       while letting the HTML label overlay render outside without being cut off. */
    border: 1px solid color-mix(in srgb, var(--muted), transparent 78%);
  }

  #blobCanvas {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 1.5rem; /* clips WebGL rendering to match panel corners */
  }

  /* ── Vertex labels (CSS2DRenderer overlay) ───────────────────── */
  /* CSS2DRenderer injects position:absolute on its container and each label */
  .vertex-label {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text);
    background: color-mix(in srgb, var(--bg), transparent 15%);
    backdrop-filter: blur(6px);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    white-space: nowrap;
    border: 1px solid color-mix(in srgb, #4ade80, transparent 45%);
    transition: opacity 0.15s;
    pointer-events: none;
    user-select: none;
  }

  /* ── Period tabs ─────────────────────────────────────────────── */
  .period-tabs {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.3rem;
    background: color-mix(in srgb, var(--bg), transparent 25%);
    backdrop-filter: blur(10px);
    border-radius: 999px;
    padding: 0.25rem;
    border: 1px solid color-mix(in srgb, var(--muted), transparent 80%);
  }

  .period-tab {
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    border: none;
    background: transparent;
    color: var(--muted);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .period-tab.active {
    background: #4ade80;
    color: #0c1f10;
    font-weight: 600;
  }

  .no-data-msg {
    position: absolute;
    bottom: 3.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.78rem;
    color: var(--muted);
    white-space: nowrap;
    background: color-mix(in srgb, var(--bg), transparent 20%);
    backdrop-filter: blur(6px);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
  }

  /* ── Control panel ───────────────────────────────────────────── */
  .control-panel {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .conn-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.2rem 0;
  }

  .conn-status {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .conn-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #555;
    flex-shrink: 0;
  }
  .conn-dot.connected    { background: #4ade80; }
  .conn-dot.disconnected { background: #f87171; }
  .conn-dot.active       { background: #4ade80; }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
  }
  .pulse { animation: pulse 1.6s ease-in-out infinite; }

  .icon-btn {
    background: transparent;
    border: none;
    color: var(--muted);
    font-size: 1rem;
    cursor: pointer;
    padding: 0.2rem 0.3rem;
    border-radius: 0.3rem;
    transition: color 0.15s;
  }
  .icon-btn:hover { color: var(--text); }

  .settings-panel {
    background: var(--card);
    border-radius: 0.75rem;
    padding: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .settings-label {
    font-size: 0.72rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .settings-row {
    display: flex;
    gap: 0.45rem;
  }

  .settings-input {
    flex: 1;
    min-width: 0;
    background: var(--bg);
    border: 1px solid color-mix(in srgb, var(--muted), transparent 60%);
    border-radius: 0.4rem;
    color: var(--text);
    padding: 0.38rem 0.6rem;
    font-size: 0.8rem;
  }

  .settings-hint {
    font-size: 0.73rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }

  .settings-hint code {
    background: var(--bg);
    padding: 0.1rem 0.3rem;
    border-radius: 0.25rem;
    font-size: 0.71rem;
  }

  .active-banner {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    background: color-mix(in srgb, #4ade80, transparent 88%);
    border: 1px solid color-mix(in srgb, #4ade80, transparent 55%);
    border-radius: 0.75rem;
    padding: 0.55rem 0.85rem;
    font-size: 0.85rem;
  }

  .active-clock {
    margin-left: auto;
    font-family: monospace;
    color: #4ade80;
    font-weight: 600;
    font-size: 0.9rem;
  }

  /* ── Cards ───────────────────────────────────────────────────── */
  .cp-card {
    background: var(--card);
    border-radius: 1rem;
    padding: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .cp-card-title {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0;
  }

  .cp-select {
    background: var(--bg);
    border: 1px solid color-mix(in srgb, var(--muted), transparent 60%);
    border-radius: 0.5rem;
    color: var(--text);
    padding: 0.48rem 0.7rem;
    font-size: 0.88rem;
    width: 100%;
    cursor: pointer;
  }

  .timer-btn {
    width: 100%;
    padding: 0.75rem;
    border: none;
    border-radius: 0.6rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    background: #4ade80;
    color: #0c1f10;
    transition: background 0.2s, opacity 0.2s;
  }
  .timer-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .timer-btn.running  { background: #f87171; color: #fff; }

  /* ── Category list ───────────────────────────────────────────── */
  .cat-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    max-height: 220px;
    overflow-y: auto;
  }

  .cat-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.5rem;
    border-radius: 0.45rem;
    background: var(--bg);
    font-size: 0.83rem;
  }

  .cat-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4ade80;
    flex-shrink: 0;
  }

  .cat-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .cat-time {
    color: var(--muted);
    font-size: 0.76rem;
    font-variant-numeric: tabular-nums;
  }

  .cat-del {
    background: transparent;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 0.8rem;
    padding: 0 0.15rem;
    opacity: 0;
    transition: opacity 0.12s;
    line-height: 1;
  }
  .cat-item:hover .cat-del { opacity: 1; }

  .add-cat-row {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .cp-input {
    flex: 1;
    min-width: 0;
    background: var(--bg);
    border: 1px solid color-mix(in srgb, var(--muted), transparent 60%);
    border-radius: 0.4rem;
    color: var(--text);
    padding: 0.38rem 0.55rem;
    font-size: 0.82rem;
  }

  .btn-sm {
    background: #4ade80;
    color: #0c1f10;
    border: none;
    border-radius: 0.4rem;
    padding: 0.38rem 0.7rem;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── History ─────────────────────────────────────────────────── */
  .history-section { margin: 1rem 0 3rem; }

  .history-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .history-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--card);
    border-radius: 0.5rem;
    padding: 0.48rem 0.8rem;
    font-size: 0.83rem;
  }

  .history-cat {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    min-width: 110px;
    font-weight: 500;
  }

  .history-dur {
    color: #4ade80;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    min-width: 70px;
  }

  .history-date { color: var(--muted); margin-left: auto; font-size: 0.76rem; }

  .empty-msg { color: var(--muted); font-size: 0.83rem; padding: 0.5rem 0; }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 700px) {
    .tracker-shell { grid-template-columns: 1fr; }
  }
</style>

<script>
import * as THREE from 'three';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
import { ConvexGeometry } from 'three/addons/geometries/ConvexGeometry.js';
import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';

// ── Types ─────────────────────────────────────────────────────────
interface Category {
  id: number;
  name: string;
  color: string;
}

interface StatsCat {
  id: number;
  name: string;
  color: string;
  axis: [number, number, number];
  total_seconds: number;
  proportion: number;
}

interface StatsResponse {
  categories: StatsCat[];
  total_seconds: number;
}

interface ActiveSession {
  id: number;
  category_id: number;
  started_at: string;
  category_name: string;
  color: string;
}

// ── State ─────────────────────────────────────────────────────────
const SHAPE_COLOR = 0x4ade80;
const MAX_R       = 1.8;
// Four tiny epsilon points near origin ensure ConvexGeometry always gets
// enough non-coplanar input regardless of how many categories exist.
const EPS_POINTS  = [
  new THREE.Vector3( 0.001,  0,      0    ),
  new THREE.Vector3( 0,      0.001,  0    ),
  new THREE.Vector3( 0,      0,      0.001),
  new THREE.Vector3(-0.001,  0,      0    ),
];

let apiBase = (localStorage.getItem('st-api') ?? 'http://localhost:8000').replace(/\/$/, '');
let categories: Category[]       = [];
let activeSession: ActiveSession | null = null;
let currentPeriod: 'today' | 'week' | 'year' | 'lifetime' = 'today';
let clockInterval: ReturnType<typeof setInterval> | null = null;
let wasConnected = false;

// ── Three.js globals ──────────────────────────────────────────────
let scene: THREE.Scene;
let camera: THREE.PerspectiveCamera;
let renderer: THREE.WebGLRenderer;
let controls: OrbitControls;
let polyGroup: THREE.Group | null = null;
let labelRenderer: CSS2DRenderer;
let vertexData: { pos: THREE.Vector3; tipPos: THREE.Vector3; labelPos: THREE.Vector3; name: string; proportion: number }[] = [];
let labelObjs: CSS2DObject[] = [];
let labelEls:  HTMLElement[] = [];
let canvasW = 400, canvasH = 400;

// ── API ───────────────────────────────────────────────────────────
async function api<T>(path: string, opts: RequestInit = {}): Promise<T> {
  const res = await fetch(`${apiBase}${path}`, {
    headers: { 'Content-Type': 'application/json' },
    ...opts,
  });
  if (!res.ok) throw new Error(await res.text());
  if (res.status === 204) return undefined as T;
  return res.json() as Promise<T>;
}

// ── Three.js setup ────────────────────────────────────────────────
function initThree(canvas: HTMLCanvasElement) {
  scene = new THREE.Scene();
  // Initialize module-level dims immediately so label projection is correct
  // before the async ResizeObserver fires.
  canvasW = canvas.clientWidth || 400;
  canvasH = canvas.clientHeight || 400;

  camera = new THREE.PerspectiveCamera(48, canvasW / canvasH, 0.1, 100);
  camera.position.set(0, 0, 4.2);

  renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(canvasW, canvasH, false);
  renderer.setClearColor(0x000000, 0);

  // Lights affect MeshPhongMaterial fill
  scene.add(new THREE.AmbientLight(0x405040, 2.0));
  const dir = new THREE.DirectionalLight(0xffffff, 2.2);
  dir.position.set(3, 4, 3);
  scene.add(dir);
  const fill = new THREE.DirectionalLight(0x80ffb0, 0.6);
  fill.position.set(-2, -2, -2);
  scene.add(fill);

  controls = new OrbitControls(camera, renderer.domElement);
  controls.enableDamping   = true;
  controls.dampingFactor   = 0.06;
  controls.rotateSpeed     = -1;
  controls.autoRotate      = true;
  controls.autoRotateSpeed = 0.5;
  controls.enableZoom      = true;
  controls.minDistance     = 2.0;
  controls.maxDistance     = 9.0;
  controls.enablePan       = false;

  // CSS2DRenderer overlays HTML labels exactly on top of the WebGL canvas.
  // It manages its own absolutely-positioned container and handles all 3D→2D
  // projection internally, so we never need to manually compute screen coords.
  labelRenderer = new CSS2DRenderer();
  labelRenderer.setSize(canvasW, canvasH);
  const lr = labelRenderer.domElement;
  lr.style.position = 'absolute';
  lr.style.top      = '0';
  lr.style.left     = '0';
  lr.style.width    = '100%';
  lr.style.height   = '100%';
  lr.style.pointerEvents = 'none';
  canvas.parentElement!.appendChild(lr);

  new ResizeObserver(() => {
    canvasW = canvas.clientWidth;
    canvasH = canvas.clientHeight;
    camera.aspect = canvasW / canvasH;
    camera.updateProjectionMatrix();
    renderer.setSize(canvasW, canvasH, false);
    labelRenderer.setSize(canvasW, canvasH);
  }).observe(canvas);

  animate();
}

// ── Polyhedron builder ────────────────────────────────────────────
function disposePolyGroup() {
  if (!polyGroup) return;
  scene.remove(polyGroup);
  polyGroup.children.forEach(child => {
    const c = child as any;
    if (c.geometry) c.geometry.dispose();
    if (c.material) {
      if (Array.isArray(c.material)) c.material.forEach((m: any) => m.dispose());
      else c.material.dispose();
    }
  });
  polyGroup = null;
}

function buildPolyhedron(cats: StatsCat[]) {
  disposePolyGroup();
  labelObjs.forEach(obj => scene.remove(obj));
  labelObjs = [];
  labelEls  = [];
  vertexData = [];

  const noData = document.getElementById('noDataMsg')!;

  if (cats.length === 0) {
    noData.hidden = false;
    return;
  }
  noData.hidden = true;

  // Position each vertex: 0-proportion → sits near origin (0.06),
  // full proportion → MAX_R out along its axis.
  vertexData = cats.map(c => {
    const pos = new THREE.Vector3(...c.axis).multiplyScalar(
      (c.proportion > 0 ? c.proportion : 0.06) * MAX_R
    );
    const dir = pos.clone().normalize();
    const tipPos   = pos.clone().addScaledVector(dir, 0.35); // leader line ends here
    const labelPos = pos.clone().addScaledVector(dir, 0.58); // label sits further out (gap)
    return { pos, tipPos, labelPos, name: c.name, proportion: c.proportion };
  });

  polyGroup = new THREE.Group();
  scene.add(polyGroup);

  // ── Convex hull fill + edges ──────────────────────────────────
  try {
    const hullPts = [...vertexData.map(v => v.pos), ...EPS_POINTS];
    const fillGeo = new ConvexGeometry(hullPts);

    // Semi-transparent green fill
    polyGroup.add(new THREE.Mesh(fillGeo, new THREE.MeshPhongMaterial({
      color:       SHAPE_COLOR,
      transparent: true,
      opacity:     0.18,
      side:        THREE.DoubleSide,
      depthWrite:  false,
      shininess:   15,
    })));

    // Opaque edge outline
    const edgeGeo = new THREE.EdgesGeometry(fillGeo);
    polyGroup.add(new THREE.LineSegments(edgeGeo, new THREE.LineBasicMaterial({
      color: SHAPE_COLOR,
    })));
  } catch (e) {
    console.warn('ConvexGeometry failed:', e);
  }

  // ── Spokes from origin to each vertex ────────────────────────
  const spokePts = vertexData.flatMap(v => [new THREE.Vector3(), v.pos.clone()]);
  const spokeGeo = new THREE.BufferGeometry().setFromPoints(spokePts);
  polyGroup.add(new THREE.LineSegments(spokeGeo, new THREE.LineBasicMaterial({
    color:       SHAPE_COLOR,
    transparent: true,
    opacity:     0.28,
  })));

  // ── Leader lines: short extension from vertex outward to label tip ──
  const leaderPts = vertexData.flatMap(v => [v.pos.clone(), v.tipPos.clone()]);
  const leaderGeo = new THREE.BufferGeometry().setFromPoints(leaderPts);
  polyGroup.add(new THREE.LineSegments(leaderGeo, new THREE.LineBasicMaterial({
    color: SHAPE_COLOR,
  })));

  // ── Vertex marker spheres ─────────────────────────────────────
  const markerGeo = new THREE.SphereGeometry(0.028, 10, 8);
  const markerMat = new THREE.MeshBasicMaterial({ color: SHAPE_COLOR });
  vertexData.forEach(v => {
    const m = new THREE.Mesh(markerGeo, markerMat);
    m.position.copy(v.pos);
    polyGroup!.add(m);
  });

  // ── CSS2D labels — positioned in world space, projected by CSS2DRenderer ──
  vertexData.forEach(v => {
    const pct = Math.round(v.proportion * 100);
    const el = document.createElement('div');
    el.className = 'vertex-label';
    el.textContent = pct > 0 ? `${v.name} ${pct}%` : v.name;
    const obj = new CSS2DObject(el);
    obj.position.copy(v.labelPos);
    scene.add(obj);
    labelObjs.push(obj);
    labelEls.push(el);
  });
}

// ── Animation loop ────────────────────────────────────────────────
function animate() {
  requestAnimationFrame(animate);
  controls.update();

  // Dim labels whose axis faces away from the camera (back side of the shape)
  vertexData.forEach((v, i) => {
    const label = labelEls[i];
    if (!label) return;
    // Positive dot = vertex axis points toward camera = front face
    label.style.opacity = v.pos.dot(camera.position) > 0 ? '1' : '0.28';
  });

  renderer.render(scene, camera);
  labelRenderer.render(scene, camera);
}

// ── UI helpers ────────────────────────────────────────────────────
function setConnected(ok: boolean) {
  document.getElementById('connDot')!.className   = 'conn-dot ' + (ok ? 'connected' : 'disconnected');
  document.getElementById('connLabel')!.textContent = ok ? 'Connected' : 'Not connected';
}

function fmtDuration(s: number): string {
  const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
  if (h > 0) return `${h}h ${m}m`;
  if (m > 0) return `${m}m ${sec}s`;
  return `${sec}s`;
}

function fmtElapsed(startedAt: string): string {
  const elapsed = Math.floor((Date.now() - new Date(startedAt + 'Z').getTime()) / 1000);
  const h = Math.floor(elapsed / 3600), m = Math.floor((elapsed % 3600) / 60), s = elapsed % 60;
  return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
}

function renderCategoryList(stats: StatsResponse | null) {
  const list   = document.getElementById('categoryList')!;
  const select = document.getElementById('categorySelect') as HTMLSelectElement;
  const saved  = select.value;

  list.innerHTML   = '';
  select.innerHTML = '<option value="">Select a skill…</option>';

  for (const cat of categories) {
    const sec = stats?.categories.find(c => c.id === cat.id)?.total_seconds ?? 0;

    const li = document.createElement('li');
    li.className = 'cat-item';
    li.innerHTML = `
      <span class="cat-dot"></span>
      <span class="cat-name">${cat.name}</span>
      <span class="cat-time">${sec > 0 ? fmtDuration(sec) : '—'}</span>
      <button class="cat-del" data-id="${cat.id}" title="Remove">✕</button>`;
    list.appendChild(li);

    const opt = document.createElement('option');
    opt.value = String(cat.id); opt.textContent = cat.name;
    select.appendChild(opt);
  }

  if (saved) select.value = saved;
  updateTimerBtn();
}

function renderHistory(sessions: any[]) {
  const list = document.getElementById('historyList')!;
  list.innerHTML = '';
  if (!sessions.length) {
    list.innerHTML = '<p class="empty-msg">No sessions logged yet.</p>';
    return;
  }
  sessions.slice(0, 15).forEach(s => {
    const d = new Date(s.started_at + 'Z');
    const dateStr = d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
    const timeStr = d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
    const el = document.createElement('div');
    el.className = 'history-item';
    el.innerHTML = `
      <span class="history-cat"><span class="cat-dot"></span>${s.category_name}</span>
      <span class="history-dur">${fmtDuration(s.duration_seconds)}</span>
      <span class="history-date">${dateStr} · ${timeStr}</span>`;
    list.appendChild(el);
  });
}

function startClock(startedAt: string) {
  stopClock();
  const banner = document.getElementById('activeBanner')!;
  const clock  = document.getElementById('activeClock')!;
  document.getElementById('activeCatName')!.textContent = activeSession?.category_name ?? '';
  banner.hidden = false;
  clock.textContent = fmtElapsed(startedAt);
  clockInterval = setInterval(() => { clock.textContent = fmtElapsed(startedAt); }, 1000);
}

function stopClock() {
  if (clockInterval) { clearInterval(clockInterval); clockInterval = null; }
  document.getElementById('activeBanner')!.hidden = true;
}

function updateTimerBtn() {
  const btn    = document.getElementById('timerBtn') as HTMLButtonElement;
  const label  = document.getElementById('timerBtnLabel')!;
  const select = document.getElementById('categorySelect') as HTMLSelectElement;
  if (activeSession) {
    btn.disabled = false; btn.classList.add('running'); label.textContent = '■ Stop';
  } else {
    btn.classList.remove('running'); label.textContent = '▶ Start';
    btn.disabled = !select.value || !wasConnected;
  }
}

// ── Data loading ──────────────────────────────────────────────────
async function loadAll() {
  const [cats, stats, sessions, active] = await Promise.all([
    api<Category[]>('/categories'),
    api<StatsResponse>(`/stats/${currentPeriod}`),
    api<any[]>('/sessions'),
    api<ActiveSession | null>('/sessions/active'),
  ]);
  categories = cats;
  buildPolyhedron(stats.categories);
  renderCategoryList(stats);
  renderHistory(sessions);
  activeSession = active;
  if (active) startClock(active.started_at); else stopClock();
  updateTimerBtn();
}

async function refreshStats() {
  try {
    const stats = await api<StatsResponse>(`/stats/${currentPeriod}`);
    buildPolyhedron(stats.categories);
    renderCategoryList(stats);
  } catch {}
}

// ── Connection ────────────────────────────────────────────────────
async function connect() {
  try {
    await api('/health');
    setConnected(true);
    wasConnected = true;
    await loadAll();
  } catch {
    setConnected(false);
    wasConnected = false;
    buildPolyhedron([]);
    updateTimerBtn();
  }
}

// ── Event handlers ────────────────────────────────────────────────
document.getElementById('settingsToggle')!.addEventListener('click', () => {
  const panel = document.getElementById('settingsPanel')!;
  panel.hidden = !panel.hidden;
  if (!panel.hidden)
    (document.getElementById('apiUrlInput') as HTMLInputElement).value = apiBase;
});

document.getElementById('connectBtn')!.addEventListener('click', async () => {
  const v = (document.getElementById('apiUrlInput') as HTMLInputElement).value.trim().replace(/\/$/, '');
  if (v) { apiBase = v; localStorage.setItem('st-api', apiBase); }
  document.getElementById('settingsPanel')!.hidden = true;
  await connect();
});

document.getElementById('apiUrlInput')!.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') (document.getElementById('connectBtn') as HTMLButtonElement).click();
});

document.getElementById('timerBtn')!.addEventListener('click', async () => {
  const select = document.getElementById('categorySelect') as HTMLSelectElement;
  if (activeSession) {
    try {
      await api(`/sessions/stop/${activeSession.id}`, { method: 'POST' });
      activeSession = null; stopClock(); updateTimerBtn();
      const [stats, sessions] = await Promise.all([
        api<StatsResponse>(`/stats/${currentPeriod}`),
        api<any[]>('/sessions'),
      ]);
      buildPolyhedron(stats.categories); renderCategoryList(stats); renderHistory(sessions);
    } catch (e) { console.error('Stop failed:', e); }
  } else {
    const catId = parseInt(select.value);
    if (!catId) return;
    try {
      const sess = await api<{ id: number; category_id: number; started_at: string }>('/sessions/start', {
        method: 'POST', body: JSON.stringify({ category_id: catId }),
      });
      const cat = categories.find(c => c.id === catId);
      activeSession = { ...sess, category_name: cat?.name ?? '', color: '' };
      startClock(sess.started_at); updateTimerBtn();
    } catch (e) { console.error('Start failed:', e); }
  }
});

document.getElementById('categorySelect')!.addEventListener('change', updateTimerBtn);

document.getElementById('addCatBtn')!.addEventListener('click', async () => {
  const nameEl = document.getElementById('newCatName') as HTMLInputElement;
  const name   = nameEl.value.trim();
  if (!name || !wasConnected) return;
  try {
    const cat = await api<Category>('/categories', {
      method: 'POST',
      body: JSON.stringify({ name, color: '#4ade80' }),
    });
    categories.push(cat);
    nameEl.value = '';
    await refreshStats();
  } catch (e) { console.error('Add category failed:', e); }
});

document.getElementById('newCatName')!.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') (document.getElementById('addCatBtn') as HTMLButtonElement).click();
});

document.getElementById('categoryList')!.addEventListener('click', async (e) => {
  const btn = (e.target as HTMLElement).closest('[data-id]') as HTMLElement | null;
  if (!btn) return;
  const id = parseInt(btn.dataset.id!);
  if (!confirm('Remove this skill? Past sessions are preserved.')) return;
  try {
    await api(`/categories/${id}`, { method: 'DELETE' });
    categories = categories.filter(c => c.id !== id);
    await refreshStats();
  } catch (e) { console.error('Delete failed:', e); }
});

document.querySelectorAll<HTMLButtonElement>('.period-tab').forEach(btn => {
  btn.addEventListener('click', async () => {
    document.querySelectorAll('.period-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentPeriod = btn.dataset.period as typeof currentPeriod;
    if (wasConnected) await refreshStats();
  });
});

// ── Init ──────────────────────────────────────────────────────────
const canvas = document.getElementById('blobCanvas') as HTMLCanvasElement;
initThree(canvas);

// Pre-fill saved URL; show settings panel open so user can Connect.
(document.getElementById('apiUrlInput') as HTMLInputElement).value = apiBase;
// Auto-connect only if the user has previously saved a URL.
if (localStorage.getItem('st-api')) {
  document.getElementById('settingsPanel')!.hidden = true;
  connect();
  setInterval(() => { if (wasConnected) refreshStats(); }, 15_000);
}
</script>
