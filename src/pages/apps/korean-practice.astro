---
import Layout from '../../layouts/Layout.astro';
import sentences from '../../data/korean-sentences.json';
import words from '../../data/korean-words.json';
import kor111 from '../../data/korean-kor111-unitized.json';

const kor111Units = [...new Set(kor111.map((x: any) => x.unit as number))]
  .sort((a, b) => a - b)
  .map(u => ({ num: u, title: (kor111 as any[]).find(x => x.unit === u)?.unitTitle ?? '' }));
---

<Layout
  title="Korean Practice | SqualieC"
  description="Read or dictation-practice Korean with pre-rendered Microsoft Edge SunHiNeural TTS audio."
>
  <section class="hero hero-surface">
    <p class="eyebrow">Online Tool</p>
    <h1>Korean Practice</h1>
    <p class="lead">
      Practice reading or listening to Korean. Uses pre-rendered Microsoft Edge neural Korean TTS (SunHi) for
      high-quality playback.
    </p>
  </section>

  <section class="card section-title practice-shell">
    <!-- Reading / Dictation toggle -->
    <div class="mode-toggle">
      <button id="readingTab" class="mode-tab active" type="button">Reading</button>
      <button id="dictationTab" class="mode-tab" type="button">Dictation</button>
      <button id="readAlongTab" class="mode-tab" type="button">Read Along</button>
      <button id="srsTab" class="mode-tab" type="button">SRS</button>
    </div>

    <div class="control-row">
      <label for="modeSelect">Mode</label>
      <select id="modeSelect" aria-label="Practice mode">
        <option value="sentences">Everyday Sentences</option>
        <option value="words">Beginner Words</option>
        <option value="kor111">KOR111 Unitized Vocabulary</option>
      </select>

      <label for="voiceSelect">Fallback Voice</label>
      <select id="voiceSelect" aria-label="Fallback voice selection"></select>

      <label for="rateRange">Rate</label>
      <input id="rateRange" type="range" min="0.7" max="1.2" step="0.05" value="0.95" />
    </div>

    <div id="unitFilterRow" class="unit-filter-row hidden">
      <span class="unit-filter-label">Units</span>
      <label class="unit-chip">
        <input id="unitAllToggle" type="checkbox" checked />
        All
      </label>
      <label class="unit-chip">
        <input id="unit1Toggle" type="checkbox" checked />
        Unit 1
      </label>
      <label class="unit-chip">
        <input id="unit2Toggle" type="checkbox" checked />
        Unit 2
      </label>
      <label class="unit-chip">
        <input id="unit3Toggle" type="checkbox" checked />
        Unit 3
      </label>
    </div>

    <!-- ── READING PANEL ─────────────────────────────────────── -->
    <div id="readingPanel">
      <section id="koreanText" class="sentence" aria-live="polite">Loading...</section>
      <section id="englishText" class="translation hidden" aria-live="polite"></section>
      <section id="itemMeta" class="item-meta hidden" aria-live="polite"></section>

      <div class="btn-row">
        <button id="newBtn" class="btn btn-primary" type="button">New Item</button>
        <button id="revealPlayBtn" class="btn btn-secondary" type="button">Reveal + Play</button>
        <button id="playBtn" class="btn btn-secondary" type="button">Play Again</button>
        <button id="srsAddCurrentBtn" class="btn btn-secondary" type="button">+ SRS</button>
      </div>

      <div id="readStatus" class="status"></div>
    </div>

    <!-- ── DICTATION PANEL ───────────────────────────────────── -->
    <div id="dictationPanel" class="hidden">
      <div class="dict-audio-row">
        <button id="dictPlayBtn" class="btn btn-primary" type="button">&#128266; Play Audio</button>
        <button id="dictSkipBtn" class="btn btn-secondary" type="button">Skip</button>
        <div id="dictStatus" class="status dict-status"></div>
      </div>

      <div class="dict-input-row">
        <input
          id="dictInput"
          type="text"
          lang="ko"
          autocomplete="off"
          spellcheck="false"
          placeholder="한국어로 입력하세요…"
          class="dict-input"
        />
        <button id="dictSubmitBtn" class="btn btn-primary" type="button">Submit</button>
      </div>

      <div id="dictResult" class="hidden"></div>

      <div id="dictNextRow" class="btn-row hidden">
        <button id="dictNextBtn" class="btn btn-primary" type="button">Next &#8594;</button>
      </div>

      <!-- Hangul keyboard layout reference -->
      <div class="kb-section">
        <p class="kb-title">Hangul Keyboard Layout (두벌식)</p>
        <div class="kb-wrap">
          <!-- Row 1: QWERTYUIOP -->
          <div class="kb-row">
            <div class="kb-key" data-char="ㅂ" data-shift="ㅃ"><span class="qwerty">Q</span><span class="sh">ㅃ</span>ㅂ</div>
            <div class="kb-key" data-char="ㅈ" data-shift="ㅉ"><span class="qwerty">W</span><span class="sh">ㅉ</span>ㅈ</div>
            <div class="kb-key" data-char="ㄷ" data-shift="ㄸ"><span class="qwerty">E</span><span class="sh">ㄸ</span>ㄷ</div>
            <div class="kb-key" data-char="ㄱ" data-shift="ㄲ"><span class="qwerty">R</span><span class="sh">ㄲ</span>ㄱ</div>
            <div class="kb-key" data-char="ㅅ" data-shift="ㅆ"><span class="qwerty">T</span><span class="sh">ㅆ</span>ㅅ</div>
            <div class="kb-key" data-char="ㅛ"><span class="qwerty">Y</span>ㅛ</div>
            <div class="kb-key" data-char="ㅕ"><span class="qwerty">U</span>ㅕ</div>
            <div class="kb-key" data-char="ㅑ"><span class="qwerty">I</span>ㅑ</div>
            <div class="kb-key" data-char="ㅐ"><span class="qwerty">O</span>ㅐ</div>
            <div class="kb-key" data-char="ㅔ"><span class="qwerty">P</span>ㅔ</div>
          </div>
          <!-- Row 2: ASDFGHJKL -->
          <div class="kb-row kb-row-2">
            <div class="kb-key" data-char="ㅁ"><span class="qwerty">A</span>ㅁ</div>
            <div class="kb-key" data-char="ㄴ"><span class="qwerty">S</span>ㄴ</div>
            <div class="kb-key" data-char="ㅇ"><span class="qwerty">D</span>ㅇ</div>
            <div class="kb-key" data-char="ㄹ"><span class="qwerty">F</span>ㄹ</div>
            <div class="kb-key" data-char="ㅎ"><span class="qwerty">G</span>ㅎ</div>
            <div class="kb-key" data-char="ㅗ"><span class="qwerty">H</span>ㅗ</div>
            <div class="kb-key" data-char="ㅓ"><span class="qwerty">J</span>ㅓ</div>
            <div class="kb-key" data-char="ㅏ"><span class="qwerty">K</span>ㅏ</div>
            <div class="kb-key" data-char="ㅣ"><span class="qwerty">L</span>ㅣ</div>
          </div>
          <!-- Row 3: ZXCVBNM -->
          <div class="kb-row kb-row-3">
            <div class="kb-key" data-char="ㅋ"><span class="qwerty">Z</span>ㅋ</div>
            <div class="kb-key" data-char="ㅌ"><span class="qwerty">X</span>ㅌ</div>
            <div class="kb-key" data-char="ㅊ"><span class="qwerty">C</span>ㅊ</div>
            <div class="kb-key" data-char="ㅍ"><span class="qwerty">V</span>ㅍ</div>
            <div class="kb-key" data-char="ㅠ"><span class="qwerty">B</span>ㅠ</div>
            <div class="kb-key" data-char="ㅜ"><span class="qwerty">N</span>ㅜ</div>
            <div class="kb-key" data-char="ㅡ"><span class="qwerty">M</span>ㅡ</div>
          </div>
          <!-- Space and backspace -->
          <div class="kb-row kb-row-btm">
            <div class="kb-key kb-space" data-char=" ">SPACE</div>
            <div class="kb-key kb-bksp"  data-char="backspace">⌫</div>
          </div>
        </div>
        <p class="kb-note">Click keys to type. Shift+click Q–T for ㅃㅉㄸㄲㅆ. Or use Korean IME (한/영 / Alt+Shift).</p>
      </div>
    </div>

    <!-- ── READ ALONG PANEL ──────────────────────────────── -->
    <div id="readAlongPanel" class="hidden">
      <div id="raText" class="sentence ra-text" aria-live="polite"></div>

      <div class="ra-progress-wrap">
        <div id="raProgressFill" class="ra-progress-fill"></div>
      </div>

      <div id="raEnglish" class="translation hidden"></div>

      <div class="btn-row">
        <button id="raStartBtn" class="btn btn-primary" type="button">Start</button>
        <button id="raPauseBtn" class="btn btn-secondary" type="button" disabled>Pause</button>
        <button id="raNewBtn" class="btn btn-secondary" type="button">New Item</button>
      </div>

      <div id="raStatus" class="status"></div>
    </div>

    <!-- ── SRS PANEL ─────────────────────────────────────────── -->
    <div id="srsPanel" class="hidden">
      <div class="mode-toggle" style="margin-bottom:0.75rem">
        <button id="srsModeBtn"    class="mode-tab active" type="button">SRS</button>
        <button id="flashModeBtn"  class="mode-tab"        type="button">Flashcard</button>
        <button id="browseModeBtn" class="mode-tab"        type="button">Browse</button>
      </div>

      <div id="srsStatsRow" class="srs-stats-row">
        <span class="srs-stat"><strong id="srsDueCount">0</strong> due today</span>
        <span class="srs-stat"><strong id="srsTotalCount">0</strong> total cards</span>
      </div>
      <div id="flashStatsRow" class="srs-stats-row hidden">
        <span class="srs-stat"><strong id="flashRemainingCount">0</strong> remaining</span>
        <span class="srs-stat"><strong id="flashMasteredCount">0</strong> mastered</span>
      </div>

      <div class="srs-card-area">
        <div id="srsFront" class="srs-front hidden"></div>
        <div id="srsBack"  class="srs-back  hidden"></div>
        <div id="srsEmptyMsg" class="srs-message hidden">No cards yet for the selected units. They will appear here once added.</div>
        <div id="srsDoneMsg"  class="srs-message hidden">All done for today! Come back tomorrow.</div>
        <div id="flashDoneMsg" class="srs-message hidden">
          Session complete!
          <button id="flashRestartBtn" class="btn btn-secondary" type="button" style="margin-top:0.5rem">Restart</button>
        </div>
      </div>

      <div id="srsActionRow" class="btn-row">
        <button id="srsRevealBtn" class="btn btn-primary hidden" type="button">Show Answer</button>
        <button id="srsReplayBtn" class="btn btn-secondary hidden" type="button">&#128266; Replay</button>
      </div>

      <div id="srsRatingRow" class="btn-row hidden">
        <button id="srsAgainBtn" class="btn srs-btn-again" type="button">Again</button>
        <button id="srsHardBtn"  class="btn srs-btn-hard"  type="button">Hard</button>
        <button id="srsGoodBtn"  class="btn srs-btn-good"  type="button">Good</button>
        <button id="srsEasyBtn"  class="btn srs-btn-easy"  type="button">Easy</button>
      </div>
      <div id="flashRatingRow" class="btn-row hidden">
        <button id="flashAgainBtn" class="btn srs-btn-again" type="button">Again</button>
        <button id="flashGotItBtn" class="btn srs-btn-good"  type="button">Got It!</button>
      </div>

      <!-- Browse Panel -->
      <div id="browsePanel" class="hidden">
        <div class="browse-toolbar">
          <select id="browsePoolFilter" class="browse-filter-select">
            <option value="">All pools</option>
          </select>
          <span id="browseSelInfo" class="browse-sel-info"></span>
          <div id="browseActions" class="browse-actions hidden">
            <button id="browseDueNowBtn" class="btn btn-secondary" type="button">Due Now</button>
            <input id="browseDatePicker" type="date" class="browse-date-input" />
            <button id="browseSetDateBtn" class="btn btn-secondary" type="button">Set Date</button>
          </div>
        </div>
        <div class="browse-table-wrap">
          <table class="browse-table">
            <thead>
              <tr>
                <th class="browse-th-cb"><input type="checkbox" id="browseSelectAll" /></th>
                <th>Front</th>
                <th>Back</th>
                <th>Pool</th>
                <th>Due</th>
                <th>Shown</th>
                <th>Good %</th>
              </tr>
            </thead>
            <tbody id="browseTableBody"></tbody>
          </table>
        </div>
      </div>

      <!-- Units to study -->
      <div class="srs-units-section">
        <p class="srs-add-label">Units to study</p>
        <div class="srs-unit-checks">
          <label class="unit-chip">
            <input type="checkbox" class="srs-pool-check" data-pool="sentences" />
            Everyday Sentences
          </label>
          <label class="unit-chip">
            <input type="checkbox" class="srs-pool-check" data-pool="words" />
            Beginner Words
          </label>
          {kor111Units.map(u => (
            <label class="unit-chip">
              <input type="checkbox" class="srs-pool-check" data-pool="kor111" data-unit={String(u.num)} />
              KOR111 Unit {u.num}
            </label>
          ))}
        </div>
      </div>

      <!-- Cloud Sync -->
      <div id="srsSyncSection" class="srs-sync-section">
        <p class="srs-add-label">Cloud Sync</p>
        <p id="srsSyncMsg" class="srs-sync-msg"></p>
        <!-- Not logged in -->
        <div id="srsSyncGuestRow" class="hidden">
          <p class="srs-sync-hint">Log in from the header to sync your cards across devices.</p>
        </div>
        <!-- Logged in -->
        <div id="srsSyncActiveRow" class="hidden">
          <div class="srs-user-row">
            <span id="srsUserEmailDisplay" class="srs-user-email"></span>
            <span id="srsLastSyncedEl" class="srs-last-synced"></span>
          </div>
          <div class="btn-row">
            <button id="srsSyncNowBtn" class="btn btn-secondary" type="button">Sync now</button>
          </div>
        </div>
      </div>
    </div>

    <p class="hint">
      Playback uses pre-rendered <code>ko-KR-SunHiNeural</code> audio first. Browser voice is used as fallback.
      Read Along highlights each syllable in sync with the SunHi audio; Rate slider adjusts playback speed.
    </p>
  </section>
</Layout>

<script define:vars={{ sentences, words, kor111 }}>
  // ── Elements ──────────────────────────────────────────────
  const modeSelect    = document.getElementById("modeSelect");
  const voiceSelect   = document.getElementById("voiceSelect");
  const rateRange     = document.getElementById("rateRange");
  const readingTab    = document.getElementById("readingTab");
  const dictationTab  = document.getElementById("dictationTab");
  const readAlongTab  = document.getElementById("readAlongTab");
  const readingPanel  = document.getElementById("readingPanel");
  const dictationPanel = document.getElementById("dictationPanel");
  const readAlongPanel = document.getElementById("readAlongPanel");

  // Read Along
  const raTextEl       = document.getElementById("raText");
  const raProgressFill = document.getElementById("raProgressFill");
  const raEnglishEl    = document.getElementById("raEnglish");
  const raStartBtn     = document.getElementById("raStartBtn");
  const raPauseBtn     = document.getElementById("raPauseBtn");
  const raNewBtn       = document.getElementById("raNewBtn");
  const raStatusEl     = document.getElementById("raStatus");
  const unitFilterRow = document.getElementById("unitFilterRow");
  const unitAllToggle = document.getElementById("unitAllToggle");
  const unit1Toggle   = document.getElementById("unit1Toggle");
  const unit2Toggle   = document.getElementById("unit2Toggle");
  const unit3Toggle   = document.getElementById("unit3Toggle");

  // Reading
  const koreanTextEl  = document.getElementById("koreanText");
  const englishTextEl = document.getElementById("englishText");
  const itemMetaEl    = document.getElementById("itemMeta");
  const readStatus    = document.getElementById("readStatus");
  const newBtn        = document.getElementById("newBtn");
  const revealPlayBtn = document.getElementById("revealPlayBtn");
  const playBtn       = document.getElementById("playBtn");

  // Dictation
  const dictPlayBtn   = document.getElementById("dictPlayBtn");
  const dictSkipBtn   = document.getElementById("dictSkipBtn");
  const dictStatus    = document.getElementById("dictStatus");
  const dictInput     = document.getElementById("dictInput");
  const dictSubmitBtn = document.getElementById("dictSubmitBtn");
  const dictResult    = document.getElementById("dictResult");
  const dictNextRow   = document.getElementById("dictNextRow");
  const dictNextBtn   = document.getElementById("dictNextBtn");

  // SRS
  const srsTab          = document.getElementById("srsTab");
  const srsPanel        = document.getElementById("srsPanel");
  const srsFrontEl      = document.getElementById("srsFront");
  const srsBackEl       = document.getElementById("srsBack");
  const srsEmptyMsgEl   = document.getElementById("srsEmptyMsg");
  const srsDoneMsgEl    = document.getElementById("srsDoneMsg");
  const srsRevealBtn    = document.getElementById("srsRevealBtn");
  const srsReplayBtn    = document.getElementById("srsReplayBtn");
  const srsRatingRow    = document.getElementById("srsRatingRow");
  const srsAgainBtn     = document.getElementById("srsAgainBtn");
  const srsHardBtn      = document.getElementById("srsHardBtn");
  const srsGoodBtn      = document.getElementById("srsGoodBtn");
  const srsEasyBtn      = document.getElementById("srsEasyBtn");
  const srsDueCountEl   = document.getElementById("srsDueCount");
  const srsTotalCountEl = document.getElementById("srsTotalCount");
  const srsAddCurrentBtn  = document.getElementById("srsAddCurrentBtn");
  const srsModeBtn        = document.getElementById("srsModeBtn");
  const flashModeBtn      = document.getElementById("flashModeBtn");
  const srsStatsRow       = document.getElementById("srsStatsRow");
  const flashStatsRow     = document.getElementById("flashStatsRow");
  const flashRemainingEl  = document.getElementById("flashRemainingCount");
  const flashMasteredEl   = document.getElementById("flashMasteredCount");
  const flashDoneMsgEl    = document.getElementById("flashDoneMsg");
  const flashRestartBtn   = document.getElementById("flashRestartBtn");
  const flashRatingRow    = document.getElementById("flashRatingRow");
  const flashAgainBtn     = document.getElementById("flashAgainBtn");
  const flashGotItBtn     = document.getElementById("flashGotItBtn");
  const srsActionRow      = document.getElementById("srsActionRow");
  const browseModeBtn     = document.getElementById("browseModeBtn");
  const browsePanel       = document.getElementById("browsePanel");
  const browsePoolFilter  = document.getElementById("browsePoolFilter");
  const browseSelInfoEl   = document.getElementById("browseSelInfo");
  const browseActionsEl   = document.getElementById("browseActions");
  const browseDueNowBtn   = document.getElementById("browseDueNowBtn");
  const browseDatePickerEl= document.getElementById("browseDatePicker");
  const browseSetDateBtn  = document.getElementById("browseSetDateBtn");
  const browseSelectAllEl = document.getElementById("browseSelectAll");
  const browseTableBodyEl = document.getElementById("browseTableBody");

  // ── State ─────────────────────────────────────────────────
  const pools = { sentences, words, kor111 };
  const PREFETCHED_AUDIO_BASE = "/audio/korean";
  const ALL_UNITS = [1, 2, 3];
  const unitToggles = [unit1Toggle, unit2Toggle, unit3Toggle];

  let current    = null;
  let activeAudio = null;
  let appMode    = "reading";  // "reading" | "dictation" | "readalong"
  let dictState  = "ready";    // "ready" | "wrong" | "correct"
  let selectedUnits = new Set(ALL_UNITS);

  // Read Along state
  let raState  = "idle";  // "idle" | "running" | "paused" | "done"
  let raTokens = [];
  let raIndex  = 0;
  let raAudio  = null;

  // ── Mode switching ─────────────────────────────────────────
  readingTab.addEventListener("click",   () => switchAppMode("reading"));
  dictationTab.addEventListener("click", () => switchAppMode("dictation"));
  readAlongTab.addEventListener("click", () => switchAppMode("readalong"));

  function switchAppMode(mode) {
    appMode = mode;
    stopPlayback();
    stopReadAlong();
    readingTab.classList.toggle("active",     mode === "reading");
    dictationTab.classList.toggle("active",   mode === "dictation");
    readAlongTab.classList.toggle("active",   mode === "readalong");
    srsTab.classList.toggle("active",         mode === "srs");
    readingPanel.classList.toggle("hidden",   mode !== "reading");
    dictationPanel.classList.toggle("hidden", mode !== "dictation");
    readAlongPanel.classList.toggle("hidden", mode !== "readalong");
    srsPanel.classList.toggle("hidden",       mode !== "srs");
    applyUnitFilterVisibility();
    if (mode !== "srs") loadNewItem();
    else { refreshSrsPanel(); syncFetchCards().then(refreshSrsPanel); }
  }

  // ── Audio utilities ────────────────────────────────────────
  function stopPlayback() {
    if (activeAudio) {
      activeAudio.pause();
      activeAudio.currentTime = 0;
      activeAudio = null;
    }
    if ("speechSynthesis" in window) window.speechSynthesis.cancel();
  }

  function getPrefetchedAudioUrl(item) {
    if (!item || item._mode === undefined) return null;
    if (item._mode === "kor111") {
      if (!item.audioFile) return null;
      return `${PREFETCHED_AUDIO_BASE}/kor111/${item.audioFile}`;
    }
    if (item._index === undefined) return null;
    return `${PREFETCHED_AUDIO_BASE}/${item._mode}/${item._index}.mp3`;
  }

  async function playPreRenderedAudio(item, setStatus) {
    const url = getPrefetchedAudioUrl(item);
    if (!url) return false;
    try {
      const audio = new Audio(url);
      audio.playbackRate = Number(rateRange.value || 0.95);
      activeAudio = audio;
      audio.onended = () => { if (activeAudio === audio) activeAudio = null; setStatus(""); };
      audio.onerror = () => { if (activeAudio === audio) activeAudio = null; };
      setStatus("Playing SunHi neural audio...");
      await audio.play();
      return true;
    } catch {
      if (activeAudio) activeAudio = null;
      return false;
    }
  }

  function speakBrowserVoice(text, setStatus) {
    if (!("speechSynthesis" in window)) { setStatus("Speech synthesis not supported."); return; }
    if (!text) return;
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = "ko-KR";
    utterance.rate = Number(rateRange.value || 0.95);
    const voices   = getKoreanVoices();
    const selected = voices.find(v => v.voiceURI === voiceSelect.value);
    if (selected) utterance.voice = selected;
    utterance.onstart = () => setStatus("Using fallback browser voice...");
    utterance.onend   = () => setStatus("");
    utterance.onerror = () => setStatus("Could not play audio.");
    window.speechSynthesis.cancel();
    window.speechSynthesis.speak(utterance);
  }

  async function speakKorean(item, setStatus) {
    if (!item || !item.korean) return;
    stopPlayback();
    const played = await playPreRenderedAudio(item, setStatus);
    if (!played) speakBrowserVoice(item.korean, setStatus);
  }

  // ── Voice select ───────────────────────────────────────────
  function getKoreanVoices() {
    if (!("speechSynthesis" in window)) return [];
    return window.speechSynthesis.getVoices()
      .filter(v => v.lang && v.lang.toLowerCase().startsWith("ko"))
      .sort((a, b) => {
        const rank = v => {
          const n = `${v.name} ${v.voiceURI}`.toLowerCase();
          if (n.includes("sunhi")) return 0;
          if (n.includes("online") && n.includes("korean")) return 1;
          if (n.includes("neural") && n.includes("korean")) return 2;
          if (n.includes("korean")) return 3;
          return 10;
        };
        return rank(a) - rank(b) || a.name.localeCompare(b.name);
      });
  }

  function populateVoiceSelect() {
    const voices = getKoreanVoices();
    const prev   = voiceSelect.value;
    voiceSelect.innerHTML = "";
    if (!voices.length) {
      const opt = document.createElement("option");
      opt.value = ""; opt.textContent = "No Korean fallback voice found";
      voiceSelect.appendChild(opt); return;
    }
    voices.forEach((v, i) => {
      const opt = document.createElement("option");
      opt.value = v.voiceURI;
      opt.textContent = `${v.name} (${v.lang})`;
      if (prev ? prev === v.voiceURI : i === 0) opt.selected = true;
      voiceSelect.appendChild(opt);
    });
  }

  // ── Random item ────────────────────────────────────────────
  function isKor111Mode() {
    return modeSelect.value === "kor111";
  }

  function syncUnitControlsFromState() {
    unitToggles.forEach((toggle, idx) => {
      toggle.checked = selectedUnits.has(ALL_UNITS[idx]);
    });
    unitAllToggle.checked = ALL_UNITS.every(unit => selectedUnits.has(unit));
  }

  function applyUnitFilterVisibility() {
    unitFilterRow.classList.toggle("hidden", appMode === "srs" || !isKor111Mode());
  }

  function filteredKor111Pool() {
    return pools.kor111.filter(item => selectedUnits.has(Number(item.unit)));
  }

  function randomItem() {
    const mode = modeSelect.value;
    let pool = [];
    if (mode === "kor111") {
      pool = filteredKor111Pool();
    } else if (mode === "words") {
      pool = pools.words || [];
    } else {
      pool = pools.sentences || [];
    }
    if (!pool.length) return null;
    const index = Math.floor(Math.random() * pool.length);
    return { ...pool[index], _index: index, _mode: mode };
  }

  function setPracticeDisabled(disabled) {
    newBtn.disabled = disabled;
    revealPlayBtn.disabled = disabled;
    playBtn.disabled = disabled;
    dictPlayBtn.disabled = disabled;
    dictSkipBtn.disabled = disabled;
    dictNextBtn.disabled = disabled;
    raNewBtn.disabled = disabled;
    if (disabled) { raStartBtn.disabled = true; raPauseBtn.disabled = true; }
  }

  function metadataHtml(item) {
    if (!item || item._mode !== "kor111") return "";
    const bits = [`Unit ${item.unit}`, item.section, item.category]
      .filter(Boolean)
      .map(part => `<span class="meta-badge">${esc(String(part))}</span>`)
      .join("");
    return bits ? `<div class="meta-badges">${bits}</div>` : "";
  }

  function renderItemMeta(item) {
    const html = metadataHtml(item);
    if (!html) {
      itemMetaEl.innerHTML = "";
      itemMetaEl.classList.add("hidden");
      return;
    }
    itemMetaEl.innerHTML = html;
    itemMetaEl.classList.remove("hidden");
  }

  function renderNoUnitSelectionState() {
    current = null;
    setPracticeDisabled(true);
    setReadStatus("");
    setDictStatus("");
    renderItemMeta(null);

    if (appMode === "reading") {
      koreanTextEl.textContent = "Select at least one KOR111 unit to continue.";
      englishTextEl.textContent = "";
      englishTextEl.classList.add("hidden");
      setReadStatus("No units selected.");
      return;
    }

    resetHangulCompose();
    dictInput.value = "";
    dictInput.disabled = true;
    dictSubmitBtn.disabled = true;
    dictResult.className = "result-box result-info";
    dictResult.innerHTML =
      "<strong>Choose at least one unit.</strong>" +
      '<span class="result-english">Enable Unit 1, Unit 2, or Unit 3 to continue dictation.</span>';
    dictResult.classList.remove("hidden");
    dictNextRow.classList.add("hidden");
    setDictStatus("No units selected.");
  }

  // ── Load new item ──────────────────────────────────────────
  function loadNewItem() {
    stopPlayback();
    current = randomItem();
    if (!current) {
      renderNoUnitSelectionState();
      return;
    }
    setPracticeDisabled(false);
    dictNextBtn.disabled = false;
    if (appMode === "reading") {
      renderReading(current);
    } else if (appMode === "dictation") {
      renderDictation(current);
    } else {
      renderReadAlong(current);
    }
  }

  modeSelect.addEventListener("change", () => {
    applyUnitFilterVisibility();
    loadNewItem();
  });

  rateRange.addEventListener("input", () => {
    if (raAudio) raAudio.playbackRate = Number(rateRange.value || 0.95);
  });

  unitAllToggle.addEventListener("change", () => {
    if (unitAllToggle.checked) {
      selectedUnits = new Set(ALL_UNITS);
    } else {
      selectedUnits = new Set();
    }
    syncUnitControlsFromState();
    if (isKor111Mode()) loadNewItem();
  });

  unitToggles.forEach((toggle, idx) => {
    toggle.addEventListener("change", () => {
      const unit = ALL_UNITS[idx];
      if (toggle.checked) {
        selectedUnits.add(unit);
      } else {
        selectedUnits.delete(unit);
      }
      syncUnitControlsFromState();
      if (isKor111Mode()) loadNewItem();
    });
  });

  // ── Reading mode ───────────────────────────────────────────
  function renderReading(item) {
    koreanTextEl.textContent = item.korean;
    englishTextEl.textContent = item.english;
    englishTextEl.classList.add("hidden");
    renderItemMeta(item);
    setReadStatus("");
    const key = `${item._mode}:${item.korean}`;
    const inSrs = srsDb.cards[key] !== undefined;
    srsAddCurrentBtn.textContent = inSrs ? "✓ In SRS" : "+ SRS";
    srsAddCurrentBtn.disabled = inSrs;
  }

  function setReadStatus(msg) { readStatus.textContent = msg || ""; }

  newBtn.addEventListener("click", loadNewItem);
  revealPlayBtn.addEventListener("click", async () => {
    englishTextEl.classList.remove("hidden");
    await speakKorean(current, setReadStatus);
  });
  playBtn.addEventListener("click", () => speakKorean(current, setReadStatus));

  // ── Dictation mode ─────────────────────────────────────────
  function renderDictation(item) {
    resetHangulCompose();
    dictInput.value = "";
    dictInput.disabled = false;
    dictSubmitBtn.disabled = false;
    dictResult.classList.add("hidden");
    dictResult.innerHTML = "";
    dictNextRow.classList.add("hidden");
    dictState = "ready";
    speakKorean(item, setDictStatus);
    setTimeout(() => dictInput.focus(), 200);
  }

  function setDictStatus(msg) { dictStatus.textContent = msg || ""; }

  dictPlayBtn.addEventListener("click",  () => speakKorean(current, setDictStatus));
  dictSkipBtn.addEventListener("click",  loadNewItem);
  dictNextBtn.addEventListener("click",  loadNewItem);
  dictSubmitBtn.addEventListener("click", submitDictation);

  dictInput.addEventListener("keydown", e => {
    if (e.key === "Enter" && !e.isComposing) submitDictation();
  });

  function submitDictation() {
    if (!current || dictState === "correct") return;
    const typed   = dictInput.value.trim();
    const correct = current.korean.trim();
    if (!typed) return;

    if (koreanMatch(typed, correct)) {
      dictState = "correct";
      dictInput.disabled = true;
      dictSubmitBtn.disabled = true;
      dictResult.className = "result-box result-correct";
      dictResult.innerHTML =
        `<strong>&#10003; Correct!</strong>` +
        `<span class="result-korean">${esc(correct)}</span>` +
        `<span class="result-english">${esc(current.english)}</span>` +
        metadataHtml(current);
      dictResult.classList.remove("hidden");
      dictNextRow.classList.remove("hidden");
    } else {
      dictState = "wrong";
      resetHangulCompose();
      dictInput.value = "";
      dictResult.className = "result-box result-wrong";
      dictResult.innerHTML =
        `<strong>&#10007; Incorrect - type the correct answer to continue:</strong>` +
        `<span class="result-korean">${esc(correct)}</span>` +
        metadataHtml(current);
      dictResult.classList.remove("hidden");
      dictInput.focus();
    }
  }

  function esc(str) {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }

  // ── Korean jamo comparison ─────────────────────────────────
  function decomposeHangul(str) {
    const CHO  = 'ㄱㄲㄴㄷㄸㄹㅁㅂㅃㅅㅆㅇㅈㅉㅊㅋㅌㅍㅎ';
    const JUNG = 'ㅏㅐㅑㅒㅓㅔㅕㅖㅗㅘㅙㅚㅛㅜㅝㅞㅟㅠㅡㅢㅣ';
    const JONG = ' ㄱㄲㄳㄴㄵㄶㄷㄹㄺㄻㄼㄽㄾㄿㅀㅁㅂㅄㅅㅆㅇㅈㅊㅋㅌㅍㅎ';
    let result = '';
    for (const ch of str) {
      const code = ch.charCodeAt(0);
      if (code >= 0xAC00 && code <= 0xD7A3) {
        const s    = code - 0xAC00;
        const jong = s % 28;
        const jung = Math.floor(s / 28) % 21;
        const cho  = Math.floor(s / 588);
        result += CHO[cho] + JUNG[jung] + (jong ? JONG[jong] : '');
      } else {
        result += ch;
      }
    }
    return result;
  }

  function koreanMatch(a, b) {
    return decomposeHangul(a.trim()) === decomposeHangul(b.trim());
  }

  // ── Hangul Syllable Composer ───────────────────────────────
  // Implements 두벌식 composition: clicking keys builds real syllable
  // blocks (한글) exactly like a Korean IME.
  const _CHO  = ['ㄱ','ㄲ','ㄴ','ㄷ','ㄸ','ㄹ','ㅁ','ㅂ','ㅃ','ㅅ','ㅆ','ㅇ','ㅈ','ㅉ','ㅊ','ㅋ','ㅌ','ㅍ','ㅎ'];
  const _JUNG = ['ㅏ','ㅐ','ㅑ','ㅒ','ㅓ','ㅔ','ㅕ','ㅖ','ㅗ','ㅘ','ㅙ','ㅚ','ㅛ','ㅜ','ㅝ','ㅞ','ㅟ','ㅠ','ㅡ','ㅢ','ㅣ'];
  const _choIdx  = Object.fromEntries(_CHO.map((c,i)  => [c,i]));
  const _jungIdx = Object.fromEntries(_JUNG.map((c,i) => [c,i]));
  const _jamoJong = {'ㄱ':1,'ㄲ':2,'ㄴ':4,'ㄷ':7,'ㄹ':8,'ㅁ':16,'ㅂ':17,'ㅅ':19,'ㅆ':20,'ㅇ':21,'ㅈ':22,'ㅊ':23,'ㅋ':24,'ㅌ':25,'ㅍ':26,'ㅎ':27};
  const _jongCho  = {1:0,2:1,4:2,7:3,8:5,16:6,17:7,19:9,20:10,21:11,22:12,23:14,24:15,25:16,26:17,27:18};
  const _compJung = {'8,0':9,'8,1':10,'8,20':11,'13,4':14,'13,5':15,'13,20':16,'18,20':19};
  const _compJungFirst = {9:8,10:8,11:8,14:13,15:13,16:13,19:18};
  const _compJong = {'1,9':3,'4,12':5,'4,18':6,'8,0':9,'8,6':10,'8,7':11,'8,9':12,'8,16':13,'8,17':14,'8,18':15,'17,9':18};
  const _jongSplit = {3:[1,9],5:[4,12],6:[4,18],9:[8,0],10:[8,6],11:[8,7],12:[8,9],13:[8,16],14:[8,17],15:[8,18],18:[17,9]};
  const _compJongFirst = Object.fromEntries(Object.entries(_jongSplit).map(([k,v]) => [+k, v[0]]));

  function _syl(cho, jung, jong) {
    return String.fromCharCode(0xAC00 + (cho * 21 + jung) * 28 + jong);
  }

  const _s = { stage:'empty', cho:-1, jung:-1, jong:0, committed:'' };

  function _pending() {
    if (_s.stage === 'empty')     return '';
    if (_s.stage === 'cho')       return _CHO[_s.cho];
    if (_s.stage === 'cho_jung')  return _syl(_s.cho, _s.jung, 0);
    return _syl(_s.cho, _s.jung, _s.jong);
  }

  function _commit() {
    _s.committed += _pending();
    _s.stage = 'empty'; _s.cho = _s.jung = -1; _s.jong = 0;
  }

  function _flush() { dictInput.value = _s.committed + _pending(); }

  function resetHangulCompose() {
    _s.stage = 'empty'; _s.cho = _s.jung = -1; _s.jong = 0; _s.committed = '';
  }

  dictInput.addEventListener('input', () => {
    if (dictInput.value !== _s.committed + _pending()) {
      _s.stage = 'empty'; _s.cho = _s.jung = -1; _s.jong = 0;
      _s.committed = dictInput.value;
    }
  });

  function _backspace() {
    if (_s.stage === 'empty') {
      _s.committed = _s.committed.slice(0, -1);
    } else if (_s.stage === 'cho') {
      _s.stage = 'empty'; _s.cho = -1;
    } else if (_s.stage === 'cho_jung') {
      const f = _compJungFirst[_s.jung];
      if (f !== undefined) { _s.jung = f; }
      else { _s.stage = 'cho'; _s.jung = -1; }
    } else {
      const f = _compJongFirst[_s.jong];
      if (f !== undefined) { _s.jong = f; }
      else { _s.stage = 'cho_jung'; _s.jong = 0; }
    }
  }

  function _handleJamo(jamo) {
    if (jamo === ' ')         { _commit(); _s.committed += ' '; _flush(); dictInput.focus(); return; }
    if (jamo === 'backspace') { _backspace(); _flush(); dictInput.focus(); return; }

    const vIdx = _jungIdx[jamo];
    if (vIdx !== undefined) {
      if (_s.stage === 'empty') {
        _s.stage = 'cho_jung'; _s.cho = 11; _s.jung = vIdx;
      } else if (_s.stage === 'cho') {
        _s.stage = 'cho_jung'; _s.jung = vIdx;
      } else if (_s.stage === 'cho_jung') {
        const comp = _compJung[`${_s.jung},${vIdx}`];
        if (comp !== undefined) { _s.jung = comp; }
        else { _commit(); _s.stage = 'cho_jung'; _s.cho = 11; _s.jung = vIdx; }
      } else {
        const split = _jongSplit[_s.jong];
        if (split) {
          const [remJong, newCho] = split;
          _s.committed += _syl(_s.cho, _s.jung, remJong);
          _s.stage = 'cho_jung'; _s.cho = newCho; _s.jung = vIdx; _s.jong = 0;
        } else {
          _s.committed += _syl(_s.cho, _s.jung, 0);
          _s.stage = 'cho_jung'; _s.cho = _jongCho[_s.jong]; _s.jung = vIdx; _s.jong = 0;
        }
      }
    } else {
      const cIdx = _choIdx[jamo];
      const jIdx = _jamoJong[jamo];
      if (_s.stage === 'empty') {
        _s.stage = 'cho'; _s.cho = cIdx;
      } else if (_s.stage === 'cho') {
        _commit(); _s.stage = 'cho'; _s.cho = cIdx;
      } else if (_s.stage === 'cho_jung') {
        if (jIdx !== undefined) { _s.stage = 'cho_jung_jong'; _s.jong = jIdx; }
        else { _commit(); _s.stage = 'cho'; _s.cho = cIdx; }
      } else {
        const comp = _compJong[`${_s.jong},${cIdx}`];
        if (comp !== undefined) { _s.jong = comp; }
        else { _commit(); _s.stage = 'cho'; _s.cho = cIdx; }
      }
    }
    _flush();
    dictInput.focus();
  }

  document.querySelectorAll('.kb-key').forEach(key => {
    key.addEventListener('click', e => {
      if (!dictInput || dictInput.disabled) return;
      _handleJamo((e.shiftKey && key.dataset.shift) ? key.dataset.shift : key.dataset.char);
    });
  });

  // ── Read Along mode ───────────────────────────────────────
  raNewBtn.addEventListener("click", loadNewItem);

  raStartBtn.addEventListener("click", () => {
    if (raState === "running") {
      pauseReadAlong();
    } else if (raState === "paused") {
      resumeReadAlong();
    } else {
      stopReadAlong();
      startReadAlong();
    }
  });

  raPauseBtn.addEventListener("click", () => {
    if (raState === "running") pauseReadAlong();
    else if (raState === "paused") resumeReadAlong();
  });

  function tokenizeKorean(text) {
    // Always syllable-level so rate slider controls each syllable's duration.
    // Preserve word boundaries as metadata so we can add visual spacing.
    const words = text.trim().split(/\s+/).filter(Boolean);
    const tokens = [];
    words.forEach((word, wi) => {
      const syls = [...word].filter(c => c.trim() !== "");
      syls.forEach((syl, si) => {
        tokens.push({ text: syl, wordEnd: si === syls.length - 1 && wi < words.length - 1 });
      });
    });
    return tokens.length ? tokens : [{ text: text.trim(), wordEnd: false }];
  }

  function renderReadAlong(item) {
    stopReadAlong();
    raTokens = tokenizeKorean(item.korean);
    raIndex  = 0;
    raState  = "idle";
    raEnglishEl.textContent = item.english;
    raEnglishEl.classList.add("hidden");
    buildRaDisplay();
    updateRaProgress(0);
    setRaStatus("Press Start to read along with the audio.");
    raStartBtn.textContent  = "Start";
    raStartBtn.disabled     = false;
    raPauseBtn.disabled     = true;
    raPauseBtn.textContent  = "Pause";
  }

  function buildRaDisplay() {
    raTextEl.innerHTML = raTokens
      .map((tok, i) =>
        `<span class="ra-token" data-i="${i}">${esc(tok.text)}</span>${tok.wordEnd ? '<span class="ra-space">&nbsp;</span>' : ''}`
      )
      .join('');
    adjustProgressWidth();
  }

  function adjustProgressWidth() {
    requestAnimationFrame(() => {
      const tokens = Array.from(raTextEl.querySelectorAll('.ra-token'));
      if (!tokens.length) return;
      const first = tokens[0].getBoundingClientRect();
      const last  = tokens[tokens.length - 1].getBoundingClientRect();
      const isMultiLine = Math.abs(first.top - last.top) > 4;
      const progressWrap = document.getElementById('raProgressFill').parentElement;
      if (isMultiLine) {
        progressWrap.style.width = '';
      } else {
        const container = raTextEl.getBoundingClientRect();
        const used = last.right - container.left;
        progressWrap.style.width = `${Math.min(used / container.width, 1) * 100}%`;
      }
    });
  }

  function highlightRaTokens(activeIdx) {
    raTextEl.querySelectorAll(".ra-token").forEach((el, i) => {
      el.classList.remove("ra-active", "ra-done");
      if      (i < activeIdx)  el.classList.add("ra-done");
      else if (i === activeIdx) el.classList.add("ra-active");
    });
  }

  function updateRaProgress(idx) {
    const pct = raTokens.length ? (idx / raTokens.length) * 100 : 0;
    raProgressFill.style.width = `${pct}%`;
  }

  function setRaStatus(msg) { raStatusEl.textContent = msg || ""; }

  function startReadAlong() {
    if (!current) return;
    raState = "running";
    raIndex = 0;
    raStartBtn.textContent = "Pause";
    raStartBtn.disabled    = false;
    raPauseBtn.disabled    = true;
    setRaStatus("Reading along…");
    window.speechSynthesis.cancel();
    runReadAlongWithAudio();
  }

  function pauseReadAlong() {
    raState = "paused";
    if (raAudio) raAudio.pause();
    else window.speechSynthesis.cancel();
    raStartBtn.textContent = "Resume";
    setRaStatus("Paused — press Resume to continue.");
  }

  function resumeReadAlong() {
    raState = "running";
    raStartBtn.textContent = "Pause";
    setRaStatus("Reading along…");
    if (raAudio) raAudio.play().catch(() => { raAudio = null; runNextRaToken(); });
    else runNextRaToken();
  }

  function stopReadAlong() {
    raState = "idle";
    if (raAudio) { raAudio.pause(); raAudio = null; }
    window.speechSynthesis.cancel();
  }

  // Plays SunHi pre-rendered audio; highlights each syllable via uniform time distribution
  function runReadAlongWithAudio() {
    const url = getPrefetchedAudioUrl(current);
    if (!url) { runNextRaToken(); return; }

    const total = raTokens.length;
    const audio = new Audio(url);
    audio.playbackRate = Number(rateRange.value || 0.95);
    raAudio = audio;

    let tokenStarts = null;
    highlightRaTokens(0);
    updateRaProgress(0);

    audio.addEventListener('loadedmetadata', () => {
      const D = audio.duration;
      tokenStarts = raTokens.map((_, i) => (i / total) * D);
    });

    audio.addEventListener('timeupdate', () => {
      if (raState !== 'running' || !tokenStarts) return;
      while (raIndex + 1 < raTokens.length && audio.currentTime >= tokenStarts[raIndex + 1]) {
        raIndex++;
        highlightRaTokens(raIndex);
        updateRaProgress(raIndex);
      }
    });

    audio.addEventListener('ended', () => {
      if (raAudio === audio) raAudio = null;
      if (raState === 'running') finishReadAlong();
    });

    audio.addEventListener('error', () => {
      if (raAudio === audio) raAudio = null;
      if (raState === 'running') { raIndex = 0; runNextRaToken(); }
    });

    audio.play().catch(() => {
      raAudio = null;
      if (raState === 'running') runNextRaToken();
    });
  }

  function finishReadAlong() {
    raState = "done";
    updateRaProgress(raTokens.length);
    highlightRaTokens(-1);
    raEnglishEl.classList.remove("hidden");
    setRaStatus("Done! Press New Item for the next one.");
    raStartBtn.textContent = "Restart";
    raStartBtn.disabled    = false;
    raPauseBtn.disabled    = true;
  }

  function runNextRaToken() {
    if (raState !== "running") return;
    if (raIndex >= raTokens.length) { finishReadAlong(); return; }

    highlightRaTokens(raIndex);
    updateRaProgress(raIndex);

    const utterance  = new SpeechSynthesisUtterance(raTokens[raIndex].text);
    utterance.lang   = "ko-KR";
    utterance.rate   = Number(rateRange.value || 0.95);
    const voices     = getKoreanVoices();
    const selected   = voices.find(v => v.voiceURI === voiceSelect.value) ?? voices[0];
    if (selected) utterance.voice = selected;

    utterance.onend = () => {
      if (raState !== "running") return;
      raIndex++;
      setTimeout(runNextRaToken, 90);
    };
    utterance.onerror = () => {
      if (raState !== "running") return;
      raIndex++;
      setTimeout(runNextRaToken, 90);
    };

    window.speechSynthesis.speak(utterance);
  }

  // ── Init ──────────────────────────────────────────────────
  if ("speechSynthesis" in window) {
    populateVoiceSelect();
    window.speechSynthesis.onvoiceschanged = populateVoiceSelect;
  } else {
    populateVoiceSelect();
  }

  applyUnitFilterVisibility();
  syncUnitControlsFromState();

  // ── SRS (Spaced Repetition) ────────────────────────────────
  const SRS_LS_KEY          = "korean-srs-v1";
  const ACTIVE_POOLS_LS_KEY = "korean-srs-active-pools";
  let srsDb       = loadSrsDb();
  let srsDueQueue = [];
  let srsCard     = null;
  let srsPhase    = "front"; // "front" | "back" | "empty" | "done"
  let srsLastCardState = null; // snapshot for undo (Shift+Z)
  let srsSubMode       = "srs"; // "srs" | "flashcard" | "browse"
  let browseSelected   = new Set(); // card keys selected in browse view

  // Flashcard session state
  let flashQueue      = [];   // cards remaining this session
  let flashCard       = null;
  let flashPhase      = "front"; // "front" | "back" | "empty" | "done"
  let flashSessionMap = {};   // key → correct count this session (needs 2 to graduate)
  let flashMastered   = 0;

  // Direction is encoded in pool: base pool = kor→eng, pool+'_rev' = eng→kor
  function isRevCard(card) { return card && card.pool.endsWith('_rev'); }
  function basePool(pool)  { return pool.endsWith('_rev') ? pool.slice(0, -4) : pool; }

  // Build kor111 unit lookup: korean text → unit number
  const kor111UnitMap = Object.fromEntries(pools.kor111.map(x => [x.korean, x.unit]));

  function loadActivePools() {
    try {
      const saved = localStorage.getItem(ACTIVE_POOLS_LS_KEY);
      return saved ? new Set(JSON.parse(saved)) : new Set();
    } catch { return new Set(); }
  }
  function saveActivePools() {
    localStorage.setItem(ACTIVE_POOLS_LS_KEY, JSON.stringify([...srsActivePools]));
  }
  function cardPoolKey(card) {
    const pool = basePool(card.pool);
    if (pool === 'kor111') {
      const unit = kor111UnitMap[card.korean];
      return unit !== undefined ? `kor111:${unit}` : null;
    }
    return (pool === 'sentences' || pool === 'words') ? pool : null;
  }
  let srsActivePools = loadActivePools();

  function loadSrsDb() {
    try { return JSON.parse(localStorage.getItem(SRS_LS_KEY) || '{"cards":{}}'); }
    catch { return { cards: {} }; }
  }

  function saveSrsDb() {
    localStorage.setItem(SRS_LS_KEY, JSON.stringify(srsDb));
  }

  function todayStr() {
    return new Date().toISOString().split("T")[0];
  }

  function getDueCards() {
    const t = todayStr();
    return Object.values(srsDb.cards).filter(c => {
      if (srsActivePools.size > 0) {
        const key = cardPoolKey(c);
        if (!key || !srsActivePools.has(key)) return false;
      }
      return c.dueDate <= t;
    });
  }

  // ── FSRS-5 ────────────────────────────────────────────────────────────────
  const FSRS_W = [0.2487, 1.4899, 5.1687, 6.7905, 7.0427, 0.8069, 1.6838, 0.0010,
                  1.8202, 0.0000, 1.2660, 1.9319, 0.1229, 0.2200, 2.1515, 0.1213,
                  2.6859, 0.5386, 0.7037];
  const FSRS_DECAY     = -0.5;
  const FSRS_FACTOR    = Math.pow(0.9, 1 / FSRS_DECAY) - 1; // ≈ 19/81 ≈ 0.2346
  const FSRS_RETENTION = 0.91;

  function daysBetween(a, b) {
    return Math.round((new Date(b) - new Date(a)) / 86400000);
  }

  function fsrsInterval(stability) {
    const raw = stability / FSRS_FACTOR * (Math.pow(FSRS_RETENTION, 1 / FSRS_DECAY) - 1);
    return Math.max(1, Math.round(raw));
  }

  function fsrs(card, rating) {
    const r1 = rating + 1; // 0-based → 1-based (1=Again, 2=Hard, 3=Good, 4=Easy)
    let { stability, difficulty, interval, repetitions, dueDate } = card;

    if (repetitions === 0) {
      // New card: initialise from first rating
      stability  = Math.max(0.01, FSRS_W[r1 - 1]);
      difficulty = Math.min(10, Math.max(1, FSRS_W[4] - Math.exp(FSRS_W[5] * (r1 - 1)) + 1));
    } else {
      // Elapsed days: scheduled interval + any overdue days
      const elapsed = Math.max(1, (interval || 1) + Math.max(0, daysBetween(dueDate, todayStr())));
      const R = Math.pow(1 + FSRS_FACTOR * elapsed / stability, FSRS_DECAY);
      const d = difficulty;

      if (r1 === 1) {
        // Again → forget stability
        stability = Math.max(0.01,
          FSRS_W[11] * Math.pow(d, -FSRS_W[12]) *
          (Math.pow(stability + 1, FSRS_W[13]) - 1) *
          Math.exp(FSRS_W[14] * (1 - R))
        );
      } else {
        // Hard / Good / Easy → recall stability
        const hp = r1 === 2 ? FSRS_W[15] : 1;
        const eb = r1 === 4 ? FSRS_W[16] : 1;
        stability = Math.max(0.01,
          stability * (1 + Math.exp(FSRS_W[8]) * (11 - d) *
          Math.pow(stability, -FSRS_W[9]) *
          (Math.exp(FSRS_W[10] * (1 - R)) - 1) * hp * eb)
        );
      }
      // Update difficulty with mean-reversion toward D0(Good)
      const d0Good = FSRS_W[4] - Math.exp(FSRS_W[5] * 2) + 1;
      const nextD  = d - FSRS_W[6] * (r1 - 3);
      difficulty   = Math.min(10, Math.max(1, FSRS_W[7] * d0Good + (1 - FSRS_W[7]) * nextD));
    }

    interval    = r1 === 1 ? 1 : fsrsInterval(stability);
    repetitions = r1 === 1 ? 0 : repetitions + 1;
    const due   = new Date();
    due.setDate(due.getDate() + interval);
    return { stability, difficulty, interval, repetitions, dueDate: due.toISOString().split("T")[0] };
  }

  function srsAddCard(pool, item) {
    const key = `${pool}:${item.korean}`;
    if (!srsDb.cards[key]) {
      srsDb.cards[key] = {
        pool, korean: item.korean, english: item.english || "",
        stability: 0, difficulty: 5.0, interval: 1, repetitions: 0, dueDate: todayStr(),
        reviews: 0, goodCount: 0,
      };
    }
  }

  function getItemsForPoolKey(poolKey) {
    if (poolKey === 'sentences') return (pools.sentences || []).map(x => ({ ...x, _pool: 'sentences' }));
    if (poolKey === 'words')     return (pools.words     || []).map(x => ({ ...x, _pool: 'words' }));
    if (poolKey.startsWith('kor111:')) {
      const unit = Number(poolKey.split(':')[1]);
      return pools.kor111.filter(x => x.unit === unit).map(x => ({ ...x, _pool: 'kor111' }));
    }
    return [];
  }

  function getSrsCardAudioUrl(card) {
    if (!card) return null;
    const pool = basePool(card.pool);
    if (pool === 'kor111') {
      const item = pools.kor111.find(x => x.korean === card.korean);
      if (!item || !item.audioFile) return null;
      return `${PREFETCHED_AUDIO_BASE}/kor111/${item.audioFile}`;
    }
    const poolArr = pool === 'sentences' ? pools.sentences : pool === 'words' ? pools.words : null;
    if (!poolArr) return null;
    const idx = poolArr.findIndex(x => x.korean === card.korean);
    if (idx < 0) return null;
    return `${PREFETCHED_AUDIO_BASE}/${pool}/${idx}.mp3`;
  }

  function getEnglishAudioUrl(card) {
    if (!card) return null;
    const pool = basePool(card.pool);
    if (pool === 'kor111') {
      const item = pools.kor111.find(x => x.korean === card.korean);
      if (!item || !item.audioFile) return null;
      return `/audio/english/kor111/${item.audioFile}`;
    }
    const poolArr = pool === 'sentences' ? pools.sentences : pool === 'words' ? pools.words : null;
    if (!poolArr) return null;
    const idx = poolArr.findIndex(x => x.korean === card.korean);
    if (idx < 0) return null;
    return `/audio/english/${pool}/${idx}.mp3`;
  }

  function playSrsSide(card, language) {
    if (!card) return;
    const url = language === "korean" ? getSrsCardAudioUrl(card) : getEnglishAudioUrl(card);
    if (!url) { console.error("No pre-rendered audio for", language, card); return; }
    stopPlayback();
    const audio = new Audio(url);
    audio.playbackRate = language === "korean" ? Number(rateRange.value || 0.95) : 1.0;
    activeAudio = audio;
    audio.onended = () => { if (activeAudio === audio) activeAudio = null; };
    audio.onerror = () => {
      if (activeAudio === audio) activeAudio = null;
      console.error("Audio load error:", url);
    };
    audio.play().catch(err => {
      if (activeAudio === audio) activeAudio = null;
      console.error("Audio play error:", url, err);
    });
  }

  // Play firstLang then secondLang in sequence.
  function playSrsBothSeq(card, firstLang) {
    if (!card) return;
    const secondLang = firstLang === "korean" ? "english" : "korean";
    const url1 = firstLang  === "korean" ? getSrsCardAudioUrl(card) : getEnglishAudioUrl(card);
    const url2 = secondLang === "korean" ? getSrsCardAudioUrl(card) : getEnglishAudioUrl(card);
    if (!url1) { console.error("No pre-rendered audio for", firstLang, card); return; }
    stopPlayback();
    const rate = Number(rateRange.value || 0.95);
    const a1 = new Audio(url1);
    a1.playbackRate = rate;
    activeAudio = a1;
    a1.onended = () => {
      if (activeAudio !== a1) return;
      activeAudio = null;
      if (!url2) { console.error("No pre-rendered audio for", secondLang, card); return; }
      const a2 = new Audio(url2);
      a2.playbackRate = rate;
      activeAudio = a2;
      a2.onended = () => { if (activeAudio === a2) activeAudio = null; };
      a2.onerror = () => { if (activeAudio === a2) activeAudio = null; console.error("Audio load error:", url2); };
      a2.play().catch(err => { if (activeAudio === a2) activeAudio = null; console.error("Audio play error:", url2, err); });
    };
    a1.onerror = () => { if (activeAudio === a1) activeAudio = null; console.error("Audio load error:", url1); };
    a1.play().catch(err => { if (activeAudio === a1) activeAudio = null; console.error("Audio play error:", url1, err); });
  }

  function playSrsAudio(card) {
    playSrsSide(card, "korean");
  }

  // ── Flashcard mode ─────────────────────────────────────────
  function flashCardKey(card) { return `${card.pool}:${card.korean}`; }

  function initFlashSession() {
    const allCards = srsActivePools.size === 0
      ? Object.values(srsDb.cards)
      : Object.values(srsDb.cards).filter(c => { const k = cardPoolKey(c); return k && srsActivePools.has(k); });
    // Shuffle
    flashQueue = [...allCards].sort(() => Math.random() - 0.5);
    flashSessionMap = {};
    flashMastered = 0;
    flashCard = flashQueue[0] ?? null;
    flashPhase = flashQueue.length ? "front" : "empty";
    updateFlashStats();
    renderFlashCard();
  }

  function updateFlashStats() {
    flashRemainingEl.textContent = flashQueue.length;
    flashMasteredEl.textContent  = flashMastered;
  }

  function renderFlashCard() {
    srsFrontEl.classList.add("hidden");
    srsBackEl.classList.add("hidden");
    srsRevealBtn.classList.add("hidden");
    srsReplayBtn.classList.add("hidden");
    flashRatingRow.classList.add("hidden");
    srsEmptyMsgEl.classList.add("hidden");
    flashDoneMsgEl.classList.add("hidden");

    if (flashPhase === "empty") { srsEmptyMsgEl.classList.remove("hidden"); return; }
    if (flashPhase === "done")  { flashDoneMsgEl.classList.remove("hidden"); return; }

    const isRev = isRevCard(flashCard);
    srsFrontEl.textContent = isRev ? flashCard.english : flashCard.korean;
    srsFrontEl.classList.remove("hidden");

    if (flashPhase === "front") {
      srsRevealBtn.classList.remove("hidden");
      srsReplayBtn.classList.remove("hidden");
      if (appMode === "srs") playSrsSide(flashCard, isRev ? "english" : "korean");
    } else {
      const backLang = isRev ? "korean" : "english";
      srsBackEl.textContent = isRev ? flashCard.korean : flashCard.english;
      srsBackEl.classList.remove("hidden");
      flashRatingRow.classList.remove("hidden");
      srsReplayBtn.classList.remove("hidden");
      if (appMode === "srs") playSrsSide(flashCard, backLang);
    }
  }

  function rateFlashCard(correct) {
    if (!flashCard) return;
    const key = flashCardKey(flashCard);
    if (correct) {
      flashSessionMap[key] = (flashSessionMap[key] ?? 0) + 1;
      if (flashSessionMap[key] >= 2) {
        // Graduate: remove from queue
        flashQueue = flashQueue.filter(c => flashCardKey(c) !== key);
        flashMastered++;
      } else {
        // One correct so far — move to back of queue
        flashQueue = flashQueue.filter(c => flashCardKey(c) !== key);
        flashQueue.push(flashCard);
      }
    } else {
      // Again: reset count, move to back of queue
      flashSessionMap[key] = 0;
      flashQueue = flashQueue.filter(c => flashCardKey(c) !== key);
      flashQueue.push(flashCard);
    }
    flashCard  = flashQueue[0] ?? null;
    flashPhase = flashQueue.length ? "front" : "done";
    updateFlashStats();
    renderFlashCard();
  }

  // ── Browse helpers ────────────────────────────────────────────────────────
  function displayPoolName(card) {
    const isRev = card.pool.endsWith('_rev');
    const pool  = basePool(card.pool);
    const suffix = isRev ? " ↺" : "";
    if (pool === 'sentences') return "Sentences" + suffix;
    if (pool === 'words')     return "Words" + suffix;
    if (pool === 'kor111') {
      const unit = kor111UnitMap[card.korean];
      return unit !== undefined ? `KOR111 U${unit}${suffix}` : `KOR111${suffix}`;
    }
    return pool + suffix;
  }

  function dueDateLabel(dueDate) {
    const days = daysBetween(todayStr(), dueDate);
    if (days < 0)  return { text: `${-days}d overdue`, cls: "due-overdue" };
    if (days === 0) return { text: "Today",            cls: "due-today"   };
    return { text: `in ${days}d`, cls: "due-future" };
  }

  function updateBrowseSelInfo() {
    const total = browseTableBodyEl.rows.length;
    const sel   = browseSelected.size;
    browseSelInfoEl.textContent = sel > 0 ? `${sel} of ${total} selected` : `${total} cards`;
    browseActionsEl.classList.toggle("hidden", sel === 0);
    browseSelectAllEl.indeterminate = sel > 0 && sel < total;
    browseSelectAllEl.checked = sel > 0 && sel === total;
  }

  function renderBrowseTable() {
    const filterVal = browsePoolFilter.value;
    const cards = Object.values(srsDb.cards)
      .filter(c => !filterVal || basePool(c.pool) === filterVal)
      .sort((a, b) => a.dueDate.localeCompare(b.dueDate));

    // Rebuild pool filter options (keep current selection)
    const poolSet = [...new Set(Object.values(srsDb.cards).map(c => basePool(c.pool)))].sort();
    while (browsePoolFilter.options.length > 1) browsePoolFilter.remove(1);
    const poolLabels = { sentences: 'Sentences', words: 'Words', kor111: 'KOR111' };
    poolSet.forEach(p => {
      const opt = document.createElement('option');
      opt.value = p;
      opt.textContent = poolLabels[p] ?? p;
      if (p === filterVal) opt.selected = true;
      browsePoolFilter.appendChild(opt);
    });

    browseTableBodyEl.innerHTML = '';
    cards.forEach(card => {
      const key      = `${card.pool}:${card.korean}`;
      const isRev    = isRevCard(card);
      const front    = isRev ? card.english : card.korean;
      const back     = isRev ? card.korean  : card.english;
      const reviews  = card.reviews   ?? 0;
      const good     = card.goodCount ?? 0;
      const goodStr  = reviews > 0
        ? `${good}/${reviews} (${Math.round(good / reviews * 100)}%)`
        : '—';
      const due = dueDateLabel(card.dueDate);

      const tr = document.createElement('tr');
      tr.dataset.key = key;

      const mkTd = (cls, text) => {
        const td = document.createElement('td');
        if (cls) td.className = cls;
        td.textContent = text;
        return td;
      };

      const tdCb = document.createElement('td');
      const cb   = document.createElement('input');
      cb.type = 'checkbox'; cb.className = 'browse-cb'; cb.dataset.key = key;
      cb.checked = browseSelected.has(key);
      tdCb.appendChild(cb);

      const tdDue = mkTd('browse-due ' + due.cls, due.text);

      tr.append(
        tdCb,
        mkTd('browse-front', front),
        mkTd('browse-back',  back),
        mkTd('browse-pool',  displayPoolName(card)),
        tdDue,
        mkTd('browse-reviews', String(reviews)),
        mkTd('browse-good',    goodStr),
      );
      browseTableBodyEl.appendChild(tr);
    });

    updateBrowseSelInfo();
  }

  function showSrsSubMode(mode) {
    srsSubMode = mode;
    srsModeBtn.classList.toggle("active",    mode === "srs");
    flashModeBtn.classList.toggle("active",  mode === "flashcard");
    browseModeBtn.classList.toggle("active", mode === "browse");
    srsStatsRow.classList.toggle("hidden",   mode !== "srs");
    flashStatsRow.classList.toggle("hidden", mode !== "flashcard");
    srsRatingRow.classList.add("hidden");
    flashRatingRow.classList.add("hidden");
    // Card area + action row visible only in SRS/Flashcard modes
    const inBrowse = mode === "browse";
    document.querySelector('.srs-card-area').classList.toggle("hidden", inBrowse);
    srsActionRow.classList.toggle("hidden", inBrowse);
    browsePanel.classList.toggle("hidden", !inBrowse);
    if (mode === "srs") {
      refreshSrsPanel();
    } else if (mode === "flashcard") {
      initFlashSession();
    } else {
      browseSelected.clear();
      renderBrowseTable();
    }
  }

  function handlePoolCheck(poolKey, checked) {
    if (checked) {
      srsActivePools.add(poolKey);
      const items = getItemsForPoolKey(poolKey);
      const newCards = [];
      items.forEach(item => {
        const pool = item._pool || poolKey;
        const fwdKey = `${pool}:${item.korean}`;
        const revKey = `${pool}_rev:${item.korean}`;
        if (!srsDb.cards[fwdKey]) { srsAddCard(pool, item);          newCards.push(srsDb.cards[fwdKey]); }
        if (!srsDb.cards[revKey]) { srsAddCard(pool + '_rev', item); newCards.push(srsDb.cards[revKey]); }
      });
      if (newCards.length) { saveSrsDb(); syncPushBulk(newCards); }
    } else {
      srsActivePools.delete(poolKey);
    }
    saveActivePools();
    refreshSrsPanel();
  }

  function refreshSrsPanel() {
    srsDueQueue = getDueCards();
    const activeCards = srsActivePools.size === 0
      ? Object.values(srsDb.cards)
      : Object.values(srsDb.cards).filter(c => { const k = cardPoolKey(c); return k && srsActivePools.has(k); });
    const total = activeCards.length;
    srsDueCountEl.textContent   = srsDueQueue.length;
    srsTotalCountEl.textContent = total;
    if (srsActivePools.size === 0) {
      srsPhase = "empty"; srsCard = null;
      srsEmptyMsgEl.textContent = "Check the units above to start studying, or click + SRS on any card in Reading mode.";
    } else if (total === 0) {
      srsPhase = "empty"; srsCard = null;
      srsEmptyMsgEl.textContent = "No cards yet for the selected units. They will appear here once added.";
    } else if (srsDueQueue.length === 0) {
      srsPhase = "done"; srsCard = null;
    } else {
      srsCard  = srsDueQueue[0];
      srsPhase = "front";
    }
    renderSrsCard();
  }

  function renderSrsCard() {
    srsFrontEl.classList.add("hidden");
    srsBackEl.classList.add("hidden");
    srsRevealBtn.classList.add("hidden");
    srsReplayBtn.classList.add("hidden");
    srsRatingRow.classList.add("hidden");
    srsEmptyMsgEl.classList.add("hidden");
    srsDoneMsgEl.classList.add("hidden");
    if (srsPhase === "empty") { srsEmptyMsgEl.classList.remove("hidden"); return; }
    if (srsPhase === "done")  { srsDoneMsgEl.classList.remove("hidden");  return; }
    const isRev = isRevCard(srsCard);
    srsFrontEl.textContent = isRev ? srsCard.english : srsCard.korean;
    srsFrontEl.classList.remove("hidden");
    if (srsPhase === "front") {
      srsRevealBtn.classList.remove("hidden");
      srsReplayBtn.classList.remove("hidden");
      if (appMode === "srs") {
        playSrsSide(srsCard, isRev ? "english" : "korean");
      }
    } else {
      const backLang = isRev ? "korean" : "english";
      srsBackEl.textContent = isRev ? srsCard.korean : srsCard.english;
      srsBackEl.classList.remove("hidden");
      srsRatingRow.classList.remove("hidden");
      srsReplayBtn.classList.remove("hidden");
      if (appMode === "srs") playSrsSide(srsCard, backLang);
    }
  }

  function rateCard(rating) {
    if (!srsCard) return;
    const key = `${srsCard.pool}:${srsCard.korean}`;
    srsLastCardState = {
      cardKey: key,
      cardSnapshot: { ...srsDb.cards[key] },
      queue: [...srsDueQueue],
      card: srsCard,
    };
    const updated = fsrs(srsCard, rating);
    Object.assign(srsDb.cards[key], updated);
    srsDb.cards[key].reviews   = (srsDb.cards[key].reviews   ?? 0) + 1;
    if (rating >= 2) srsDb.cards[key].goodCount = (srsDb.cards[key].goodCount ?? 0) + 1;
    saveSrsDb();
    syncPushReview(srsDb.cards[key]);
    srsDueQueue = srsDueQueue.filter(c => !(c.pool === srsCard.pool && c.korean === srsCard.korean));
    if (rating === 0) srsDueQueue.push(srsDb.cards[key]);
    if (srsDueQueue.length === 0) {
      srsPhase = "done"; srsCard = null;
    } else {
      srsCard  = srsDueQueue[0];
      srsPhase = "front";
    }
    srsDueCountEl.textContent = srsDueQueue.length;
    renderSrsCard();
  }

  function undoLastCard() {
    if (!srsLastCardState) return;
    const { cardKey, cardSnapshot, queue, card } = srsLastCardState;
    srsDb.cards[cardKey] = cardSnapshot;
    saveSrsDb();
    syncPushReview(srsDb.cards[cardKey]);
    srsDueQueue = queue;
    srsCard = card;
    srsPhase = "front";
    srsDueCountEl.textContent = srsDueQueue.length;
    srsLastCardState = null;
    renderSrsCard();
  }

  srsModeBtn.addEventListener("click",    () => showSrsSubMode("srs"));
  flashModeBtn.addEventListener("click",  () => showSrsSubMode("flashcard"));
  browseModeBtn.addEventListener("click", () => showSrsSubMode("browse"));

  browsePoolFilter.addEventListener("change", renderBrowseTable);

  browseSelectAllEl.addEventListener("change", () => {
    const checked = browseSelectAllEl.checked;
    browseTableBodyEl.querySelectorAll('.browse-cb').forEach(cb => {
      cb.checked = checked;
      if (checked) browseSelected.add(cb.dataset.key);
      else         browseSelected.delete(cb.dataset.key);
    });
    updateBrowseSelInfo();
  });

  browseTableBodyEl.addEventListener("change", e => {
    const cb = e.target.closest('.browse-cb');
    if (!cb) return;
    if (cb.checked) browseSelected.add(cb.dataset.key);
    else            browseSelected.delete(cb.dataset.key);
    updateBrowseSelInfo();
  });

  browseDueNowBtn.addEventListener("click", () => {
    const today = todayStr();
    browseSelected.forEach(key => {
      if (srsDb.cards[key]) { srsDb.cards[key].dueDate = today; syncPushReview(srsDb.cards[key]); }
    });
    saveSrsDb();
    browseSelected.clear();
    renderBrowseTable();
  });

  browseSetDateBtn.addEventListener("click", () => {
    const date = browseDatePickerEl.value;
    if (!date) return;
    browseSelected.forEach(key => {
      if (srsDb.cards[key]) { srsDb.cards[key].dueDate = date; syncPushReview(srsDb.cards[key]); }
    });
    saveSrsDb();
    browseSelected.clear();
    renderBrowseTable();
  });
  flashAgainBtn.addEventListener("click", () => rateFlashCard(false));
  flashGotItBtn.addEventListener("click", () => rateFlashCard(true));
  flashRestartBtn.addEventListener("click", () => initFlashSession());

  srsRevealBtn.addEventListener("click", () => {
    if (srsSubMode === "flashcard") { flashPhase = "back"; renderFlashCard(); }
    else { srsPhase = "back"; renderSrsCard(); }
  });
  srsReplayBtn.addEventListener("click", () => {
    const card  = srsSubMode === "flashcard" ? flashCard : srsCard;
    const phase = srsSubMode === "flashcard" ? flashPhase : srsPhase;
    if (!card) return;
    const lang = phase === "front"
      ? (isRevCard(card) ? "english" : "korean")
      : (isRevCard(card) ? "korean"  : "english");
    playSrsSide(card, lang);
  });
  srsAgainBtn.addEventListener("click",   () => rateCard(0));
  srsHardBtn.addEventListener("click",    () => rateCard(1));
  srsGoodBtn.addEventListener("click",    () => rateCard(2));
  srsEasyBtn.addEventListener("click",    () => rateCard(3));
  srsTab.addEventListener("click",        () => switchAppMode("srs"));

  // SRS / Flashcard keyboard shortcuts (only active when on SRS tab)
  document.addEventListener("keydown", e => {
    if (appMode !== "srs") return;
    if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;

    if (srsSubMode === "flashcard") {
      const phase = flashPhase;
      if (phase === "front") {
        if (e.key === " " || e.key === "Enter") {
          e.preventDefault(); flashPhase = "back"; renderFlashCard();
        }
        return;
      }
      if (phase !== "back") return;
      // Space/Enter/2/3/4 = Got It, 1 = Again
      if (e.key === "1") { e.preventDefault(); rateFlashCard(false); }
      else if (e.key === " " || e.key === "Enter" || e.key === "2" || e.key === "3" || e.key === "4") {
        e.preventDefault(); rateFlashCard(true);
      }
      return;
    }

    // SRS sub-mode
    if (e.key.toLowerCase() === "z" && e.shiftKey) {
      e.preventDefault(); undoLastCard(); return;
    }
    if (srsPhase === "front") {
      if (e.key === " " || e.key === "Enter") {
        e.preventDefault(); srsPhase = "back"; renderSrsCard();
      }
      return;
    }
    if (srsPhase !== "back") return;
    switch (e.key) {
      case "1": e.preventDefault(); rateCard(0); break;
      case "2": e.preventDefault(); rateCard(1); break;
      case "3": case " ": case "Enter": e.preventDefault(); rateCard(2); break;
      case "4": e.preventDefault(); rateCard(3); break;
    }
  });
  // Initialise pool checkboxes from saved state
  document.querySelectorAll('.srs-pool-check').forEach(cb => {
    const pool    = cb.dataset.pool;
    const unit    = cb.dataset.unit;
    const poolKey = unit ? `${pool}:${unit}` : pool;
    cb.checked = srsActivePools.has(poolKey);
    cb.addEventListener('change', () => handlePoolCheck(poolKey, cb.checked));
  });

  srsAddCurrentBtn.addEventListener("click", () => {
    if (!current) return;
    const pool   = current._mode;
    const fwdKey = `${pool}:${current.korean}`;
    const revKey = `${pool}_rev:${current.korean}`;
    const newCards = [];
    if (!srsDb.cards[fwdKey]) { srsAddCard(pool,          current); newCards.push(srsDb.cards[fwdKey]); }
    if (!srsDb.cards[revKey]) { srsAddCard(pool + '_rev', current); newCards.push(srsDb.cards[revKey]); }
    if (newCards.length) { saveSrsDb(); newCards.forEach(c => syncPushReview(c)); }
    srsAddCurrentBtn.textContent = "✓ In SRS";
    srsAddCurrentBtn.disabled = true;
  });

  // ── SRS Cloud Sync ─────────────────────────────────────────
  // Auth is handled globally in the site header (Layout.astro).
  // This page just reads the stored token and responds to auth events.
  const SRS_WORKER_URL   = "https://korean-srs.squaliekid55.workers.dev";
  const SRS_TOKEN_LS_KEY = "korean-srs-token";
  const SRS_EMAIL_LS_KEY = "korean-srs-email";

  const srsSyncMsgEl        = document.getElementById("srsSyncMsg");
  const srsSyncGuestRow     = document.getElementById("srsSyncGuestRow");
  const srsSyncActiveRow    = document.getElementById("srsSyncActiveRow");
  const srsUserEmailDisplay = document.getElementById("srsUserEmailDisplay");
  const srsLastSyncedEl     = document.getElementById("srsLastSyncedEl");
  const srsSyncNowBtn       = document.getElementById("srsSyncNowBtn");

  let lastSyncedAt = null;

  function getSrsToken() { return localStorage.getItem(SRS_TOKEN_LS_KEY) || null; }
  function getSrsEmail() { return localStorage.getItem(SRS_EMAIL_LS_KEY) || null; }
  function setSyncMsg(msg) { if (srsSyncMsgEl) srsSyncMsgEl.textContent = msg || ""; }

  function updateLastSyncedDisplay() {
    if (!srsLastSyncedEl) return;
    if (!lastSyncedAt) { srsLastSyncedEl.textContent = ''; return; }
    const mins = Math.round((Date.now() - lastSyncedAt) / 60_000);
    srsLastSyncedEl.textContent = mins < 1 ? 'Synced just now' : `Synced ${mins}m ago`;
  }

  function renderSyncUI() {
    const token = getSrsToken();
    srsSyncGuestRow.classList.toggle("hidden",   !!token);
    srsSyncActiveRow.classList.toggle("hidden",  !token);
    if (token) srsUserEmailDisplay.textContent = getSrsEmail() || "";
    updateLastSyncedDisplay();
  }

  srsSyncNowBtn.addEventListener("click", async () => {
    srsSyncNowBtn.disabled = true;
    setSyncMsg("Syncing…");
    await syncFetchCards();
    refreshSrsPanel();
    lastSyncedAt = Date.now();
    updateLastSyncedDisplay();
    setSyncMsg("✓ Synced!");
    srsSyncNowBtn.disabled = false;
  });

  async function syncFetchCards() {
    const token = getSrsToken();
    if (!SRS_WORKER_URL || !token) return;
    try {
      const res = await fetch(`${SRS_WORKER_URL}/cards`, {
        headers: { 'Authorization': `Bearer ${token}` },
      });
      if (res.status === 401) {
        localStorage.removeItem(SRS_TOKEN_LS_KEY);
        localStorage.removeItem(SRS_EMAIL_LS_KEY);
        renderSyncUI();
        setSyncMsg("Session expired — log in again from the header.");
        return;
      }
      if (!res.ok) return;
      const { cards } = await res.json();
      cards.forEach(c => {
        const key = `${c.pool}:${c.korean}`;
        const existing = srsDb.cards[key];
        srsDb.cards[key] = {
          pool: c.pool, korean: c.korean, english: c.english,
          stability: c.ease_factor,       // ease_factor column stores stability
          difficulty: c.difficulty ?? 5.0,
          interval: c.interval, repetitions: c.repetitions, dueDate: c.due_date,
          reviews:   existing?.reviews   ?? 0,
          goodCount: existing?.goodCount ?? 0,
        };
      });
      saveSrsDb();
      lastSyncedAt = Date.now();
      updateLastSyncedDisplay();
    } catch {}
  }

  function syncPushReview(card) {
    const token = getSrsToken();
    if (!SRS_WORKER_URL || !token || !card) return;
    fetch(`${SRS_WORKER_URL}/review`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      body: JSON.stringify({
        pool: card.pool, korean: card.korean, english: card.english,
        interval: card.interval, easeFactor: card.stability,  // ease_factor column stores stability
        difficulty: card.difficulty,
        repetitions: card.repetitions, dueDate: card.dueDate,
      }),
    }).catch(() => {});
  }

  async function syncPushBulk(cards) {
    const token = getSrsToken();
    if (!SRS_WORKER_URL || !token || !cards.length) return;
    await fetch(`${SRS_WORKER_URL}/bulk`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      body: JSON.stringify({ cards }),
    }).catch(() => {});
  }

  // When the user logs in/out from the header, update the sync UI
  document.addEventListener("srs-auth-changed", async ({ detail }) => {
    renderSyncUI();
    if (detail.token && appMode === "srs") {
      setSyncMsg("Syncing…");
      const local = Object.values(srsDb.cards);
      if (local.length) await syncPushBulk(local);
      await syncFetchCards();
      refreshSrsPanel();
      setSyncMsg("✓ Synced!");
    }
  });

  // Migrate existing cards to directional: create _rev counterpart for any card that lacks one.
  (function migrateToDirectionalCards() {
    const toAdd = [];
    Object.values(srsDb.cards).forEach(card => {
      if (card.pool.endsWith('_rev')) return;
      const revKey = `${card.pool}_rev:${card.korean}`;
      if (!srsDb.cards[revKey]) {
        srsAddCard(card.pool + '_rev', card);
        toAdd.push(srsDb.cards[revKey]);
      }
    });
    if (toAdd.length) { saveSrsDb(); syncPushBulk(toAdd); }
  })();

  // Migrate existing SM-2 cards to FSRS-5 format.
  (function migrateToFsrs() {
    let changed = false;
    Object.values(srsDb.cards).forEach(card => {
      if (card.stability === undefined) {
        card.stability  = card.interval ?? 1;
        card.difficulty = 5.0;
        delete card.easeFactor;
        changed = true;
      }
    });
    if (changed) saveSrsDb();
  })();

  renderSyncUI();
  if (getSrsToken()) syncFetchCards().then(refreshSrsPanel);

  // Auto-sync every 5 minutes when logged in
  setInterval(async () => {
    if (!getSrsToken()) return;
    await syncFetchCards();
    if (appMode === "srs") refreshSrsPanel();
  }, 5 * 60 * 1000);

  // Update "last synced" timestamp display every minute
  setInterval(updateLastSyncedDisplay, 60_000);

  loadNewItem();
</script>

