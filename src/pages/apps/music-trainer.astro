---
import Layout from '../../layouts/Layout.astro';

const NOTE_NAMES_SSR = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
---

<Layout
  title="Music Trainer | SqualieC"
  description="Browser-based bass practice tool: chromatic tuner, note recognition, scale trainer, interval drills, metronome, and tone generator — all using your microphone."
>
  <section class="hero hero-surface">
    <p class="eyebrow">Online Tool</p>
    <h1>Music Trainer</h1>
    <p class="lead">
      Practice bass in your browser. Chromatic tuner, note and scale training, interval drills,
      metronome, and tone generator — powered by your microphone and the Web Audio API.
    </p>
  </section>

  <section class="card section-title practice-shell">

    <!-- ── Tab navigation ─────────────────────────────── -->
    <div class="mode-toggle">
      <button class="mode-tab active" data-tab="tuner"     type="button">Tuner</button>
      <button class="mode-tab"        data-tab="note"      type="button">Random Note</button>
      <button class="mode-tab"        data-tab="scales"    type="button">Scales</button>
      <button class="mode-tab"        data-tab="intervals" type="button">Intervals</button>
      <button class="mode-tab"        data-tab="tools"     type="button">Tools</button>
    </div>

    <!-- ── Microphone bar ─────────────────────────────── -->
    <div class="mic-bar">
      <button id="micBtn" class="btn btn-secondary" type="button">Enable Microphone</button>
      <span id="micStatus" class="mic-status"></span>
      <span class="vol-wrap" aria-hidden="true">
        <span id="volFill" class="vol-fill"></span>
      </span>
    </div>

    <!-- ── TUNER ──────────────────────────────────────── -->
    <div id="tunerPanel" class="tab-panel">
      <div class="tuner-display">
        <div id="tunerNote"  class="tuner-note">--</div>
        <div id="tunerOctave" class="tuner-octave"></div>
        <div id="tunerFreq"  class="tuner-freq"></div>
      </div>

      <div class="cents-meter">
        <div class="cents-labels">
          <span>-50</span><span>-25</span><span>0</span><span>+25</span><span>+50</span>
        </div>
        <div class="cents-track">
          <div class="cents-zone"></div>
          <div id="centsNeedle" class="cents-needle" style="left:50%"></div>
        </div>
        <div id="centsValue" class="cents-value">-- ¢</div>
      </div>

      <div id="tunerConf" class="tuner-conf"></div>
    </div>

    <!-- ── RANDOM NOTE ────────────────────────────────── -->
    <div id="notePanel" class="tab-panel hidden">
      <div class="practice-controls">
        <div class="ctrl-row">
          <label>Fret range</label>
          <input id="fretLow"  type="number" min="0" max="24" value="0"  class="fret-input" />
          <span class="ctrl-sep">to</span>
          <input id="fretHigh" type="number" min="0" max="24" value="12" class="fret-input" />
        </div>
        <div class="ctrl-row">
          <input id="notePlayRef" type="checkbox" checked />
          <label for="notePlayRef">Play reference tone</label>
        </div>
      </div>

      <div class="target-display">
        <div class="target-label">Target Note</div>
        <div id="noteTarget" class="target-note">--</div>
        <div id="noteHints" class="note-hints"></div>
      </div>

      <div id="noteResult" class="note-result"></div>

      <div class="score-row">
        <span id="noteScore"  class="score-text">Score: 0 / 0</span>
        <span id="noteStreak" class="streak-text"></span>
      </div>

      <div class="btn-row">
        <button id="noteStartBtn" class="btn btn-primary"   type="button">Start Practice</button>
        <button id="noteNextBtn"  class="btn btn-secondary" type="button" disabled>Next Note</button>
        <button id="noteResetBtn" class="btn btn-secondary" type="button">Reset Score</button>
      </div>
    </div>

    <!-- ── SCALES ─────────────────────────────────────── -->
    <div id="scalesPanel" class="tab-panel hidden">
      <div class="practice-controls">
        <div class="ctrl-row">
          <label for="scaleRoot">Root</label>
          <select id="scaleRoot" class="trainer-select"></select>
          <label for="scaleOctave">Octave</label>
          <select id="scaleOctave" class="trainer-select">
            <option value="1">1</option>
            <option value="2" selected>2</option>
            <option value="3">3</option>
          </select>
          <label for="scaleType">Type</label>
          <select id="scaleType" class="trainer-select">
            <option value="major">Major</option>
            <option value="minor">Natural Minor</option>
          </select>
        </div>
        <div class="ctrl-row">
          <input id="scalePlayRef" type="checkbox" checked />
          <label for="scalePlayRef">Play reference tones</label>
        </div>
      </div>

      <div class="target-display">
        <div id="scaleProgress" class="target-label">Note 1 / 8</div>
        <div id="scaleTarget"   class="target-note">--</div>
        <div id="scaleHints"    class="note-hints"></div>
      </div>

      <div id="scaleResult" class="note-result"></div>

      <div class="btn-row">
        <button id="scaleStartBtn" class="btn btn-primary"   type="button">Start Scale</button>
        <button id="scaleSkipBtn"  class="btn btn-secondary" type="button" disabled>Skip Note</button>
      </div>
    </div>

    <!-- ── INTERVALS ──────────────────────────────────── -->
    <div id="intervalsPanel" class="tab-panel hidden">
      <div class="practice-controls">
        <div class="ctrl-row">
          <label for="intRoot">Root</label>
          <select id="intRoot" class="trainer-select"></select>
          <label for="intOctave">Octave</label>
          <select id="intOctave" class="trainer-select">
            <option value="1">1</option>
            <option value="2" selected>2</option>
            <option value="3">3</option>
          </select>
          <label for="intType">Interval</label>
          <select id="intType" class="trainer-select"></select>
        </div>
        <div class="ctrl-row">
          <input id="intRandom" type="checkbox" checked />
          <label for="intRandom">Randomize root + interval</label>
        </div>
      </div>

      <div class="int-display">
        <div class="int-step">
          <div class="target-label">Root</div>
          <div id="intRootDisp" class="target-note target-note-sm">--</div>
        </div>
        <div class="int-arrow">+</div>
        <div class="int-step">
          <div class="target-label">Interval</div>
          <div id="intTypeDisp" class="int-type-label">--</div>
        </div>
        <div class="int-arrow">=</div>
        <div class="int-step">
          <div class="target-label">Target</div>
          <div id="intTargetDisp" class="target-note">--</div>
          <div id="intHints"       class="note-hints"></div>
        </div>
      </div>

      <div id="intPhaseLabel" class="int-phase-label">Play the root, then the interval note</div>
      <div id="intResult"     class="note-result"></div>

      <div class="btn-row">
        <button id="intStartBtn" class="btn btn-primary"   type="button">Start</button>
        <button id="intNextBtn"  class="btn btn-secondary" type="button" disabled>Next</button>
      </div>
    </div>

    <!-- ── TOOLS ──────────────────────────────────────── -->
    <div id="toolsPanel" class="tab-panel hidden">
      <div class="tools-section">
        <h3 class="tools-heading">Metronome</h3>
        <div class="ctrl-row">
          <label for="metroBpm">BPM</label>
          <input id="metroBpm" type="range" min="30" max="240" value="90" class="trainer-slider" />
          <span id="metroBpmVal" class="slider-val">90</span>
        </div>
        <div class="ctrl-row">
          <label for="metroVol">Volume</label>
          <input id="metroVol" type="range" min="0" max="100" value="30" class="trainer-slider" />
          <span id="metroVolVal" class="slider-val">30%</span>
        </div>
        <div class="btn-row" style="align-items:center">
          <button id="metroBtn"  class="btn btn-primary" type="button">Start Metronome</button>
          <div    id="metroBeat" class="metro-beat"></div>
        </div>
      </div>

      <div class="tools-section">
        <h3 class="tools-heading">Tone Generator</h3>
        <div class="ctrl-row">
          <label for="toneNote">Note</label>
          <select id="toneNote"   class="trainer-select"></select>
          <label for="toneOctave">Octave</label>
          <select id="toneOctave" class="trainer-select">
            <option value="1">1</option>
            <option value="2" selected>2</option>
            <option value="3">3</option>
            <option value="4">4</option>
          </select>
          <span id="toneFreqDisp" class="freq-disp">-- Hz</span>
        </div>
        <div class="ctrl-row">
          <label for="toneVol">Volume</label>
          <input id="toneVol" type="range" min="0" max="100" value="25" class="trainer-slider" />
          <span id="toneVolVal" class="slider-val">25%</span>
        </div>
        <div class="btn-row">
          <button id="toneBtn" class="btn btn-primary" type="button">Play Tone</button>
        </div>
      </div>
    </div>

    <!-- ── FRETBOARD ─────────────────────────────────── -->
    <div class="fretboard-wrap">
      <canvas id="fretboard" class="fretboard-canvas"></canvas>
      <div class="fretboard-labels" aria-hidden="true">
        <span>G</span><span>D</span><span>A</span><span>E</span>
      </div>
    </div>

  </section>

  <style>
    .practice-shell { padding: 1.4rem; }

    /* ── Tab toggle ── */
    .mode-toggle {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      background: color-mix(in srgb, var(--muted), transparent 88%);
      border-radius: 12px;
      padding: 4px;
      width: fit-content;
      margin-bottom: 1.1rem;
    }
    .mode-tab {
      border: none;
      border-radius: 8px;
      padding: 7px 18px;
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
      background: transparent;
      color: var(--muted);
      font-family: inherit;
      transition: background 0.12s, color 0.12s;
    }
    .mode-tab.active {
      background: var(--card);
      color: var(--accent);
      box-shadow: 0 1px 4px rgba(0,0,0,0.25);
    }

    /* ── Mic bar ── */
    .mic-bar {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.2rem;
      flex-wrap: wrap;
    }
    .mic-status {
      font-size: 0.84rem;
      color: var(--muted);
    }
    .vol-wrap {
      width: 80px;
      height: 8px;
      background: color-mix(in srgb, var(--muted), transparent 78%);
      border-radius: 4px;
      overflow: hidden;
    }
    .vol-fill {
      display: block;
      height: 100%;
      width: 0%;
      background: var(--accent);
      border-radius: 4px;
      transition: width 0.05s;
    }

    /* ── Panel visibility ── */
    .tab-panel { display: block; }
    .hidden    { display: none !important; }

    /* ── Tuner ── */
    .tuner-display {
      text-align: center;
      padding: 1.5rem 0 0.5rem;
    }
    .tuner-note {
      font-size: clamp(3.5rem, 10vw, 6rem);
      font-weight: 700;
      line-height: 1;
      color: var(--text);
      letter-spacing: -0.02em;
      min-height: 1.2em;
    }
    .tuner-octave {
      font-size: 1.5rem;
      color: var(--muted);
      margin-top: 0.2rem;
    }
    .tuner-freq {
      font-size: 0.9rem;
      color: var(--muted);
      margin-top: 0.2rem;
    }
    .cents-meter {
      max-width: 480px;
      margin: 1.2rem auto 0;
    }
    .cents-labels {
      display: flex;
      justify-content: space-between;
      font-size: 0.72rem;
      color: var(--muted);
      margin-bottom: 4px;
    }
    .cents-track {
      position: relative;
      height: 22px;
      background: linear-gradient(90deg, #c0392b 0%, #e67e22 30%, #27ae60 45%, #27ae60 55%, #e67e22 70%, #c0392b 100%);
      border-radius: 11px;
      overflow: visible;
    }
    .cents-zone {
      position: absolute;
      left: 44%;
      width: 12%;
      height: 100%;
      background: rgba(39,220,140,0.18);
      border-radius: 11px;
      border: 1.5px solid rgba(39,220,140,0.5);
    }
    .cents-needle {
      position: absolute;
      top: -3px;
      width: 4px;
      height: 28px;
      background: #fff;
      border-radius: 2px;
      transform: translateX(-50%);
      box-shadow: 0 0 6px rgba(0,0,0,0.5);
      transition: left 0.07s linear;
    }
    .cents-value {
      text-align: center;
      margin-top: 8px;
      font-size: 0.88rem;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
    }
    .tuner-conf {
      text-align: center;
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 0.5rem;
      min-height: 1.2em;
    }

    /* ── Target display ── */
    .target-display {
      text-align: center;
      padding: 1.2rem 0 0.6rem;
    }
    .target-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      font-weight: 600;
    }
    .target-note {
      font-size: clamp(3rem, 9vw, 5rem);
      font-weight: 700;
      color: var(--text);
      line-height: 1.1;
      letter-spacing: -0.02em;
    }
    .target-note-sm {
      font-size: clamp(2rem, 6vw, 3.2rem);
    }
    .note-hints {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      justify-content: center;
      margin-top: 0.5rem;
    }
    .hint-chip {
      background: color-mix(in srgb, var(--accent), transparent 82%);
      color: color-mix(in srgb, var(--accent), white 20%);
      border-radius: 999px;
      padding: 0.2rem 0.65rem;
      font-size: 0.78rem;
      font-weight: 600;
    }

    /* ── Result / score ── */
    .note-result {
      text-align: center;
      min-height: 2rem;
      font-size: 1.15rem;
      font-weight: 700;
      margin: 0.4rem 0;
    }
    .result-correct  { color: #27ae60; }
    .result-wrong    { color: #e74c3c; }
    .result-detected { color: var(--accent); }

    .score-row {
      display: flex;
      gap: 1.2rem;
      align-items: center;
      margin-bottom: 0.6rem;
    }
    .score-text  { font-size: 0.9rem; color: var(--muted); }
    .streak-text { font-size: 0.9rem; color: var(--accent); font-weight: 600; }

    /* ── Controls ── */
    .practice-controls { margin-bottom: 0.8rem; }
    .ctrl-row {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex-wrap: wrap;
      margin-bottom: 0.5rem;
    }
    .ctrl-row label { font-size: 0.85rem; color: var(--muted); }
    .ctrl-sep       { font-size: 0.85rem; color: var(--muted); }

    .trainer-select {
      background: color-mix(in srgb, var(--bg), transparent 5%);
      border: 1px solid color-mix(in srgb, var(--muted), transparent 60%);
      color: var(--text);
      border-radius: 8px;
      padding: 0.3rem 0.6rem;
      font-size: 0.88rem;
      font-family: inherit;
      cursor: pointer;
    }
    .fret-input {
      background: color-mix(in srgb, var(--bg), transparent 5%);
      border: 1px solid color-mix(in srgb, var(--muted), transparent 60%);
      color: var(--text);
      border-radius: 8px;
      padding: 0.3rem 0.5rem;
      font-size: 0.88rem;
      width: 4rem;
      text-align: center;
      font-family: inherit;
    }
    .trainer-slider { width: 130px; accent-color: var(--accent); cursor: pointer; }
    .slider-val { font-size: 0.82rem; color: var(--muted); min-width: 2.5rem; }

    /* ── Intervals ── */
    .int-display {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
      padding: 1rem 0 0.6rem;
    }
    .int-step     { text-align: center; }
    .int-arrow    { font-size: 1.5rem; color: var(--muted); font-weight: 700; }
    .int-type-label {
      font-size: clamp(1.4rem, 4vw, 2.2rem);
      font-weight: 700;
      color: var(--accent);
      min-height: 1.2em;
    }
    .int-phase-label {
      text-align: center;
      font-size: 0.85rem;
      color: var(--muted);
      margin-bottom: 0.4rem;
    }

    /* ── Tools ── */
    .tools-section {
      background: color-mix(in srgb, var(--bg-soft), transparent 10%);
      border: 1px solid color-mix(in srgb, var(--muted), transparent 75%);
      border-radius: 12px;
      padding: 1.1rem 1.2rem;
      margin-bottom: 1rem;
    }
    .tools-heading {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text);
      margin: 0 0 0.75rem;
    }
    .metro-beat {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: color-mix(in srgb, var(--muted), transparent 60%);
      transition: background 0.04s;
    }
    .metro-beat.on { background: var(--accent); box-shadow: 0 0 8px var(--accent); }
    .freq-disp { font-size: 0.82rem; color: var(--muted); }

    .btn-row { margin-top: 0.75rem; }

    /* ── Fretboard ── */
    .fretboard-wrap {
      position: relative;
      margin-top: 1.4rem;
      display: flex;
      align-items: stretch;
    }
    .fretboard-labels {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 14px 6px 14px 0;
      font-size: 0.75rem;
      font-weight: 700;
      color: color-mix(in srgb, var(--muted), transparent 30%);
      user-select: none;
    }
    .fretboard-canvas {
      flex: 1;
      height: 160px;
      border-radius: 10px;
      display: block;
    }

    /* ── Tuner in-tune glow ── */
    @keyframes in-tune-pulse {
      0%   { text-shadow: 0 0 0px var(--accent); }
      50%  { text-shadow: 0 0 24px var(--accent); }
      100% { text-shadow: 0 0 0px var(--accent); }
    }
    .in-tune { animation: in-tune-pulse 0.6s ease; color: var(--accent) !important; }
  </style>

  <script is:inline>
  (function () {
    'use strict';

    /* ═══════════════════════════════════════════════════════════
       CONSTANTS
    ═══════════════════════════════════════════════════════════ */
    const NOTE_NAMES = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];

    const BASS_STRINGS = [
      { name: 'E', midi: 28 },
      { name: 'A', midi: 33 },
      { name: 'D', midi: 38 },
      { name: 'G', midi: 43 },
    ];

    const MAJOR_SCALE = [0,2,4,5,7,9,11,12];
    const MINOR_SCALE = [0,2,3,5,7,8,10,12];

    const INTERVALS = [
      ['m2',1],['M2',2],['m3',3],['M3',4],['P4',5],
      ['TT',6],['P5',7],['m6',8],['M6',9],['m7',10],['M7',11],['P8',12],
    ];

    /* ═══════════════════════════════════════════════════════════
       NOTE UTILITIES
    ═══════════════════════════════════════════════════════════ */
    function midiToName(midi) {
      return NOTE_NAMES[((midi % 12) + 12) % 12];
    }
    function midiToOctave(midi) {
      return Math.floor(midi / 12) - 1;
    }
    function midiToFullName(midi) {
      return midiToName(midi) + midiToOctave(midi);
    }
    function midiToFreq(midi) {
      return 440 * Math.pow(2, (midi - 69) / 12);
    }
    function freqToMidi(freq) {
      return 69 + 12 * Math.log2(freq / 440);
    }
    function bassPositions(midi) {
      const out = [];
      for (const s of BASS_STRINGS) {
        const fret = midi - s.midi;
        if (fret >= 0 && fret <= 24) out.push({ string: s.name, fret });
      }
      return out;
    }
    function hintsHtml(midi) {
      return bassPositions(midi)
        .map(p => `<span class="hint-chip">${p.string} str · fret ${p.fret}</span>`)
        .join('');
    }

    /* ═══════════════════════════════════════════════════════════
       YIN PITCH DETECTION
    ═══════════════════════════════════════════════════════════ */
    function yin(buf, sr, fmin, fmax) {
      fmin = fmin || 40.0;
      fmax = fmax || 2000.0;
      const N       = buf.length;
      const tauMin  = Math.max(2, Math.floor(sr / fmax));
      const tauMax  = Math.min(Math.floor(sr / fmin), N - 2);
      if (tauMin >= tauMax) return null;

      // Difference function (direct method)
      const d = new Float32Array(tauMax + 1);
      for (let tau = 1; tau <= tauMax; tau++) {
        const end = N - tau;
        for (let j = 0; j < end; j++) {
          const diff = buf[j] - buf[j + tau];
          d[tau] += diff * diff;
        }
      }

      // Cumulative mean normalized difference
      const cmnd = new Float32Array(tauMax + 1);
      cmnd[0] = 1;
      let running = 0;
      for (let tau = 1; tau <= tauMax; tau++) {
        running += d[tau];
        cmnd[tau] = running > 0 ? d[tau] * tau / running : 1;
      }

      // Find first local minimum below threshold
      const threshold = 0.10;
      let tau = tauMin;
      let found = false;
      for (let t = tauMin; t <= tauMax; t++) {
        if (cmnd[t] < threshold) {
          tau = t;
          while (tau + 1 <= tauMax && cmnd[tau + 1] < cmnd[tau]) tau++;
          found = true;
          break;
        }
      }
      if (!found) {
        // Fall back to global minimum in range
        let minVal = Infinity;
        for (let t = tauMin; t <= tauMax; t++) {
          if (cmnd[t] < minVal) { minVal = cmnd[t]; tau = t; }
        }
        // If minimum is above threshold, signal is too noisy
        if (minVal > 0.35) return null;
      }

      // Parabolic interpolation
      if (tau > 0 && tau < tauMax) {
        const x0 = cmnd[tau - 1], x1 = cmnd[tau], x2 = cmnd[tau + 1];
        const denom = x0 - 2 * x1 + x2;
        if (Math.abs(denom) > 1e-8) tau = tau + 0.5 * (x0 - x2) / denom;
      }

      const freq       = sr / tau;
      const cmndTauInt = Math.round(Math.min(tau, tauMax));
      const confidence = Math.max(0, Math.min(1, 1 - cmnd[cmndTauInt]));
      if (confidence < 0.6) return null;
      return { freq, confidence };
    }

    /* ═══════════════════════════════════════════════════════════
       AUDIO STATE
    ═══════════════════════════════════════════════════════════ */
    let audioCtx   = null;
    let analyser   = null;
    let micStream  = null;
    let rafId      = null;

    // Metronome
    let metroRunning  = false;
    let metroInterval = null;
    let metroNextBeat = 0;

    // Tone generator
    let toneOscNode  = null;
    let toneGainNode = null;

    function getCtx() {
      if (!audioCtx || audioCtx.state === 'closed') {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      }
      if (audioCtx.state === 'suspended') audioCtx.resume();
      return audioCtx;
    }

    async function startMic() {
      try {
        const ctx = getCtx();
        micStream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
        const src = ctx.createMediaStreamSource(micStream);
        analyser = ctx.createAnalyser();
        analyser.fftSize = 4096;
        analyser.smoothingTimeConstant = 0;
        src.connect(analyser);
        setMicStatus('Microphone active', 'var(--accent)');
        startRaf();
        return true;
      } catch (err) {
        setMicStatus('Microphone denied: ' + err.message, '#e74c3c');
        return false;
      }
    }

    function stopMic() {
      if (micStream) {
        micStream.getTracks().forEach(t => t.stop());
        micStream = null;
      }
      if (analyser) { analyser.disconnect(); analyser = null; }
      stopRaf();
      setMicStatus('', '');
    }

    function setMicStatus(msg, color) {
      const el = document.getElementById('micStatus');
      if (el) { el.textContent = msg; el.style.color = color; }
    }

    /* Reference tone playback (sawtooth + envelope for bass-like timbre) */
    function playRefTone(midi, duration) {
      duration = duration || 0.8;
      const ctx  = getCtx();
      const freq = midiToFreq(midi);

      // Main oscillator (sawtooth has natural harmonics)
      const osc  = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = 'sawtooth';
      osc.frequency.value = freq;

      // Light low-pass to smooth harshness
      const lp = ctx.createBiquadFilter();
      lp.type = 'lowpass';
      lp.frequency.value = Math.min(freq * 6, 3000);
      lp.Q.value = 0.5;

      const now = ctx.currentTime;
      gain.gain.setValueAtTime(0, now);
      gain.gain.linearRampToValueAtTime(0.28, now + 0.01);
      gain.gain.setValueAtTime(0.28, now + duration * 0.7);
      gain.gain.linearRampToValueAtTime(0, now + duration);

      osc.connect(lp);
      lp.connect(gain);
      gain.connect(ctx.destination);
      osc.start(now);
      osc.stop(now + duration);
    }

    /* ═══════════════════════════════════════════════════════════
       RAF PITCH LOOP
    ═══════════════════════════════════════════════════════════ */
    const pitchBuf = new Float32Array(4096);
    let   lastRafTime = 0;

    function startRaf() {
      if (rafId) return;
      function loop(ts) {
        rafId = requestAnimationFrame(loop);
        if (ts - lastRafTime < 33) return; // ~30 fps
        lastRafTime = ts;
        if (!analyser) return;

        analyser.getFloatTimeDomainData(pitchBuf);

        // RMS silence gate
        let rms = 0;
        for (let i = 0; i < pitchBuf.length; i++) rms += pitchBuf[i] * pitchBuf[i];
        rms = Math.sqrt(rms / pitchBuf.length);

        // Volume bar
        const vf = document.getElementById('volFill');
        if (vf) vf.style.width = Math.min(100, rms * 400) + '%';

        const result = rms > 0.004 ? yin(pitchBuf, audioCtx.sampleRate) : null;
        onPitchResult(result);
      }
      rafId = requestAnimationFrame(loop);
    }

    function stopRaf() {
      if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
    }

    /* ═══════════════════════════════════════════════════════════
       PITCH RESULT → DISPATCH TO ACTIVE PANELS
    ═══════════════════════════════════════════════════════════ */
    let currentTab = 'tuner';

    function onPitchResult(result) {
      updateTuner(result);
      if (currentTab === 'note')      updateNoteDetect(result);
      if (currentTab === 'scales')    updateScaleDetect(result);
      if (currentTab === 'intervals') updateIntervalDetect(result);

      // Update fretboard detected note
      if (result) {
        const nearest = Math.round(freqToMidi(result.freq));
        if (nearest !== fbDetectedMidi) {
          fbDetectedMidi = nearest;
          refreshFretboard();
        }
      } else if (fbDetectedMidi !== null) {
        fbDetectedMidi = null;
        refreshFretboard();
      }
    }

    /* ═══════════════════════════════════════════════════════════
       TUNER PANEL
       Smoothing strategy:
         - EMA on raw MIDI value (alpha=0.2) to reduce note-name flicker
         - Separate EMA on cents (alpha=0.15) for a silky needle
         - Note name only commits after TUNER_STABLE_FRAMES consecutive
           frames landing on the same semitone (within ±30 ¢)
         - Silence clears state so the needle snaps back to centre
    ═══════════════════════════════════════════════════════════ */
    const TUNER_STABLE_FRAMES = 4;   // ~130 ms at 30 fps before note name commits
    const MIDI_EMA_ALPHA      = 0.20; // lower = smoother MIDI trace
    const CENTS_EMA_ALPHA     = 0.12; // lower = smoother needle

    let tunerSmoothedMidi  = null;  // EMA of raw MIDI
    let tunerSmoothedCents = 0;     // EMA of cents offset
    let tunerStableMidi    = null;  // committed semitone (shown in display)
    let tunerStableCount   = 0;     // consecutive frames on same semitone
    let tunerSilenceCount  = 0;     // frames without a valid result

    function updateTuner(result) {
      const noteEl   = document.getElementById('tunerNote');
      const octaveEl = document.getElementById('tunerOctave');
      const freqEl   = document.getElementById('tunerFreq');
      const needleEl = document.getElementById('centsNeedle');
      const centsEl  = document.getElementById('centsValue');
      const confEl   = document.getElementById('tunerConf');
      if (!noteEl) return;

      if (!result) {
        tunerSilenceCount++;
        // After a few silent frames, reset everything cleanly
        if (tunerSilenceCount > 6) {
          tunerSmoothedMidi  = null;
          tunerStableMidi    = null;
          tunerStableCount   = 0;
          tunerSmoothedCents = 0;
          noteEl.textContent   = '--';
          noteEl.classList.remove('in-tune');
          octaveEl.textContent = '';
          freqEl.textContent   = '';
          needleEl.style.left  = '50%';
          centsEl.textContent  = '-- ¢';
          centsEl.style.color  = '';
          confEl.textContent   = '';
        }
        return;
      }
      tunerSilenceCount = 0;

      // ── EMA on raw MIDI ──────────────────────────────────
      const rawMidi = freqToMidi(result.freq);
      if (tunerSmoothedMidi === null) {
        tunerSmoothedMidi = rawMidi;
      } else {
        tunerSmoothedMidi = MIDI_EMA_ALPHA * rawMidi + (1 - MIDI_EMA_ALPHA) * tunerSmoothedMidi;
      }

      const nearest = Math.round(tunerSmoothedMidi);
      const rawCents = (tunerSmoothedMidi - nearest) * 100;

      // ── EMA on cents for silky needle ────────────────────
      tunerSmoothedCents = CENTS_EMA_ALPHA * rawCents + (1 - CENTS_EMA_ALPHA) * tunerSmoothedCents;

      // ── Note name stability gate ──────────────────────────
      if (nearest === tunerStableMidi) {
        tunerStableCount++;
      } else {
        // Only allow note change if we're reasonably confident and smoothed
        if (Math.abs(rawCents) < 30) {
          tunerStableCount = tunerStableMidi === null ? TUNER_STABLE_FRAMES : 1;
          tunerStableMidi  = nearest;
        }
      }
      const showMidi = tunerStableCount >= TUNER_STABLE_FRAMES ? nearest : (tunerStableMidi ?? nearest);

      // ── Update display ────────────────────────────────────
      noteEl.textContent   = midiToName(showMidi);
      octaveEl.textContent = 'Oct ' + midiToOctave(showMidi);
      freqEl.textContent   = result.freq.toFixed(1) + ' Hz';

      const cents  = tunerSmoothedCents;
      const pct    = 50 + cents;
      needleEl.style.left = Math.max(2, Math.min(98, pct)) + '%';
      centsEl.textContent = (cents >= 0 ? '+' : '') + cents.toFixed(1) + ' ¢';

      const inTune = Math.abs(cents) < 5;
      if (inTune) {
        noteEl.classList.add('in-tune');
        centsEl.style.color = '#27ae60';
      } else {
        noteEl.classList.remove('in-tune');
        centsEl.style.color = '';
      }
      confEl.textContent = 'Confidence: ' + (result.confidence * 100).toFixed(0) + '%';
    }

    /* ═══════════════════════════════════════════════════════════
       RANDOM NOTE PRACTICE
    ═══════════════════════════════════════════════════════════ */
    const noteState = {
      active:       false,
      targetMidi:   null,
      stableFrames: 0,
      lastMidi:     null,
      waiting:      false,   // true after correct, waiting for next
      score: { correct: 0, total: 0 },
      streak: 0,
    };
    const NOTE_STABLE_REQUIRED = 6; // ~200ms

    function noteGetFretRange() {
      const lo = parseInt(document.getElementById('fretLow').value, 10)  || 0;
      const hi = parseInt(document.getElementById('fretHigh').value, 10) || 12;
      return { lo, hi };
    }

    function notePickTarget() {
      const { lo, hi } = noteGetFretRange();
      // Collect all valid MIDI notes in the fret range
      const valid = [];
      for (const s of BASS_STRINGS) {
        for (let f = lo; f <= hi; f++) {
          const m = s.midi + f;
          if (!valid.includes(m)) valid.push(m);
        }
      }
      if (!valid.length) return null;
      return valid[Math.floor(Math.random() * valid.length)];
    }

    function noteStart() {
      if (!analyser) {
        setMicStatus('Enable microphone first!', '#e74c3c');
        return;
      }
      noteState.active   = false;
      noteState.waiting  = false;
      noteState.targetMidi = notePickTarget();
      if (!noteState.targetMidi) return;

      document.getElementById('noteStartBtn').textContent = 'New Target';
      document.getElementById('noteNextBtn').disabled     = true;
      noteShowTarget();
      noteState.active = true;

      if (document.getElementById('notePlayRef').checked) {
        playRefTone(noteState.targetMidi, 0.9);
      }
    }

    function noteShowTarget() {
      const midi = noteState.targetMidi;
      document.getElementById('noteTarget').textContent = midiToFullName(midi);
      document.getElementById('noteHints').innerHTML    = hintsHtml(midi);
      setNoteResult('', '');
      noteState.stableFrames = 0;
      noteState.lastMidi     = null;
      noteState.waiting      = false;
      fbTargetMidi = midi;
      refreshFretboard();
    }

    function noteNext() {
      noteState.targetMidi = notePickTarget();
      if (!noteState.targetMidi) return;
      noteShowTarget();
      document.getElementById('noteNextBtn').disabled = true;
      if (document.getElementById('notePlayRef').checked) {
        playRefTone(noteState.targetMidi, 0.9);
      }
    }

    function setNoteResult(text, cls) {
      const el = document.getElementById('noteResult');
      el.textContent = text;
      el.className   = 'note-result' + (cls ? ' ' + cls : '');
    }

    function updateNoteDetect(result) {
      if (!noteState.active || noteState.waiting || !result) {
        if (!result && noteState.active && !noteState.waiting) {
          noteState.stableFrames = 0;
          noteState.lastMidi     = null;
        }
        return;
      }
      const rawMidi = freqToMidi(result.freq);
      const nearest = Math.round(rawMidi);
      const cents   = Math.abs((rawMidi - nearest) * 100);

      // Show what's being detected
      setNoteResult('Hearing: ' + midiToFullName(nearest), 'result-detected');

      if (nearest === noteState.targetMidi && cents < 30) {
        if (noteState.lastMidi === nearest) {
          noteState.stableFrames++;
        } else {
          noteState.lastMidi     = nearest;
          noteState.stableFrames = 1;
        }
        if (noteState.stableFrames >= NOTE_STABLE_REQUIRED) {
          // Correct!
          noteState.waiting = true;
          noteState.score.correct++;
          noteState.score.total++;
          noteState.streak++;
          setNoteResult('Correct! \u2713', 'result-correct');
          updateNoteScore();
          document.getElementById('noteNextBtn').disabled = false;
        }
      } else {
        noteState.lastMidi     = nearest;
        noteState.stableFrames = 0;
      }
    }

    function updateNoteScore() {
      const { correct, total } = noteState.score;
      document.getElementById('noteScore').textContent  = 'Score: ' + correct + ' / ' + total;
      const streak = noteState.streak;
      document.getElementById('noteStreak').textContent = streak > 2 ? '\uD83D\uDD25 ' + streak + ' streak!' : '';
    }

    /* ═══════════════════════════════════════════════════════════
       SCALE PRACTICE
    ═══════════════════════════════════════════════════════════ */
    const scaleState = {
      active:   false,
      notes:    [],   // MIDI values for current scale
      idx:      0,
      stableFrames: 0,
      lastMidi: null,
    };
    const SCALE_STABLE_REQUIRED = 8;

    function scaleBuild() {
      const root   = parseInt(document.getElementById('scaleRoot').value, 10);
      const octave = parseInt(document.getElementById('scaleOctave').value, 10);
      const type   = document.getElementById('scaleType').value;
      const pattern = type === 'major' ? MAJOR_SCALE : MINOR_SCALE;
      const rootMidi = root + (octave + 1) * 12;
      return pattern.map(s => rootMidi + s);
    }

    function scaleStart() {
      if (!analyser) { setMicStatus('Enable microphone first!', '#e74c3c'); return; }
      scaleState.notes  = scaleBuild();
      scaleState.idx    = 0;
      scaleState.active = true;
      scaleState.stableFrames = 0;
      scaleState.lastMidi     = null;
      document.getElementById('scaleStartBtn').textContent = 'Restart Scale';
      document.getElementById('scaleSkipBtn').disabled     = false;
      scaleShowCurrent();
    }

    function scaleShowCurrent() {
      const midi = scaleState.notes[scaleState.idx];
      const total = scaleState.notes.length;
      document.getElementById('scaleProgress').textContent = 'Note ' + (scaleState.idx + 1) + ' / ' + total;
      document.getElementById('scaleTarget').textContent   = midiToFullName(midi);
      document.getElementById('scaleHints').innerHTML      = hintsHtml(midi);
      setScaleResult('', '');
      scaleState.stableFrames = 0;
      scaleState.lastMidi     = null;
      fbTargetMidi = midi;
      refreshFretboard();
      if (document.getElementById('scalePlayRef').checked) {
        playRefTone(midi, 0.6);
      }
    }

    function scaleSkip() {
      if (!scaleState.active) return;
      scaleAdvance();
    }

    function scaleAdvance() {
      scaleState.idx++;
      if (scaleState.idx >= scaleState.notes.length) {
        setScaleResult('Scale complete! \uD83C\uDF89', 'result-correct');
        document.getElementById('scaleTarget').textContent = '--';
        document.getElementById('scaleHints').innerHTML    = '';
        document.getElementById('scaleProgress').textContent = 'Done!';
        document.getElementById('scaleSkipBtn').disabled = true;
        scaleState.active = false;
      } else {
        scaleShowCurrent();
      }
    }

    function setScaleResult(text, cls) {
      const el = document.getElementById('scaleResult');
      el.textContent = text;
      el.className   = 'note-result' + (cls ? ' ' + cls : '');
    }

    function updateScaleDetect(result) {
      if (!scaleState.active || !result) {
        if (!result) { scaleState.stableFrames = 0; scaleState.lastMidi = null; }
        return;
      }
      const rawMidi = freqToMidi(result.freq);
      const nearest = Math.round(rawMidi);
      const cents   = Math.abs((rawMidi - nearest) * 100);
      const target  = scaleState.notes[scaleState.idx];

      setScaleResult('Hearing: ' + midiToFullName(nearest), 'result-detected');

      if (nearest === target && cents < 30) {
        if (scaleState.lastMidi === nearest) {
          scaleState.stableFrames++;
        } else {
          scaleState.lastMidi     = nearest;
          scaleState.stableFrames = 1;
        }
        if (scaleState.stableFrames >= SCALE_STABLE_REQUIRED) {
          setScaleResult('\u2713', 'result-correct');
          setTimeout(() => scaleAdvance(), 300);
        }
      } else {
        scaleState.lastMidi     = nearest;
        scaleState.stableFrames = 0;
      }
    }

    /* ═══════════════════════════════════════════════════════════
       INTERVALS
    ═══════════════════════════════════════════════════════════ */
    const intState = {
      active:       false,
      rootMidi:     null,
      targetMidi:   null,
      phase:        'root',  // 'root' | 'target'
      stableFrames: 0,
      lastMidi:     null,
    };
    const INT_STABLE_REQUIRED = 6;

    function intBuild() {
      const random = document.getElementById('intRandom').checked;
      let rootNote, octave, semitones;
      if (random) {
        rootNote  = Math.floor(Math.random() * 12);
        octave    = 1 + Math.floor(Math.random() * 2); // 1 or 2
        semitones = INTERVALS[Math.floor(Math.random() * INTERVALS.length)][1];
        // sync selectors
        document.getElementById('intRoot').value   = rootNote;
        document.getElementById('intOctave').value = octave;
        const typeIdx = INTERVALS.findIndex(i => i[1] === semitones);
        document.getElementById('intType').selectedIndex = typeIdx;
      } else {
        rootNote  = parseInt(document.getElementById('intRoot').value, 10);
        octave    = parseInt(document.getElementById('intOctave').value, 10);
        const typeVal = parseInt(document.getElementById('intType').value, 10);
        semitones = typeVal;
      }
      const rootMidi   = rootNote + (octave + 1) * 12;
      const targetMidi = rootMidi + semitones;
      return { rootMidi, targetMidi };
    }

    function intStart() {
      if (!analyser) { setMicStatus('Enable microphone first!', '#e74c3c'); return; }
      const { rootMidi, targetMidi } = intBuild();
      intState.rootMidi   = rootMidi;
      intState.targetMidi = targetMidi;
      intState.phase      = 'root';
      intState.active     = true;
      intState.stableFrames = 0;
      intState.lastMidi     = null;

      intRefreshDisplay();
      setIntPhase('root');
      document.getElementById('intStartBtn').textContent = 'New Interval';
      document.getElementById('intNextBtn').disabled     = true;
    }

    function intRefreshDisplay() {
      const rootLabel = midiToFullName(intState.rootMidi);
      const tgtLabel  = midiToFullName(intState.targetMidi);
      const semitones = intState.targetMidi - intState.rootMidi;
      const ivEntry   = INTERVALS.find(i => i[1] === semitones);
      const ivLabel   = ivEntry ? ivEntry[0] : semitones + 'st';

      document.getElementById('intRootDisp').textContent  = rootLabel;
      document.getElementById('intTypeDisp').textContent  = ivLabel;
      document.getElementById('intTargetDisp').textContent = tgtLabel;
      document.getElementById('intHints').innerHTML       = hintsHtml(intState.targetMidi);
    }

    function setIntPhase(phase) {
      intState.phase = phase;
      intState.stableFrames = 0;
      intState.lastMidi = null;
      const label = document.getElementById('intPhaseLabel');
      if (phase === 'root') {
        label.textContent = 'Step 1: Play the root note (' + midiToFullName(intState.rootMidi) + ')';
        fbTargetMidi = intState.rootMidi;
        playRefTone(intState.rootMidi, 0.6);
      } else {
        label.textContent = 'Step 2: Play the interval note (' + midiToFullName(intState.targetMidi) + ')';
        fbTargetMidi = intState.targetMidi;
        playRefTone(intState.targetMidi, 0.6);
      }
      refreshFretboard();
    }

    function setIntResult(text, cls) {
      const el = document.getElementById('intResult');
      el.textContent = text;
      el.className   = 'note-result' + (cls ? ' ' + cls : '');
    }

    function updateIntervalDetect(result) {
      if (!intState.active || !result) {
        if (!result) { intState.stableFrames = 0; intState.lastMidi = null; }
        return;
      }
      const rawMidi  = freqToMidi(result.freq);
      const nearest  = Math.round(rawMidi);
      const cents    = Math.abs((rawMidi - nearest) * 100);
      const expected = intState.phase === 'root' ? intState.rootMidi : intState.targetMidi;

      setIntResult('Hearing: ' + midiToFullName(nearest), 'result-detected');

      if (nearest === expected && cents < 30) {
        if (intState.lastMidi === nearest) {
          intState.stableFrames++;
        } else {
          intState.lastMidi     = nearest;
          intState.stableFrames = 1;
        }
        if (intState.stableFrames >= INT_STABLE_REQUIRED) {
          if (intState.phase === 'root') {
            setIntResult('\u2713 Root matched!', 'result-correct');
            setTimeout(() => setIntPhase('target'), 500);
          } else {
            setIntResult('Interval complete! \uD83C\uDF89', 'result-correct');
            intState.active = false;
            document.getElementById('intNextBtn').disabled = false;
          }
        }
      } else {
        intState.lastMidi     = nearest;
        intState.stableFrames = 0;
      }
    }

    /* ═══════════════════════════════════════════════════════════
       METRONOME
    ═══════════════════════════════════════════════════════════ */
    function metroGetBpm()     { return parseFloat(document.getElementById('metroBpm').value) || 90; }
    function metroGetVolume()  { return (parseFloat(document.getElementById('metroVol').value) || 30) / 100; }

    function metroStart() {
      const ctx      = getCtx();
      metroRunning   = true;
      metroNextBeat  = ctx.currentTime + 0.05;

      function schedule() {
        if (!metroRunning) return;
        const bpm         = metroGetBpm();
        const vol         = metroGetVolume();
        const beatInterval = 60 / bpm;
        const lookahead   = 0.1;

        while (metroNextBeat < ctx.currentTime + lookahead) {
          const t    = metroNextBeat;
          const osc  = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.frequency.value = 1000;
          gain.gain.setValueAtTime(vol * 0.5, t);
          gain.gain.exponentialRampToValueAtTime(0.001, t + 0.035);
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.start(t);
          osc.stop(t + 0.04);

          // Visual flash
          const delay = Math.max(0, (t - ctx.currentTime) * 1000);
          setTimeout(() => {
            const beat = document.getElementById('metroBeat');
            if (beat) {
              beat.classList.add('on');
              setTimeout(() => beat.classList.remove('on'), 80);
            }
          }, delay);

          metroNextBeat += beatInterval;
        }
      }

      metroInterval = setInterval(schedule, 50);
      schedule();
      document.getElementById('metroBtn').textContent = 'Stop Metronome';
    }

    function metroStop() {
      metroRunning = false;
      clearInterval(metroInterval);
      metroInterval = null;
      document.getElementById('metroBtn').textContent = 'Start Metronome';
      const beat = document.getElementById('metroBeat');
      if (beat) beat.classList.remove('on');
    }

    /* ═══════════════════════════════════════════════════════════
       TONE GENERATOR
    ═══════════════════════════════════════════════════════════ */
    function toneGetMidi() {
      const note   = parseInt(document.getElementById('toneNote').value, 10);
      const octave = parseInt(document.getElementById('toneOctave').value, 10);
      return note + (octave + 1) * 12;
    }

    function toneUpdateFreqDisplay() {
      const midi = toneGetMidi();
      const freq = midiToFreq(midi);
      document.getElementById('toneFreqDisp').textContent = freq.toFixed(1) + ' Hz';
      if (toneOscNode) toneOscNode.frequency.value = freq;
    }

    function toneToggle() {
      const btn = document.getElementById('toneBtn');
      if (toneOscNode) {
        toneOscNode.stop();
        toneOscNode  = null;
        toneGainNode = null;
        btn.textContent = 'Play Tone';
        return;
      }
      const ctx  = getCtx();
      const midi = toneGetMidi();
      const freq = midiToFreq(midi);
      const vol  = (parseFloat(document.getElementById('toneVol').value) || 25) / 100;

      toneOscNode  = ctx.createOscillator();
      toneGainNode = ctx.createGain();
      const lp     = ctx.createBiquadFilter();
      lp.type = 'lowpass';
      lp.frequency.value = Math.min(freq * 5, 2500);

      toneOscNode.type = 'sawtooth';
      toneOscNode.frequency.value = freq;
      toneGainNode.gain.value = vol * 0.3;
      toneOscNode.connect(lp);
      lp.connect(toneGainNode);
      toneGainNode.connect(ctx.destination);
      toneOscNode.start();
      btn.textContent = 'Stop Tone';
    }

    /* ═══════════════════════════════════════════════════════════
       UI INIT
    ═══════════════════════════════════════════════════════════ */
    function populateNoteSelects() {
      const selectors = ['scaleRoot','intRoot','toneNote'];
      selectors.forEach(id => {
        const sel = document.getElementById(id);
        if (!sel) return;
        NOTE_NAMES.forEach((n, i) => {
          const opt = document.createElement('option');
          opt.value = i;
          opt.textContent = n;
          sel.appendChild(opt);
        });
      });

      // Interval types
      const intTypeSel = document.getElementById('intType');
      if (intTypeSel) {
        INTERVALS.forEach(([name, semi]) => {
          const opt = document.createElement('option');
          opt.value = semi;
          opt.textContent = name;
          intTypeSel.appendChild(opt);
        });
      }
    }

    function initTabs() {
      document.querySelectorAll('.mode-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.mode-tab').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const tab = btn.dataset.tab;
          currentTab = tab;
          document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
          const panel = document.getElementById(tab + 'Panel');
          if (panel) panel.classList.remove('hidden');
          // Clear target dots when on tuner or tools (no target note)
          if (tab === 'tuner' || tab === 'tools') {
            fbTargetMidi = null;
            refreshFretboard();
          }
        });
      });
    }

    function initMicBtn() {
      const btn = document.getElementById('micBtn');
      btn.addEventListener('click', async () => {
        if (micStream) {
          stopMic();
          btn.textContent = 'Enable Microphone';
          // Stop practice modes
          noteState.active   = false;
          scaleState.active  = false;
          intState.active    = false;
          metroStop();
          if (toneOscNode) toneToggle();
        } else {
          btn.textContent = 'Connecting…';
          btn.disabled    = true;
          const ok = await startMic();
          btn.disabled    = false;
          btn.textContent = ok ? 'Disable Microphone' : 'Enable Microphone';
        }
      });
    }

    function initNotePanel() {
      document.getElementById('noteStartBtn').addEventListener('click', noteStart);
      document.getElementById('noteNextBtn').addEventListener('click', () => {
        if (!noteState.active && noteState.targetMidi) {
          noteState.active = true;
        }
        noteNext();
      });
      document.getElementById('noteResetBtn').addEventListener('click', () => {
        noteState.score  = { correct: 0, total: 0 };
        noteState.streak = 0;
        updateNoteScore();
        setNoteResult('', '');
      });
    }

    function initScalesPanel() {
      document.getElementById('scaleStartBtn').addEventListener('click', scaleStart);
      document.getElementById('scaleSkipBtn').addEventListener('click', scaleSkip);
    }

    function initIntervalsPanel() {
      document.getElementById('intStartBtn').addEventListener('click', intStart);
      document.getElementById('intNextBtn').addEventListener('click', () => {
        intStart();
      });
    }

    function initToolsPanel() {
      // Metronome
      document.getElementById('metroBtn').addEventListener('click', () => {
        if (metroRunning) { metroStop(); } else { metroStart(); }
      });
      document.getElementById('metroBpm').addEventListener('input', function () {
        document.getElementById('metroBpmVal').textContent = this.value;
      });
      document.getElementById('metroVol').addEventListener('input', function () {
        document.getElementById('metroVolVal').textContent = this.value + '%';
      });

      // Tone generator
      document.getElementById('toneBtn').addEventListener('click', toneToggle);
      document.getElementById('toneNote').addEventListener('change', toneUpdateFreqDisplay);
      document.getElementById('toneOctave').addEventListener('change', toneUpdateFreqDisplay);
      document.getElementById('toneVol').addEventListener('input', function () {
        document.getElementById('toneVolVal').textContent = this.value + '%';
        if (toneGainNode) toneGainNode.gain.value = (this.value / 100) * 0.3;
      });
    }

    /* ═══════════════════════════════════════════════════════════
       FRETBOARD CANVAS
       Mirrors the desktop FretboardWidget paintEvent exactly:
         - bg #1c1f24, strings #c8cbd1, frets #3a3f47, nut #e2a86f
         - inlays at 3,5,7,9,12 (#596070), double dots at 12
         - target positions: green #3ddc84 r=9
         - detected position:  blue  #56a3ff r=7
         - G string at top, E string at bottom (index 0=bottom)
    ═══════════════════════════════════════════════════════════ */
    const INLAY_FRETS = [3, 5, 7, 9, 12, 15, 17, 19, 21, 24];

    function drawFretboard(targetPositions, detectedMidi) {
      const canvas = document.getElementById('fretboard');
      if (!canvas) return;

      // Hi-DPI
      const dpr  = window.devicePixelRatio || 1;
      const displayW = canvas.clientWidth;
      const displayH = canvas.clientHeight;
      if (canvas.width  !== Math.round(displayW * dpr) ||
          canvas.height !== Math.round(displayH * dpr)) {
        canvas.width  = Math.round(displayW * dpr);
        canvas.height = Math.round(displayH * dpr);
      }

      const ctx = canvas.getContext('2d');
      ctx.save();
      ctx.scale(dpr, dpr);
      const W = displayW, H = displayH;

      const pad    = 14;
      const lx     = pad, rx = W - pad;
      const ty     = pad, by = H - pad;
      const rw     = rx - lx, rh = by - ty;
      const frets  = 12;
      const strs   = 4; // G D A E (top→bottom = index 3→0)

      // Background
      ctx.fillStyle = '#1c1f24';
      ctx.fillRect(0, 0, W, H);

      // ── Strings (horizontal) ──────────────────────────────
      ctx.lineWidth = 2;
      for (let s = 0; s < strs; s++) {
        const y = ty + (rh * s) / (strs - 1);
        ctx.strokeStyle = '#c8cbd1';
        ctx.beginPath(); ctx.moveTo(lx, y); ctx.lineTo(rx, y); ctx.stroke();
      }

      // ── Fret wires (vertical) ─────────────────────────────
      for (let f = 0; f <= frets; f++) {
        const x = lx + (rw * f) / frets;
        ctx.strokeStyle = f === 0 ? '#e2a86f' : '#3a3f47';
        ctx.lineWidth   = f === 0 ? 4 : 1;
        ctx.beginPath(); ctx.moveTo(x, ty); ctx.lineTo(x, by); ctx.stroke();
      }

      // ── Inlay dots ────────────────────────────────────────
      ctx.fillStyle = '#596070';
      const cy = ty + rh / 2;
      for (const fret of INLAY_FRETS) {
        if (fret > frets) continue;
        const x = lx + (rw * (fret - 0.5)) / frets;
        if (fret === 12 || fret === 24) {
          const off = rh * 0.26;
          ctx.beginPath(); ctx.arc(x, cy - off, 5, 0, Math.PI * 2); ctx.fill();
          ctx.beginPath(); ctx.arc(x, cy + off, 5, 0, Math.PI * 2); ctx.fill();
        } else {
          ctx.beginPath(); ctx.arc(x, cy, 5, 0, Math.PI * 2); ctx.fill();
        }
      }

      // ── Draw position dots ────────────────────────────────
      // stringIndex: 0=E(bottom), 3=G(top) — same convention as desktop
      function dotY(stringIndex) {
        return ty + (rh * (strs - 1 - stringIndex)) / (strs - 1);
      }
      function dotX(fret) {
        // desktop draws AT the fret wire position
        return lx + (rw * fret) / frets;
      }

      function drawDots(positions, color, radius, labelColor) {
        for (const pos of positions) {
          const { stringIndex, fret: f, label } = pos;
          if (f < 0 || f > frets) continue;
          const x = dotX(f), y = dotY(stringIndex);
          ctx.fillStyle = color;
          ctx.beginPath(); ctx.arc(x, y, radius, 0, Math.PI * 2); ctx.fill();
          if (label) {
            ctx.fillStyle = labelColor || '#0b0e12';
            ctx.font = 'bold 10px sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(label, x, y);
          }
        }
      }

      // Target positions (green)
      drawDots(targetPositions || [], '#3ddc84', 9, '#0b0e12');

      // Detected note positions (blue) — all bass positions for that midi
      if (detectedMidi !== null && detectedMidi !== undefined) {
        const detPos = bassPositions(detectedMidi).map(p => ({
          stringIndex: BASS_STRINGS.findIndex(s => s.name === p.string),
          fret: p.fret,
          label: '',
        }));
        drawDots(detPos, '#56a3ff', 7, '#0b0e12');
      }

      ctx.restore();
    }

    // Build target position list from a MIDI note (for green dots)
    function midiToFretPositions(midi) {
      return bassPositions(midi).map(p => ({
        stringIndex: BASS_STRINGS.findIndex(s => s.name === p.string),
        fret: p.fret,
        label: midiToName(midi),
      }));
    }

    // State for what the fretboard should show
    let fbTargetMidi   = null;
    let fbDetectedMidi = null;

    function refreshFretboard() {
      const targets = fbTargetMidi !== null ? midiToFretPositions(fbTargetMidi) : [];
      drawFretboard(targets, fbDetectedMidi);
    }

    /* ═══════════════════════════════════════════════════════════
       BOOT
    ═══════════════════════════════════════════════════════════ */
    document.addEventListener('DOMContentLoaded', function () {
      populateNoteSelects();
      initTabs();
      initMicBtn();
      initNotePanel();
      initScalesPanel();
      initIntervalsPanel();
      initToolsPanel();
      toneUpdateFreqDisplay();

      // Initial fretboard draw + resize handler
      refreshFretboard();
      const ro = new ResizeObserver(() => refreshFretboard());
      const canvas = document.getElementById('fretboard');
      if (canvas) ro.observe(canvas);
    });

  })();
  </script>

</Layout>
