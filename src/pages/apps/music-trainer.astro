---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Music Trainer | SqualieC"
  description="Browser-based music practice: chromatic tuner, note and scale drills, sight-reading flashcards, and staff writing — all in your browser."
>
  <section class="hero hero-surface">
    <p class="eyebrow">Online Tool</p>
    <h1>Music Trainer</h1>
    <p class="lead">
      Practice in your browser: tuner, note and scale drills, sight-reading flashcards,
      and staff writing — powered by the Web Audio API.
    </p>
  </section>

  <section class="card section-title practice-shell">

    <!-- ── Tab navigation ─────────────────────────────── -->
    <div class="mode-toggle">
      <button class="mode-tab active" data-tab="tuner"     type="button">Tuner</button>
      <button class="mode-tab"        data-tab="note"      type="button">Note Practice</button>
      <button class="mode-tab"        data-tab="scales"     type="button">Scales</button>
      <button class="mode-tab"        data-tab="arpeggios" type="button">Arpeggios</button>
      <button class="mode-tab"        data-tab="shape"     type="button">Shape</button>
      <button class="mode-tab"        data-tab="intervals"  type="button">Intervals</button>
      <button class="mode-tab"        data-tab="fretquiz"  type="button">Fret Quiz</button>
      <button class="mode-tab"        data-tab="progr"     type="button">Progressions</button>
      <button class="mode-tab"        data-tab="ear"       type="button">Ear Train</button>
      <button class="mode-tab"        data-tab="theory"    type="button">Theory</button>
      <button class="mode-tab"        data-tab="staff"     type="button">Staff</button>
      <button class="mode-tab"        data-tab="tools"     type="button">Tools</button>
    </div>

    <!-- ── Microphone bar ─────────────────────────────── -->
    <div class="mic-bar">
      <button id="micBtn" class="btn btn-secondary" type="button">Enable Microphone</button>
      <span id="micStatus" class="mic-status"></span>
      <span class="vol-wrap" aria-hidden="true">
        <span id="volFill" class="vol-fill"></span>
      </span>
      <label for="instrSelect" class="instr-label">Instrument</label>
      <select id="instrSelect" class="trainer-select">
        <option value="synth">Bass (Synth)</option>
        <option value="bass" selected>Bass Guitar</option>
        <option value="piano">Piano</option>
      </select>
      <span id="instrStatus" class="instr-status"></span>
    </div>

    <!-- ── TUNER ──────────────────────────────────────── -->
    <div id="tunerPanel" class="tab-panel">
      <div class="tuner-display">
        <div id="tunerNote"   class="tuner-note">--</div>
        <div id="tunerOctave" class="tuner-octave"></div>
        <div id="tunerFreq"   class="tuner-freq"></div>
      </div>
      <div class="cents-meter">
        <div class="cents-labels">
          <span>-50</span><span>-25</span><span>0</span><span>+25</span><span>+50</span>
        </div>
        <div class="cents-track">
          <div class="cents-zone"></div>
          <div id="centsNeedle" class="cents-needle" style="left:50%"></div>
        </div>
        <div id="centsValue" class="cents-value">-- ¢</div>
      </div>
      <div id="tunerConf" class="tuner-conf"></div>
    </div>

    <!-- ── RANDOM NOTE ────────────────────────────────── -->
    <div id="notePanel" class="tab-panel hidden">
      <div class="practice-controls">
        <div class="ctrl-row">
          <label>Fret range</label>
          <input id="fretLow"  type="number" min="0" max="24" value="0"  class="fret-input" />
          <span class="ctrl-sep">to</span>
          <input id="fretHigh" type="number" min="0" max="24" value="12" class="fret-input" />
        </div>
        <div class="ctrl-row">
          <input id="notePlayRef" type="checkbox" checked />
          <label for="notePlayRef">Play reference tone</label>
        </div>
      </div>
      <div class="target-display">
        <div class="target-label">Target Note</div>
        <div id="noteTarget" class="target-note">--</div>
        <div id="noteHints"  class="note-hints"></div>
      </div>
      <div id="noteResult" class="note-result"></div>
      <div class="score-row">
        <span id="noteScore"  class="score-text">Score: 0 / 0</span>
        <span id="noteStreak" class="streak-text"></span>
      </div>
      <div class="btn-row">
        <button id="noteStartBtn" class="btn btn-primary"   type="button">Start Practice</button>
        <button id="noteNextBtn"  class="btn btn-secondary" type="button" disabled>Next Note</button>
        <button id="noteResetBtn" class="btn btn-secondary" type="button">Reset Score</button>
      </div>
    </div>

    <!-- ── SCALES ─────────────────────────────────────── -->
    <div id="scalesPanel" class="tab-panel hidden">
      <div class="practice-controls">
        <div class="ctrl-row">
          <label for="scaleRoot">Root</label>
          <select id="scaleRoot"   class="trainer-select"></select>
          <label for="scaleOctave">Octave</label>
          <select id="scaleOctave" class="trainer-select">
            <option value="1">1</option>
            <option value="2" selected>2</option>
            <option value="3">3</option>
          </select>
          <label for="scaleType">Type</label>
          <select id="scaleType" class="trainer-select">
            <optgroup label="Modes">
              <option value="major">Major (Ionian)</option>
              <option value="dorian">Dorian</option>
              <option value="phrygian">Phrygian</option>
              <option value="lydian">Lydian</option>
              <option value="mixolydian">Mixolydian</option>
              <option value="minor">Natural Minor (Aeolian)</option>
              <option value="locrian">Locrian</option>
            </optgroup>
            <optgroup label="Pentatonic / Blues">
              <option value="minorPent">Minor Pentatonic</option>
              <option value="majorPent">Major Pentatonic</option>
              <option value="blues">Blues</option>
            </optgroup>
            <optgroup label="Other">
              <option value="harmonicMinor">Harmonic Minor</option>
              <option value="melodicMinor">Melodic Minor</option>
            </optgroup>
          </select>
        </div>
        <div class="ctrl-row">
          <input id="scalePlayRef" type="checkbox" checked />
          <label for="scalePlayRef">Play reference tones</label>
        </div>
      </div>
      <div class="target-display">
        <div id="scaleProgress" class="target-label">Note 1 / 8</div>
        <div id="scaleTarget"   class="target-note">--</div>
        <div id="scaleHints"    class="note-hints"></div>
      </div>
      <div id="scaleResult" class="note-result"></div>
      <div class="btn-row">
        <button id="scaleStartBtn" class="btn btn-primary"   type="button">Start Scale</button>
        <button id="scaleSkipBtn"  class="btn btn-secondary" type="button" disabled>Skip Note</button>
      </div>
    </div>

    <!-- ── ARPEGGIOS ─────────────────────────────────────── -->
    <div id="arpeggiosPanel" class="tab-panel hidden">
      <div class="practice-controls">
        <div class="ctrl-row">
          <label for="arpRoot">Root</label>
          <select id="arpRoot"   class="trainer-select"></select>
          <label for="arpOctave">Octave</label>
          <select id="arpOctave" class="trainer-select">
            <option value="1">1</option>
            <option value="2" selected>2</option>
            <option value="3">3</option>
          </select>
          <label for="arpType">Chord</label>
          <select id="arpType" class="trainer-select">
            <optgroup label="Triads">
              <option value="major">Major</option>
              <option value="minor">Minor</option>
              <option value="dim">Diminished</option>
              <option value="aug">Augmented</option>
            </optgroup>
            <optgroup label="7th Chords">
              <option value="maj7">Major 7</option>
              <option value="min7">Minor 7</option>
              <option value="dom7">Dominant 7</option>
              <option value="hdim7">Half-Dim (ø7)</option>
              <option value="dim7">Diminished 7</option>
            </optgroup>
          </select>
        </div>
        <div class="ctrl-row">
          <input id="arpPlayRef" type="checkbox" checked />
          <label for="arpPlayRef">Play reference tones</label>
        </div>
      </div>
      <div class="target-display">
        <div id="arpChordName" class="target-label" style="min-height:1.4em">--</div>
        <div id="arpProgress"  class="target-label">Tone 1 / 4</div>
        <div id="arpTarget"    class="target-note">--</div>
        <div id="arpHints"     class="note-hints"></div>
      </div>
      <div id="arpResult" class="note-result"></div>
      <div class="btn-row">
        <button id="arpStartBtn" class="btn btn-primary"   type="button">Start Arpeggio</button>
        <button id="arpSkipBtn"  class="btn btn-secondary" type="button" disabled>Skip Note</button>
      </div>
    </div>

    <!-- ── SHAPE VIEWER ───────────────────────────────────── -->
    <div id="shapePanel" class="tab-panel hidden">
      <div class="practice-controls">
        <div class="ctrl-row">
          <label for="shapeRoot">Root</label>
          <select id="shapeRoot" class="trainer-select"></select>
          <label for="shapeType">Scale / Arpeggio</label>
          <select id="shapeType" class="trainer-select">
            <optgroup label="Modes">
              <option value="major">Major (Ionian)</option>
              <option value="dorian">Dorian</option>
              <option value="phrygian">Phrygian</option>
              <option value="lydian">Lydian</option>
              <option value="mixolydian">Mixolydian</option>
              <option value="minor">Natural Minor</option>
              <option value="locrian">Locrian</option>
            </optgroup>
            <optgroup label="Pentatonic / Blues">
              <option value="minorPent">Minor Pentatonic</option>
              <option value="majorPent">Major Pentatonic</option>
              <option value="blues">Blues</option>
            </optgroup>
            <optgroup label="Other Scales">
              <option value="harmonicMinor">Harmonic Minor</option>
              <option value="melodicMinor">Melodic Minor</option>
            </optgroup>
            <optgroup label="Arpeggios">
              <option value="arp_major">Major arpeggio</option>
              <option value="arp_minor">Minor arpeggio</option>
              <option value="arp_dom7">Dominant 7 arpeggio</option>
              <option value="arp_min7">Minor 7 arpeggio</option>
              <option value="arp_maj7">Major 7 arpeggio</option>
              <option value="arp_dim7">Dim 7 arpeggio</option>
              <option value="arp_hdim7">Half-Dim arpeggio</option>
            </optgroup>
          </select>
        </div>
      </div>
      <p style="font-size:0.82rem; color:var(--muted); margin:0.3rem 0 0.6rem;">
        Root&nbsp;<span style="color:#ff6b38; font-weight:700;">●</span>&nbsp;&nbsp;
        Scale tones&nbsp;<span style="color:#28edc4; font-weight:700;">●</span>
        &nbsp;— shown on fretboard below
      </p>
      <div id="shapeInfo" style="font-size:0.9rem; color:var(--muted); min-height:1.4em;"></div>
    </div>

    <!-- ── INTERVALS ──────────────────────────────────── -->
    <div id="intervalsPanel" class="tab-panel hidden">
      <div class="practice-controls">
        <div class="ctrl-row">
          <label for="intRoot">Root</label>
          <select id="intRoot"   class="trainer-select"></select>
          <label for="intOctave">Octave</label>
          <select id="intOctave" class="trainer-select">
            <option value="1">1</option>
            <option value="2" selected>2</option>
            <option value="3">3</option>
          </select>
          <label for="intType">Interval</label>
          <select id="intType" class="trainer-select"></select>
        </div>
        <div class="ctrl-row">
          <input id="intRandom" type="checkbox" checked />
          <label for="intRandom">Randomize root + interval</label>
        </div>
      </div>
      <div class="int-display">
        <div class="int-step">
          <div class="target-label">Root</div>
          <div id="intRootDisp"   class="target-note target-note-sm">--</div>
        </div>
        <div class="int-arrow">+</div>
        <div class="int-step">
          <div class="target-label">Interval</div>
          <div id="intTypeDisp"   class="int-type-label">--</div>
        </div>
        <div class="int-arrow">=</div>
        <div class="int-step">
          <div class="target-label">Target</div>
          <div id="intTargetDisp" class="target-note">--</div>
          <div id="intHints"      class="note-hints"></div>
        </div>
      </div>
      <div id="intPhaseLabel" class="int-phase-label">Play the root, then the interval note</div>
      <div id="intResult"     class="note-result"></div>
      <div class="btn-row">
        <button id="intStartBtn" class="btn btn-primary"   type="button">Start</button>
        <button id="intNextBtn"  class="btn btn-secondary" type="button" disabled>Next</button>
      </div>
    </div>

    <!-- ── STAFF ──────────────────────────────────────── -->
    <div id="staffPanel" class="tab-panel hidden">

      <!-- Clef + mode + key + label controls -->
      <div class="ctrl-row staff-top-row" style="flex-wrap:wrap;gap:0.5rem 0.75rem;">
        <span class="ctrl-sep">Clef</span>
        <div class="seg-group" id="clefToggle">
          <button class="seg-btn active" data-clef="bass"   type="button">Bass</button>
          <button class="seg-btn"        data-clef="treble" type="button">Treble</button>
        </div>
        <span class="ctrl-sep">Mode</span>
        <div class="seg-group" id="staffModeToggle">
          <button class="seg-btn active" data-mode="reading" type="button">Reading</button>
          <button class="seg-btn"        data-mode="writing" type="button">Writing</button>
        </div>
        <span class="ctrl-sep">Key</span>
        <select id="staffKeySelect" class="trainer-select">
          <optgroup label="Major">
            <option value="C">C (none)</option>
            <option value="G">G (1♯)</option>
            <option value="D">D (2♯)</option>
            <option value="A">A (3♯)</option>
            <option value="E">E (4♯)</option>
            <option value="B">B (5♯)</option>
            <option value="F#">F♯ (6♯)</option>
            <option value="F">F (1♭)</option>
            <option value="Bb">B♭ (2♭)</option>
            <option value="Eb">E♭ (3♭)</option>
            <option value="Ab">A♭ (4♭)</option>
            <option value="Db">D♭ (5♭)</option>
            <option value="Gb">G♭ (6♭)</option>
          </optgroup>
          <optgroup label="Minor">
            <option value="Am">Am (none)</option>
            <option value="Em">Em (1♯)</option>
            <option value="Bm">Bm (2♯)</option>
            <option value="F#m">F♯m (3♯)</option>
            <option value="C#m">C♯m (4♯)</option>
            <option value="G#m">G♯m (5♯)</option>
            <option value="Dm">Dm (1♭)</option>
            <option value="Gm">Gm (2♭)</option>
            <option value="Cm">Cm (3♭)</option>
            <option value="Fm">Fm (4♭)</option>
            <option value="Bbm">B♭m (5♭)</option>
            <option value="Ebm">E♭m (6♭)</option>
          </optgroup>
          <optgroup label="Other">
            <option value="random">Random per note</option>
          </optgroup>
        </select>
        <div class="seg-group">
          <button id="noteLabelToggle" class="seg-btn" type="button" title="Show note names on staff">Labels</button>
        </div>
      </div>

      <!-- Staff display -->
      <div class="staff-card" id="staffCard">
        <div id="staffContainer"></div>
        <canvas id="writeOverlay" class="write-overlay hidden"></canvas>
      </div>

      <!-- ── READING sub-panel ── -->
      <div id="staffReadingPanel">
        <div class="target-display">
          <div id="staffReadPrompt" class="target-label" style="min-height:1.4em">Identify the note shown on the staff</div>
        </div>
        <div id="staffReadResult" class="note-result"></div>
        <div style="display:flex; align-items:center; gap:0.5rem; margin:0.35rem 0 0.2rem;">
          <div class="seg-group" id="srAnswerToggle">
            <button class="seg-btn active" data-srmode="buttons" type="button">Buttons</button>
            <button class="seg-btn"        data-srmode="type"    type="button">Type</button>
          </div>
        </div>
        <div id="staffReadTypeRow" class="ctrl-row" style="display:none; margin:0.2rem 0 0.5rem;">
          <input id="staffReadTypeInput" type="text" class="fret-input"
            style="width:9rem; text-align:left; font-size:1rem;"
            placeholder="e.g. Bb, F#, A" autocomplete="off" spellcheck="false">
          <button id="staffReadTypeSubmit" class="btn btn-primary" type="button">Check</button>
        </div>
        <div id="staffReadChoices" class="note-choices-grid"></div>
        <div class="score-row">
          <span id="staffReadScore"  class="score-text">Score: 0 / 0</span>
          <span id="staffReadStreak" class="streak-text"></span>
        </div>
        <div class="btn-row">
          <button id="staffReadStartBtn"  class="btn btn-primary"   type="button">Start</button>
          <button id="staffReadNextBtn"   class="btn btn-secondary" type="button" disabled>Next</button>
          <button id="staffReadReplayBtn" class="btn btn-secondary" type="button" disabled>&#x1F50A; Replay</button>
          <button id="staffReadResetBtn"  class="btn btn-secondary" type="button">Reset</button>
        </div>
      </div>

      <!-- ── WRITING sub-panel ── -->
      <div id="staffWritingPanel" class="hidden">
        <div class="target-display">
          <div class="target-label">Place this note on the staff</div>
          <div id="staffWritePrompt" class="target-note write-prompt">--</div>
          <div class="target-label" style="font-size:0.78rem;margin-top:0.3rem">Click the correct line or space</div>
        </div>
        <div id="staffWriteResult" class="note-result"></div>
        <div class="score-row">
          <span id="staffWriteScore"  class="score-text">Score: 0 / 0</span>
          <span id="staffWriteStreak" class="streak-text"></span>
        </div>
        <div class="btn-row">
          <button id="staffWriteStartBtn"  class="btn btn-primary"   type="button">Start</button>
          <button id="staffWriteNextBtn"   class="btn btn-secondary" type="button" disabled>Next</button>
          <button id="staffWriteReplayBtn" class="btn btn-secondary" type="button" disabled>&#x1F50A; Replay</button>
        </div>
      </div>

    </div>

    <!-- ── FRET QUIZ ─────────────────────────────────── -->
    <div id="fretquizPanel" class="tab-panel hidden">
      <div class="panel-body">
        <div class="ctrl-row" style="flex-wrap:wrap;gap:0.7rem;align-items:center;">
          <button id="fqStartBtn" class="btn btn-primary" type="button">Start</button>
          <span id="fqScore" class="score-badge">Score: 0 / 0</span>
          <span id="fqResult" class="result-label"></span>
        </div>
        <div id="fqPrompt" class="drill-prompt" style="display:none;">
          Find all <strong id="fqTargetName"></strong> notes on the fretboard
        </div>
        <p class="panel-hint" id="fqHint">Click Start, then tap every position of the target note on the fretboard below.</p>
      </div>
    </div>

    <!-- ── PROGRESSIONS ───────────────────────────────── -->
    <div id="progrPanel" class="tab-panel hidden">
      <div class="panel-body">
        <div class="ctrl-row" style="flex-wrap:wrap;gap:0.7rem;align-items:center;">
          <label for="progrType">Progression</label>
          <select id="progrType" class="trainer-select">
            <option value="I-IV-V">I – IV – V (major)</option>
            <option value="ii-V-I">ii – V – I (jazz)</option>
            <option value="I-V-vi-IV">I – V – vi – IV (pop)</option>
            <option value="blues12">12-Bar Blues</option>
            <option value="I-IV-I-V">I – IV – I – V (shuffle)</option>
          </select>
          <label for="progrKey">Key</label>
          <select id="progrKey" class="trainer-select"></select>
        </div>
        <div class="ctrl-row" style="flex-wrap:wrap;gap:0.7rem;align-items:center;">
          <button id="progrStartBtn" class="btn btn-primary" type="button">Start</button>
          <span id="progrScore" class="score-badge">Score: 0 / 0</span>
        </div>
        <div id="progrChordRow" class="chord-chip-row" style="display:none;"></div>
        <div id="progrResult" class="result-label" style="margin-top:0.5rem;"></div>
        <p class="panel-hint">Play the root note of each highlighted chord on your bass. Hold it steady for ~0.1s to advance.</p>
      </div>
    </div>

    <!-- ── EAR TRAINING ───────────────────────────────── -->
    <div id="earPanel" class="tab-panel hidden">
      <div class="panel-body">
        <div class="ctrl-row" style="flex-wrap:wrap;gap:0.7rem;align-items:center;">
          <label>Direction</label>
          <div class="seg-group" id="earDirToggle">
            <button class="seg-btn active" data-dir="asc"  type="button">Asc</button>
            <button class="seg-btn"        data-dir="desc" type="button">Desc</button>
            <button class="seg-btn"        data-dir="harm" type="button">Harmonic</button>
          </div>
          <button id="earStartBtn" class="btn btn-primary" type="button">Start</button>
          <span id="earScore" class="score-badge">Score: 0 / 0</span>
        </div>
        <div id="earPromptRow" style="display:none;margin-top:0.6rem;">
          <button id="earReplayBtn" class="btn btn-secondary" type="button">&#x1F50A; Replay</button>
          <span style="font-size:0.85rem;color:var(--muted);margin-left:0.6rem;">What interval did you hear?</span>
        </div>
        <div id="earChoices" class="note-choices-grid" style="margin-top:0.7rem;"></div>
        <div id="earResult" class="result-label" style="margin-top:0.5rem;"></div>
      </div>
    </div>

    <!-- ── THEORY ─────────────────────────────────────── -->
    <div id="theoryPanel" class="tab-panel hidden">
      <div class="panel-body">
        <div class="ctrl-row" style="flex-wrap:wrap;gap:0.7rem;align-items:center;">
          <label>Key</label>
          <span id="cofKeyLabel" class="score-badge" style="min-width:3rem;text-align:center;">C</span>
        </div>
        <div id="cofSvgWrap" style="width:100%;max-width:340px;margin:0.8rem auto 0;"></div>
        <div id="cofDetails" style="margin-top:1rem;"></div>
      </div>
    </div>

    <!-- ── TOOLS ──────────────────────────────────────── -->
    <div id="toolsPanel" class="tab-panel hidden">
      <div class="tools-section">
        <h3 class="tools-heading">Metronome</h3>
        <div class="ctrl-row">
          <label for="metroBpm">BPM</label>
          <input id="metroBpm" type="range" min="30" max="240" value="90" class="trainer-slider" />
          <span id="metroBpmVal" class="slider-val">90</span>
        </div>
        <div class="ctrl-row">
          <label for="metroVol">Volume</label>
          <input id="metroVol" type="range" min="0" max="100" value="30" class="trainer-slider" />
          <span id="metroVolVal" class="slider-val">30%</span>
        </div>
        <div class="btn-row" style="align-items:center">
          <button id="metroBtn"  class="btn btn-primary" type="button">Start Metronome</button>
          <div    id="metroBeat" class="metro-beat"></div>
        </div>
      </div>
      <div class="tools-section">
        <h3 class="tools-heading">Tone Generator</h3>
        <div class="ctrl-row">
          <label for="toneNote">Note</label>
          <select id="toneNote"   class="trainer-select"></select>
          <label for="toneOctave">Octave</label>
          <select id="toneOctave" class="trainer-select">
            <option value="1">1</option>
            <option value="2" selected>2</option>
            <option value="3">3</option>
            <option value="4">4</option>
          </select>
          <span id="toneFreqDisp" class="freq-disp">-- Hz</span>
