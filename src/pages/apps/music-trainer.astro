  <script is:inline>
  (function () {
    'use strict';

    /* ═══════════════════════════════════════════════════════════
       CONSTANTS
    ═══════════════════════════════════════════════════════════ */
    const NOTE_NAMES   = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
    const SHARP_CLASSES = new Set([1,3,6,8,10]);
    const VEX_NAMES    = ['c','c#','d','d#','e','f','f#','g','g#','a','a#','b'];

    const BASS_STRINGS = [
      { name: 'E', midi: 28 },
      { name: 'A', midi: 33 },
      { name: 'D', midi: 38 },
      { name: 'G', midi: 43 },
    ];

    const SCALE_PATTERNS = {
      major:         [0,2,4,5,7,9,11,12],
      dorian:        [0,2,3,5,7,9,10,12],
      phrygian:      [0,1,3,5,7,8,10,12],
      lydian:        [0,2,4,6,7,9,11,12],
      mixolydian:    [0,2,4,5,7,9,10,12],
      minor:         [0,2,3,5,7,8,10,12],
      locrian:       [0,1,3,5,6,8,10,12],
      minorPent:     [0,3,5,7,10,12],
      majorPent:     [0,2,4,7,9,12],
      blues:         [0,3,5,6,7,10,12],
      harmonicMinor: [0,2,3,5,7,8,11,12],
      melodicMinor:  [0,2,3,5,7,9,11,12],
    };

    const ARP_PATTERNS = {
      major: [0,4,7,12],
      minor: [0,3,7,12],
      dim:   [0,3,6,12],
      aug:   [0,4,8,12],
      maj7:  [0,4,7,11,12],
      min7:  [0,3,7,10,12],
      dom7:  [0,4,7,10,12],
      hdim7: [0,3,6,10,12],
      dim7:  [0,3,6,9,12],
    };
    const ARP_LABELS = {
      major:'', minor:'m', dim:'°', aug:'+',
      maj7:'maj7', min7:'m7', dom7:'7', hdim7:'ø7', dim7:'°7',
    };

    const INTERVALS = [
      ['m2',1],['M2',2],['m3',3],['M3',4],['P4',5],
      ['TT',6],['P5',7],['m6',8],['M6',9],['m7',10],['M7',11],['P8',12],
    ];

    const INLAY_FRETS = [3,5,7,9,12,15,17,19,21,24];

    /* ── Key signature definitions ────────────────────── */
    /* adj: { letter → semitone delta }, vex: VexFlow key name */
    const KEY_SIGS = {
      'C':   { adj: {}, vex: 'C' },
      'G':   { adj: { F:+1 }, vex: 'G' },
      'D':   { adj: { F:+1, C:+1 }, vex: 'D' },
      'A':   { adj: { F:+1, C:+1, G:+1 }, vex: 'A' },
      'E':   { adj: { F:+1, C:+1, G:+1, D:+1 }, vex: 'E' },
      'B':   { adj: { F:+1, C:+1, G:+1, D:+1, A:+1 }, vex: 'B' },
      'F#':  { adj: { F:+1, C:+1, G:+1, D:+1, A:+1, E:+1 }, vex: 'F#' },
      'F':   { adj: { B:-1 }, vex: 'F' },
      'Bb':  { adj: { B:-1, E:-1 }, vex: 'Bb' },
      'Eb':  { adj: { B:-1, E:-1, A:-1 }, vex: 'Eb' },
      'Ab':  { adj: { B:-1, E:-1, A:-1, D:-1 }, vex: 'Ab' },
      'Db':  { adj: { B:-1, E:-1, A:-1, D:-1, G:-1 }, vex: 'Db' },
      'Gb':  { adj: { B:-1, E:-1, A:-1, D:-1, G:-1, C:-1 }, vex: 'Gb' },
      'Am':  { adj: {}, vex: 'C' },
      'Em':  { adj: { F:+1 }, vex: 'G' },
      'Bm':  { adj: { F:+1, C:+1 }, vex: 'D' },
      'F#m': { adj: { F:+1, C:+1, G:+1 }, vex: 'A' },
      'C#m': { adj: { F:+1, C:+1, G:+1, D:+1 }, vex: 'E' },
      'G#m': { adj: { F:+1, C:+1, G:+1, D:+1, A:+1 }, vex: 'B' },
      'Dm':  { adj: { B:-1 }, vex: 'F' },
      'Gm':  { adj: { B:-1, E:-1 }, vex: 'Bb' },
      'Cm':  { adj: { B:-1, E:-1, A:-1 }, vex: 'Eb' },
      'Fm':  { adj: { B:-1, E:-1, A:-1, D:-1 }, vex: 'Ab' },
      'Bbm': { adj: { B:-1, E:-1, A:-1, D:-1, G:-1 }, vex: 'Db' },
      'Ebm': { adj: { B:-1, E:-1, A:-1, D:-1, G:-1, C:-1 }, vex: 'Gb' },
    };
    const ALL_KEY_NAMES = Object.keys(KEY_SIGS);

    /* Staff position tables: dy = pixels from stave top (staveY=60) */
    /* Each entry is one diatonic step, natural notes only */
    // STAVE_Y = visual Y of the top staff line in both canvas and SVG coordinates.
    // VexFlow Stave y-param = STAVE_Y - 40 (because VexFlow adds headroom*spacing=4*10=40
    // before drawing the first line, so: stave.y + headroom*spacing = top staff line Y).
    const STAVE_Y = 120;

    const BASS_POSITIONS = [
      { dy:-40, midi:71, name:'B4' }, { dy:-35, midi:69, name:'A4' },
      { dy:-30, midi:67, name:'G4' }, { dy:-25, midi:65, name:'F4' },
      { dy:-20, midi:64, name:'E4' }, { dy:-15, midi:62, name:'D4' },
      { dy:-10, midi:60, name:'C4' }, { dy: -5, midi:59, name:'B3' },
      { dy:  0, midi:57, name:'A3' }, { dy:  5, midi:55, name:'G3' },
      { dy: 10, midi:53, name:'F3' }, { dy: 15, midi:52, name:'E3' },
      { dy: 20, midi:50, name:'D3' }, { dy: 25, midi:48, name:'C3' },
      { dy: 30, midi:47, name:'B2' }, { dy: 35, midi:45, name:'A2' },
      { dy: 40, midi:43, name:'G2' }, { dy: 45, midi:41, name:'F2' },
      { dy: 50, midi:40, name:'E2' }, { dy: 55, midi:38, name:'D2' },
      { dy: 60, midi:36, name:'C2' },
    ];

    const TREBLE_POSITIONS = [
      { dy:-40, midi:91, name:'G6' }, { dy:-35, midi:89, name:'F6' },
      { dy:-30, midi:88, name:'E6' }, { dy:-25, midi:86, name:'D6' },
      { dy:-20, midi:84, name:'C6' }, { dy:-15, midi:83, name:'B5' },
      { dy:-10, midi:81, name:'A5' }, { dy: -5, midi:79, name:'G5' },
      { dy:  0, midi:77, name:'F5' }, { dy:  5, midi:76, name:'E5' },
      { dy: 10, midi:74, name:'D5' }, { dy: 15, midi:72, name:'C5' },
      { dy: 20, midi:71, name:'B4' }, { dy: 25, midi:69, name:'A4' },
      { dy: 30, midi:67, name:'G4' }, { dy: 35, midi:65, name:'F4' },
      { dy: 40, midi:64, name:'E4' }, { dy: 45, midi:62, name:'D4' },
      { dy: 50, midi:60, name:'C4' }, { dy: 55, midi:59, name:'B3' },
      { dy: 60, midi:57, name:'A3' },
    ];

    /* ═══════════════════════════════════════════════════════════
       NOTE UTILITIES
    ═══════════════════════════════════════════════════════════ */
    function midiToName(m)     { return NOTE_NAMES[((m % 12) + 12) % 12]; }
    function midiToOctave(m)   { return Math.floor(m / 12) - 1; }
    function midiToFullName(m) { return midiToName(m) + midiToOctave(m); }
    function midiToFreq(m)     { return 440 * Math.pow(2, (m - 69) / 12); }
    function freqToMidi(f)     { return 69 + 12 * Math.log2(f / 440); }

    function bassPositions(midi) {
      const out = [];
      for (const s of BASS_STRINGS) {
        const fret = midi - s.midi;
        if (fret >= 0 && fret <= 24) out.push({ string: s.name, fret });
      }
      return out;
    }
    function hintsHtml(midi) {
      return bassPositions(midi).map(p => `<span class="hint-chip">${p.string} str · fret ${p.fret}</span>`).join('');
    }

    function shuffle(arr) {
      const a = arr.slice();
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    /* ═══════════════════════════════════════════════════════════
       VEXFLOW  (lazy CDN load)
    ═══════════════════════════════════════════════════════════ */
    let vfReady = false, vfQueue = [];
    function withVF(fn) {
      if (vfReady) { fn(); return; }
      vfQueue.push(fn);
      if (document.getElementById('vfScript')) return;
      const s = document.createElement('script');
      s.id  = 'vfScript';
      s.src = 'https://unpkg.com/vexflow@3.0.9/releases/vexflow-min.js';
      s.onload  = () => { vfReady = true; vfQueue.forEach(f => f()); vfQueue = []; };
      s.onerror = () => console.warn('VexFlow failed to load');
      document.head.appendChild(s);
    }

    let staffCurrentMidi     = null;
    let staffCurrentClef     = 'bass';
    let staffCurrentDrawOpts = {};

    function drawStaff(midi, clef, drawOpts) {
      clef = clef || staffCurrentClef;
      staffCurrentMidi     = midi;
      staffCurrentClef     = clef;
      staffCurrentDrawOpts = drawOpts || {};
      withVF(() => _doDrawStaff(midi, clef, staffCurrentDrawOpts));
    }

    function _doDrawStaff(midi, clef, opts) {
      opts = opts || {};
      const container = document.getElementById('staffContainer');
      if (!container) return;
      container.innerHTML = '';

      const VF = Vex.Flow;
      const W  = Math.max(container.clientWidth || 400, 200);
      const H  = 240;

      const renderer = new VF.Renderer(container, VF.Renderer.Backends.SVG);
      renderer.resize(W, H);
      const ctx = renderer.getContext();

      const keySig = opts.keySig || KEY_SIGS['C'];
      const stave  = new VF.Stave(10, STAVE_Y - 40, W - 20).addClef(clef);
      if (keySig.vex && keySig.vex !== 'C') stave.addKeySignature(keySig.vex);
      stave.setContext(ctx).draw();

      // Note labels on the right side of the SVG — spaces/gaps only
      if (noteLabelsEnabled) {
        const svg = container.querySelector('svg');
        if (svg) {
          const labelPositions = applyKeySigToPositions(getClefPositions(), keySig);
          for (const p of labelPositions) {
            // Only label gap (space) positions, not line positions
            if (p.dy % 10 === 0) continue;
            if (p.dy < -40 || p.dy > 65) continue;
            const t = document.createElementNS('http://www.w3.org/2000/svg', 'text');
            t.setAttribute('x', W - 8);
            t.setAttribute('y', STAVE_Y + p.dy + 4);
            t.setAttribute('text-anchor', 'end');
            t.setAttribute('font-size', '11');
            t.setAttribute('font-family', 'sans-serif');
            t.setAttribute('fill', '#888');
            t.textContent = p.name;
            svg.appendChild(t);
          }
        }
      }

      if (midi === null || midi === undefined) return;

      // Use natural letter/octave when provided (key sig handles the accidental visually)
      let vfNoteKey, addExplicitAccidental = false;
      if (opts.letter && opts.octave != null) {
        vfNoteKey = opts.letter.toLowerCase() + '/' + opts.octave;
      } else {
        const cls = ((midi % 12) + 12) % 12;
        const oct = Math.floor(midi / 12) - 1;
        vfNoteKey = VEX_NAMES[cls] + '/' + oct;
        if (SHARP_CLASSES.has(cls)) addExplicitAccidental = true;
      }

      const note = new VF.StaveNote({ clef, keys: [vfNoteKey], duration: 'w' });
      if (addExplicitAccidental) note.addAccidental(0, new VF.Accidental('#'));
      if (opts.color) note.setStyle({ fillStyle: opts.color, strokeStyle: opts.color });

      const voice = new VF.Voice({ num_beats: 4, beat_value: 4 }).setMode(VF.Voice.Mode.SOFT);
      voice.addTickables([note]);
      new VF.Formatter().joinVoices([voice]).format([voice], W - 100);
      voice.draw(ctx, stave);
    }

    /* ═══════════════════════════════════════════════════════════
       YIN PITCH DETECTION
    ═══════════════════════════════════════════════════════════ */
    function yin(buf, sr, fmin, fmax) {
      fmin = fmin || 28.0; fmax = fmax || 2000.0;
      const N = buf.length;
      const tauMin = Math.max(2, Math.floor(sr / fmax));
      const tauMax = Math.min(Math.floor(sr / fmin), N - 2);
      if (tauMin >= tauMax) return null;

      const d = new Float32Array(tauMax + 1);
      for (let tau = 1; tau <= tauMax; tau++) {
        const end = N - tau;
        for (let j = 0; j < end; j++) { const diff = buf[j] - buf[j + tau]; d[tau] += diff * diff; }
      }
      const cmnd = new Float32Array(tauMax + 1);
      cmnd[0] = 1;
      let running = 0;
      for (let tau = 1; tau <= tauMax; tau++) {
        running += d[tau];
        cmnd[tau] = running > 0 ? d[tau] * tau / running : 1;
      }
      const threshold = 0.10;
      let tau = tauMin, found = false;
      for (let t = tauMin; t <= tauMax; t++) {
        if (cmnd[t] < threshold) {
          tau = t;
          while (tau + 1 <= tauMax && cmnd[tau + 1] < cmnd[tau]) tau++;
          found = true; break;
        }
      }
      if (!found) {
        let minVal = Infinity;
        for (let t = tauMin; t <= tauMax; t++) { if (cmnd[t] < minVal) { minVal = cmnd[t]; tau = t; } }
        if (minVal > 0.35) return null;
      }
      if (tau > 0 && tau < tauMax) {
        const x0 = cmnd[tau - 1], x1 = cmnd[tau], x2 = cmnd[tau + 1];
        const denom = x0 - 2 * x1 + x2;
        if (Math.abs(denom) > 1e-8) tau = tau + 0.5 * (x0 - x2) / denom;
      }
      const freq = sr / tau;
      const ci   = Math.round(Math.min(tau, tauMax));
      const confidence = Math.max(0, Math.min(1, 1 - cmnd[ci]));
      if (confidence < 0.5) return null;
      return { freq, confidence };
    }

    /* ═══════════════════════════════════════════════════════════
       AUDIO STATE
    ═══════════════════════════════════════════════════════════ */
    let audioCtx = null, analyser = null, micStream = null, rafId = null;
    let metroRunning = false, metroInterval = null, metroNextBeat = 0;
    let toneOscNode = null, toneGainNode = null;

    function getCtx() {
      if (!audioCtx || audioCtx.state === 'closed')
        audioCtx = new (window.AudioContext || window.webkitAudioContext)({ latencyHint: 'interactive' });
      if (audioCtx.state === 'suspended') audioCtx.resume();
      return audioCtx;
    }

    async function startMic() {
      try {
        const ctx = getCtx();
        micStream = await navigator.mediaDevices.getUserMedia({
          audio: { echoCancellation: false, noiseSuppression: false, autoGainControl: false }, video: false
        });
        const src = ctx.createMediaStreamSource(micStream);
        analyser = ctx.createAnalyser();
        analyser.fftSize = 8192; analyser.smoothingTimeConstant = 0;
        src.connect(analyser);
        setMicStatus('Microphone active', 'var(--accent)');
        startRaf(); return true;
      } catch (err) {
        setMicStatus('Microphone denied: ' + err.message, '#e74c3c'); return false;
      }
    }

    function stopMic() {
      if (micStream) { micStream.getTracks().forEach(t => t.stop()); micStream = null; }
      if (analyser)  { analyser.disconnect(); analyser = null; }
      stopRaf(); setMicStatus('', '');
    }

    function setMicStatus(msg, color) {
      const el = document.getElementById('micStatus');
      if (el) { el.textContent = msg; el.style.color = color; }
    }

    function playRefTone(midi, duration) {
      duration = duration || 0.8;
      const ctx = getCtx(), freq = midiToFreq(midi);
      const osc = ctx.createOscillator(), gain = ctx.createGain(), lp = ctx.createBiquadFilter();
      osc.type = 'sawtooth'; osc.frequency.value = freq;
      lp.type = 'lowpass'; lp.frequency.value = Math.min(freq * 6, 3000); lp.Q.value = 0.5;
      const now = ctx.currentTime;
      gain.gain.setValueAtTime(0, now);
      gain.gain.linearRampToValueAtTime(0.28, now + 0.01);
      gain.gain.setValueAtTime(0.28, now + duration * 0.7);
      gain.gain.linearRampToValueAtTime(0, now + duration);
      osc.connect(lp); lp.connect(gain); gain.connect(ctx.destination);
      osc.start(now); osc.stop(now + duration);
    }

    /* ═══════════════════════════════════════════════════════════
       INSTRUMENT SAMPLER  (Tone.js lazy CDN load)
    ═══════════════════════════════════════════════════════════ */
    const INSTR_CONFIGS = {
      synth: { label: 'Bass (Synth)', sampled: false },
      bass: {
        label: 'Bass Guitar', sampled: true,
        baseUrl: 'https://nbrosowsky.github.io/tonejs-instruments/samples/bass-electric/',
        urls: { 'A#1':'As1.mp3','A#2':'As2.mp3','A#3':'As3.mp3','C#1':'Cs1.mp3','C#2':'Cs2.mp3','C#3':'Cs3.mp3','E1':'E1.mp3','E2':'E2.mp3','E3':'E3.mp3','G1':'G1.mp3','G2':'G2.mp3','G3':'G3.mp3' },
        release: 0.4,
      },
      piano: {
        label: 'Piano', sampled: true,
        baseUrl: 'https://tonejs.github.io/audio/salamander/',
        urls: { 'A0':'A0.mp3','C1':'C1.mp3','D#1':'Ds1.mp3','F#1':'Fs1.mp3','A1':'A1.mp3','C2':'C2.mp3','D#2':'Ds2.mp3','F#2':'Fs2.mp3','A2':'A2.mp3','C3':'C3.mp3','D#3':'Ds3.mp3','F#3':'Fs3.mp3','A3':'A3.mp3','C4':'C4.mp3','D#4':'Ds4.mp3','F#4':'Fs4.mp3' },
        release: 0.8,
      },
    };

    let toneJsLoaded = false, toneJsQueue = [], activeSampler = null, samplerInstr = null;

    function withToneJs(fn) {
      if (toneJsLoaded) { fn(); return; }
      toneJsQueue.push(fn);
      if (document.getElementById('toneJsScript')) return;
      const s = document.createElement('script');
      s.id  = 'toneJsScript';
      s.src = 'https://cdnjs.cloudflare.com/ajax/libs/tone/14.9.11/Tone.js';
      s.onload  = () => { toneJsLoaded = true; toneJsQueue.forEach(f => f()); toneJsQueue = []; };
      s.onerror = () => setInstrStatus('Tone.js failed', '#e74c3c');
      document.head.appendChild(s);
    }

    function setInstrStatus(msg, color) {
      const el = document.getElementById('instrStatus');
      if (el) { el.textContent = msg; el.style.color = color || 'var(--muted)'; }
    }

    function loadSampler(instrKey) {
      const cfg = INSTR_CONFIGS[instrKey];
      if (!cfg || !cfg.sampled) { setInstrStatus(''); return; }
      if (samplerInstr === instrKey && activeSampler) return;
      withToneJs(() => {
        if (activeSampler) { try { activeSampler.dispose(); } catch (e) {} activeSampler = null; }
        setInstrStatus('Loading\u2026');
        activeSampler = new Tone.Sampler({
          urls: cfg.urls, baseUrl: cfg.baseUrl, release: cfg.release || 1,
          onload:  () => { samplerInstr = instrKey; setInstrStatus(''); },
          onerror: () => { setInstrStatus('Load failed \u2014 using synth', '#e67e22'); activeSampler = null; },
        }).toDestination();
      });
    }

    function midiToToneName(midi) {
      return NOTE_NAMES[((midi % 12) + 12) % 12] + (Math.floor(midi / 12) - 1);
    }

    function playNote(midi, duration) {
      duration = duration || 0.8;
      const instrKey = document.getElementById('instrSelect')?.value || 'synth';
      const cfg = INSTR_CONFIGS[instrKey];
      if (!cfg || !cfg.sampled || !activeSampler || samplerInstr !== instrKey) {
        playRefTone(midi, duration); return;
      }
      if (window.Tone) Tone.start();
      activeSampler.triggerAttackRelease(midiToToneName(midi), duration);
    }

    /* ═══════════════════════════════════════════════════════════
       RAF PITCH LOOP
    ═══════════════════════════════════════════════════════════ */
    const pitchBuf = new Float32Array(8192);

    function startRaf() {
      if (rafId) return;
      function loop() {
        rafId = requestAnimationFrame(loop);
        if (!analyser) return;
        analyser.getFloatTimeDomainData(pitchBuf);
        let rms = 0;
        for (let i = 0; i < pitchBuf.length; i++) rms += pitchBuf[i] * pitchBuf[i];
        rms = Math.sqrt(rms / pitchBuf.length);
        const vf = document.getElementById('volFill');
        if (vf) vf.style.width = Math.min(100, rms * 400) + '%';
        const result = rms > 0.002 ? yin(pitchBuf, audioCtx.sampleRate) : null;
        onPitchResult(result);
      }
      rafId = requestAnimationFrame(loop);
    }
    function stopRaf() { if (rafId) { cancelAnimationFrame(rafId); rafId = null; } }

    /* ═══════════════════════════════════════════════════════════
       PITCH DISPATCH
    ═══════════════════════════════════════════════════════════ */
    let currentTab = 'tuner';

    function onPitchResult(result) {
      updateTuner(result);
      if (currentTab === 'note')       updateNoteDetect(result);
      if (currentTab === 'scales')     updateScaleDetect(result);
      if (currentTab === 'arpeggios')  updateArpDetect(result);
      if (currentTab === 'intervals')  updateIntervalDetect(result);
      if (currentTab === 'progr')      updateProgrDetect(result);
      if (result) {
        const nearest = Math.round(freqToMidi(result.freq));
        if (nearest !== fbDetectedMidi) { fbDetectedMidi = nearest; refreshFretboard(); }
      } else if (fbDetectedMidi !== null) {
        fbDetectedMidi = null; refreshFretboard();
      }
    }

    /* ═══════════════════════════════════════════════════════════
       TUNER
    ═══════════════════════════════════════════════════════════ */
    const TUNER_STABLE_FRAMES = 6;
    const MIDI_EMA_ALPHA      = 0.13;
    const CENTS_EMA_ALPHA     = 0.18;

    let tunerSmoothedMidi  = null, tunerSmoothedCents = 0;
    let tunerStableMidi    = null, tunerStableCount   = 0, tunerSilenceCount = 0;

    function updateTuner(result) {
      const noteEl   = document.getElementById('tunerNote');
      const octaveEl = document.getElementById('tunerOctave');
      const freqEl   = document.getElementById('tunerFreq');
      const needleEl = document.getElementById('centsNeedle');
      const centsEl  = document.getElementById('centsValue');
      const confEl   = document.getElementById('tunerConf');
      if (!noteEl) return;

      if (!result) {
        tunerSilenceCount++;
        if (tunerSilenceCount > 6) {
          tunerSmoothedMidi = null; tunerStableMidi = null; tunerStableCount = 0; tunerSmoothedCents = 0;
          noteEl.textContent = '--'; noteEl.classList.remove('in-tune');
          octaveEl.textContent = ''; freqEl.textContent = '';
          needleEl.style.left = '50%'; centsEl.textContent = '-- \u00a2'; centsEl.style.color = ''; confEl.textContent = '';
        }
        return;
      }
      tunerSilenceCount = 0;
      const rawMidi = freqToMidi(result.freq);
      if (tunerSmoothedMidi === null) tunerSmoothedMidi = rawMidi;
      else tunerSmoothedMidi = MIDI_EMA_ALPHA * rawMidi + (1 - MIDI_EMA_ALPHA) * tunerSmoothedMidi;
      const nearest  = Math.round(tunerSmoothedMidi);
      const rawCents = (tunerSmoothedMidi - nearest) * 100;
      tunerSmoothedCents = CENTS_EMA_ALPHA * rawCents + (1 - CENTS_EMA_ALPHA) * tunerSmoothedCents;
      if (nearest === tunerStableMidi) {
        tunerStableCount++;
      } else if (Math.abs(rawCents) < 30) {
        tunerStableCount = tunerStableMidi === null ? TUNER_STABLE_FRAMES : 1;
        tunerStableMidi  = nearest;
      }
      const showMidi = tunerStableCount >= TUNER_STABLE_FRAMES ? nearest : (tunerStableMidi ?? nearest);
      noteEl.textContent   = midiToName(showMidi);
      octaveEl.textContent = 'Oct ' + midiToOctave(showMidi);
      freqEl.textContent   = result.freq.toFixed(1) + ' Hz';
      const cents = tunerSmoothedCents;
      needleEl.style.left = Math.max(2, Math.min(98, 50 + cents)) + '%';
      centsEl.textContent = (cents >= 0 ? '+' : '') + cents.toFixed(1) + ' \u00a2';
      const inTune = Math.abs(cents) < 5;
      if (inTune) { noteEl.classList.add('in-tune'); centsEl.style.color = '#27ae60'; }
      else { noteEl.classList.remove('in-tune'); centsEl.style.color = ''; }
      confEl.textContent = 'Confidence: ' + (result.confidence * 100).toFixed(0) + '%';
    }

    /* ═══════════════════════════════════════════════════════════
       RANDOM NOTE PRACTICE
    ═══════════════════════════════════════════════════════════ */
    const noteState = { active: false, targetMidi: null, stableFrames: 0, lastMidi: null, waiting: false, score: { correct: 0, total: 0 }, streak: 0 };
    const NOTE_STABLE_REQUIRED = 6;
    let noteAutoTimer = null;

    function notePickTarget() {
      const lo = parseInt(document.getElementById('fretLow').value, 10)  || 0;
      const hi = parseInt(document.getElementById('fretHigh').value, 10) || 12;
      const valid = [];
      for (const s of BASS_STRINGS) {
        for (let f = lo; f <= hi; f++) { const m = s.midi + f; if (!valid.includes(m)) valid.push(m); }
      }
      if (!valid.length) return null;
      return valid[Math.floor(Math.random() * valid.length)];
    }

    function noteStart() {
      if (!analyser) { setMicStatus('Enable microphone first!', '#e74c3c'); return; }
      noteState.active = false; noteState.waiting = false;
      noteState.targetMidi = notePickTarget();
      if (!noteState.targetMidi) return;
      document.getElementById('noteStartBtn').textContent = 'New Target';
      document.getElementById('noteNextBtn').disabled     = true;
      noteShowTarget(); noteState.active = true;
      if (document.getElementById('notePlayRef').checked) playNote(noteState.targetMidi, 0.9);
    }

    function noteShowTarget() {
      const midi = noteState.targetMidi;
      document.getElementById('noteTarget').textContent = midiToFullName(midi);
      document.getElementById('noteHints').innerHTML    = hintsHtml(midi);
      setNoteResult('', '');
      noteState.stableFrames = 0; noteState.lastMidi = null; noteState.waiting = false;
      fbTargetMidi = midi; refreshFretboard();
    }

    function noteNext() {
      if (noteAutoTimer) { clearTimeout(noteAutoTimer); noteAutoTimer = null; }
      noteState.targetMidi = notePickTarget();
      if (!noteState.targetMidi) return;
      noteShowTarget();
      document.getElementById('noteNextBtn').disabled = true;
      if (document.getElementById('notePlayRef').checked) playNote(noteState.targetMidi, 0.9);
    }

    function setNoteResult(text, cls) {
      const el = document.getElementById('noteResult');
      el.textContent = text; el.className = 'note-result' + (cls ? ' ' + cls : '');
    }

    function updateNoteDetect(result) {
      if (!noteState.active || noteState.waiting || !result) {
        if (!result && noteState.active && !noteState.waiting) { noteState.stableFrames = 0; noteState.lastMidi = null; }
        return;
      }
      const rawMidi = freqToMidi(result.freq), nearest = Math.round(rawMidi);
      const cents = Math.abs((rawMidi - nearest) * 100);
      setNoteResult('Hearing: ' + midiToFullName(nearest), 'result-detected');
      if (nearest === noteState.targetMidi && cents < 30) {
        if (noteState.lastMidi === nearest) noteState.stableFrames++;
        else { noteState.lastMidi = nearest; noteState.stableFrames = 1; }
        if (noteState.stableFrames >= NOTE_STABLE_REQUIRED) {
          noteState.waiting = true; noteState.score.correct++; noteState.score.total++; noteState.streak++;
          setNoteResult('Correct! \u2713', 'result-correct'); updateNoteScore();
          document.getElementById('noteNextBtn').disabled = false;
          if (noteAutoTimer) clearTimeout(noteAutoTimer);
          noteAutoTimer = setTimeout(() => { noteAutoTimer = null; if (noteState.waiting) noteNext(); }, 1000);
        }
      } else { noteState.lastMidi = nearest; noteState.stableFrames = 0; }
    }

    function updateNoteScore() {
      const { correct, total } = noteState.score;
      document.getElementById('noteScore').textContent  = 'Score: ' + correct + ' / ' + total;
      const s = noteState.streak;
      document.getElementById('noteStreak').textContent = s > 2 ? '\uD83D\uDD25 ' + s + ' streak!' : '';
    }

    /* ═══════════════════════════════════════════════════════════
       SCALE PRACTICE
    ═══════════════════════════════════════════════════════════ */
    const scaleState = { active: false, waiting: false, notes: [], idx: 0, stableFrames: 0, lastMidi: null };
    const SCALE_STABLE_REQUIRED = 6; // ~0.1s at 60fps

    function scaleBuild() {
      const root    = parseInt(document.getElementById('scaleRoot').value,   10);
      const octave  = parseInt(document.getElementById('scaleOctave').value, 10);
      const type    = document.getElementById('scaleType').value;
      const pattern = SCALE_PATTERNS[type] || SCALE_PATTERNS.major;
      return pattern.map(s => root + (octave + 1) * 12 + s);
    }

    function scaleStart() {
      if (!analyser) { setMicStatus('Enable microphone first!', '#e74c3c'); return; }
      scaleState.notes = scaleBuild(); scaleState.idx = 0; scaleState.active = true;
      scaleState.waiting = false; scaleState.stableFrames = 0; scaleState.lastMidi = null;
      document.getElementById('scaleStartBtn').textContent = 'Restart Scale';
      document.getElementById('scaleSkipBtn').disabled     = false;
      scaleShowCurrent();
    }

    function scaleShowCurrent() {
      const midi = scaleState.notes[scaleState.idx], total = scaleState.notes.length;
      document.getElementById('scaleProgress').textContent = 'Note ' + (scaleState.idx + 1) + ' / ' + total;
      document.getElementById('scaleTarget').textContent   = midiToFullName(midi);
      document.getElementById('scaleHints').innerHTML      = hintsHtml(midi);
      setScaleResult('', ''); scaleState.waiting = false; scaleState.stableFrames = 0; scaleState.lastMidi = null;
      fbTargetMidi = midi; refreshFretboard();
      if (document.getElementById('scalePlayRef').checked) playNote(midi, 0.6);
    }

    function scaleSkip() { if (!scaleState.active) return; scaleAdvance(); }

    function scaleAdvance() {
      scaleState.idx++;
      if (scaleState.idx >= scaleState.notes.length) {
        setScaleResult('Scale complete! \uD83C\uDF89', 'result-correct');
        document.getElementById('scaleTarget').textContent   = '--';
        document.getElementById('scaleHints').innerHTML      = '';
        document.getElementById('scaleProgress').textContent = 'Done!';
        document.getElementById('scaleSkipBtn').disabled     = true;
        scaleState.active = false;
      } else { scaleShowCurrent(); }
    }

    function setScaleResult(text, cls) {
      const el = document.getElementById('scaleResult');
      el.textContent = text; el.className = 'note-result' + (cls ? ' ' + cls : '');
    }

    function updateScaleDetect(result) {
      if (!scaleState.active || scaleState.waiting || !result) {
        if (!result && !scaleState.waiting) { scaleState.stableFrames = 0; scaleState.lastMidi = null; }
        return;
      }
      const rawMidi = freqToMidi(result.freq), nearest = Math.round(rawMidi);
      const cents = Math.abs((rawMidi - nearest) * 100), target = scaleState.notes[scaleState.idx];
      setScaleResult('Hearing: ' + midiToFullName(nearest), 'result-detected');
      if (nearest === target && cents < 30) {
        if (scaleState.lastMidi === nearest) scaleState.stableFrames++;
        else { scaleState.lastMidi = nearest; scaleState.stableFrames = 1; }
        if (scaleState.stableFrames >= SCALE_STABLE_REQUIRED) {
          scaleState.waiting = true; setScaleResult('\u2713', 'result-correct');
          setTimeout(() => scaleAdvance(), 500);
        }
      } else { scaleState.lastMidi = nearest; scaleState.stableFrames = 0; }
    }

    /* ═══════════════════════════════════════════════════════════
       ARPEGGIOS
    ═══════════════════════════════════════════════════════════ */
    const arpState = { active: false, waiting: false, notes: [], idx: 0, stableFrames: 0, lastMidi: null };
    const ARP_STABLE_REQUIRED = 6;

    function arpBuild() {
      const root    = parseInt(document.getElementById('arpRoot').value,   10);
      const octave  = parseInt(document.getElementById('arpOctave').value, 10);
      const type    = document.getElementById('arpType').value;
      const pattern = ARP_PATTERNS[type] || ARP_PATTERNS.major;
      return { notes: pattern.map(s => root + (octave + 1) * 12 + s), root, type };
    }

    function arpChordLabel(rootPc, type) {
      return NOTE_NAMES[rootPc] + (ARP_LABELS[type] || '');
    }

    function arpStart() {
      if (!analyser) { setMicStatus('Enable microphone first!', '#e74c3c'); return; }
      const { notes, root, type } = arpBuild();
      arpState.notes = notes; arpState.idx = 0; arpState.active = true;
      arpState.waiting = false; arpState.stableFrames = 0; arpState.lastMidi = null;
      document.getElementById('arpStartBtn').textContent = 'Restart Arpeggio';
      document.getElementById('arpSkipBtn').disabled     = false;
      document.getElementById('arpChordName').textContent = arpChordLabel(root, type);
      arpShowCurrent();
    }

    function arpShowCurrent() {
      const midi = arpState.notes[arpState.idx], total = arpState.notes.length;
      document.getElementById('arpProgress').textContent = 'Tone ' + (arpState.idx + 1) + ' / ' + total;
      document.getElementById('arpTarget').textContent   = midiToFullName(midi);
      document.getElementById('arpHints').innerHTML      = hintsHtml(midi);
      setArpResult(''); arpState.waiting = false; arpState.stableFrames = 0; arpState.lastMidi = null;
      fbTargetMidi = midi; refreshFretboard();
      if (document.getElementById('arpPlayRef').checked) playNote(midi, 0.6);
    }

    function arpSkip() { if (!arpState.active) return; arpAdvance(); }

    function arpAdvance() {
      arpState.idx++;
      if (arpState.idx >= arpState.notes.length) {
        setArpResult('Arpeggio complete! \uD83C\uDF89', 'result-correct');
        document.getElementById('arpTarget').textContent   = '--';
        document.getElementById('arpHints').innerHTML      = '';
        document.getElementById('arpProgress').textContent = 'Done!';
        document.getElementById('arpSkipBtn').disabled     = true;
        arpState.active = false;
      } else { arpShowCurrent(); }
    }

    function setArpResult(text, cls) {
      const el = document.getElementById('arpResult');
      el.textContent = text; el.className = 'note-result' + (cls ? ' ' + cls : '');
    }

    function updateArpDetect(result) {
      if (!arpState.active || arpState.waiting || !result) {
        if (!result && !arpState.waiting) { arpState.stableFrames = 0; arpState.lastMidi = null; }
        return;
      }
      const rawMidi = freqToMidi(result.freq), nearest = Math.round(rawMidi);
      const cents = Math.abs((rawMidi - nearest) * 100), target = arpState.notes[arpState.idx];
      setArpResult('Hearing: ' + midiToFullName(nearest), 'result-detected');
      if (nearest === target && cents < 30) {
        if (arpState.lastMidi === nearest) arpState.stableFrames++;
        else { arpState.lastMidi = nearest; arpState.stableFrames = 1; }
        if (arpState.stableFrames >= ARP_STABLE_REQUIRED) {
          arpState.waiting = true; setArpResult('\u2713', 'result-correct');
          setTimeout(() => arpAdvance(), 500);
        }
      } else { arpState.lastMidi = nearest; arpState.stableFrames = 0; }
    }

    /* ═══════════════════════════════════════════════════════════
       INTERVALS
    ═══════════════════════════════════════════════════════════ */
    const intState = { active: false, rootMidi: null, targetMidi: null, phase: 'root', stableFrames: 0, lastMidi: null };
    const INT_STABLE_REQUIRED = 6;
    let intAutoTimer = null;

    function intBuild() {
      const random = document.getElementById('intRandom').checked;
      let rootNote, octave, semitones;
      if (random) {
        rootNote  = Math.floor(Math.random() * 12);
        octave    = 1 + Math.floor(Math.random() * 2);
        semitones = INTERVALS[Math.floor(Math.random() * INTERVALS.length)][1];
        document.getElementById('intRoot').value   = rootNote;
        document.getElementById('intOctave').value = octave;
        document.getElementById('intType').selectedIndex = INTERVALS.findIndex(i => i[1] === semitones);
      } else {
        rootNote  = parseInt(document.getElementById('intRoot').value, 10);
        octave    = parseInt(document.getElementById('intOctave').value, 10);
        semitones = parseInt(document.getElementById('intType').value, 10);
      }
      return { rootMidi: rootNote + (octave + 1) * 12, targetMidi: rootNote + (octave + 1) * 12 + semitones };
    }

    function intStart() {
      if (intAutoTimer) { clearTimeout(intAutoTimer); intAutoTimer = null; }
      if (!analyser) { setMicStatus('Enable microphone first!', '#e74c3c'); return; }
      const { rootMidi, targetMidi } = intBuild();
      intState.rootMidi = rootMidi; intState.targetMidi = targetMidi;
      intState.phase = 'root'; intState.active = true; intState.stableFrames = 0; intState.lastMidi = null;
      intRefreshDisplay(); setIntPhase('root');
      document.getElementById('intStartBtn').textContent = 'New Interval';
      document.getElementById('intNextBtn').disabled     = true;
    }

    function intRefreshDisplay() {
      const semitones = intState.targetMidi - intState.rootMidi;
      const ivEntry   = INTERVALS.find(i => i[1] === semitones);
      document.getElementById('intRootDisp').textContent   = midiToFullName(intState.rootMidi);
      document.getElementById('intTypeDisp').textContent   = ivEntry ? ivEntry[0] : semitones + 'st';
      document.getElementById('intTargetDisp').textContent = midiToFullName(intState.targetMidi);
      document.getElementById('intHints').innerHTML        = hintsHtml(intState.targetMidi);
    }

    function setIntPhase(phase) {
      intState.phase = phase; intState.stableFrames = 0; intState.lastMidi = null;
      const label = document.getElementById('intPhaseLabel');
      if (phase === 'root') {
        label.textContent = 'Step 1: Play the root note (' + midiToFullName(intState.rootMidi) + ')';
        fbTargetMidi = intState.rootMidi; playNote(intState.rootMidi, 0.6);
      } else {
        label.textContent = 'Step 2: Play the interval note (' + midiToFullName(intState.targetMidi) + ')';
        fbTargetMidi = intState.targetMidi; playNote(intState.targetMidi, 0.6);
      }
      refreshFretboard();
    }

    function setIntResult(text, cls) {
      const el = document.getElementById('intResult');
      el.textContent = text; el.className = 'note-result' + (cls ? ' ' + cls : '');
    }

    function updateIntervalDetect(result) {
      if (!intState.active || !result) { if (!result) { intState.stableFrames = 0; intState.lastMidi = null; } return; }
      const rawMidi = freqToMidi(result.freq), nearest = Math.round(rawMidi);
      const cents = Math.abs((rawMidi - nearest) * 100);
      const expected = intState.phase === 'root' ? intState.rootMidi : intState.targetMidi;
      setIntResult('Hearing: ' + midiToFullName(nearest), 'result-detected');
      if (nearest === expected && cents < 30) {
        if (intState.lastMidi === nearest) intState.stableFrames++;
        else { intState.lastMidi = nearest; intState.stableFrames = 1; }
        if (intState.stableFrames >= INT_STABLE_REQUIRED) {
          if (intState.phase === 'root') {
            setIntResult('\u2713 Root matched!', 'result-correct');
            setTimeout(() => setIntPhase('target'), 500);
          } else {
            setIntResult('Interval complete! \uD83C\uDF89', 'result-correct');
            intState.active = false;
            document.getElementById('intNextBtn').disabled = false;
            if (intAutoTimer) clearTimeout(intAutoTimer);
            intAutoTimer = setTimeout(() => { intAutoTimer = null; if (!intState.active) intStart(); }, 1000);
          }
        }
      } else { intState.lastMidi = nearest; intState.stableFrames = 0; }
    }

    /* ═══════════════════════════════════════════════════════════
       STAFF TAB — SHARED
    ═══════════════════════════════════════════════════════════ */
    let currentClef       = 'bass';
    let staffMode         = 'reading';
    let currentKey        = 'C';
    let noteLabelsEnabled = false;

    function getClefPositions() {
      return currentClef === 'bass' ? BASS_POSITIONS : TREBLE_POSITIONS;
    }

    // Apply key signature adjustments to a positions array; returns new array with adjusted midi/name
    function applyKeySigToPositions(positions, keySig) {
      const adj = (keySig && keySig.adj) || {};
      return positions.map(p => {
        const letter = p.name[0];
        const octave = parseInt(p.name.slice(1), 10);
        const a = adj[letter] || 0;
        const accType = a > 0 ? '#' : a < 0 ? '\u266d' : null;
        const displayName = accType ? (letter + accType + p.name.slice(1)) : p.name;
        return { dy: p.dy, midi: p.midi + a, name: displayName, letter, octave, accType };
      });
    }

    // Returns the active key sig; picks random one if currentKey === 'random'
    function getActiveKeySig() {
      if (currentKey === 'random') {
        return KEY_SIGS[ALL_KEY_NAMES[Math.floor(Math.random() * ALL_KEY_NAMES.length)]];
      }
      return KEY_SIGS[currentKey] || KEY_SIGS['C'];
    }

    // Helper to get the display key sig for a static draw (no random roll)
    function getStaticKeySig() {
      return currentKey === 'random' ? KEY_SIGS['C'] : (KEY_SIGS[currentKey] || KEY_SIGS['C']);
    }

    // Find closest natural staff position to a y-coordinate (for click mapping in write mode)
    function posFromY(y) {
      const positions = getClefPositions();
      const dy = y - STAVE_Y;
      let best = positions[0], bestDist = Infinity;
      for (const p of positions) {
        const dist = Math.abs(p.dy - dy);
        if (dist < bestDist) { bestDist = dist; best = p; }
      }
      return best;
    }

    function staffReplayNote(midi) {
      if (midi === null || midi === undefined) return;
      if (window.Tone) Tone.start();
      playNote(midi, 1.0);
    }

    /* ── STAFF READING mode ───────────────────────────── */
    const srState = {
      active: false, targetPos: null, targetMidi: null,
      keySig: null, answered: false,
      score: { correct: 0, total: 0 }, streak: 0
    };
    let srAnswerMode = 'buttons'; // 'buttons' | 'type'

    function srPickTarget() {
      const keySig = getActiveKeySig();
      const pool   = applyKeySigToPositions(getClefPositions(), keySig);
      if (!pool.length) return null;
      let pos;
      do {
        pos = pool[Math.floor(Math.random() * pool.length)];
      } while (pool.length > 1 && srState.targetPos && pos.dy === srState.targetPos.dy);
      return { pos, keySig };
    }

    function srStart() {
      const pick = srPickTarget();
      if (!pick) return;
      const { pos, keySig } = pick;
      srState.targetPos  = pos;
      srState.targetMidi = pos.midi;
      srState.keySig     = keySig;
      srState.answered   = false;
      drawStaff(pos.midi, currentClef, { keySig, letter: pos.letter, octave: pos.octave });
      srBuildChoices();
      document.getElementById('staffReadResult').textContent = '';
      document.getElementById('staffReadResult').className   = 'note-result';
      document.getElementById('staffReadStartBtn').textContent = 'New Note';
      document.getElementById('staffReadNextBtn').disabled    = true;
      document.getElementById('staffReadReplayBtn').disabled  = false;
      srState.active = true;
      staffReplayNote(pos.midi);
    }

    // Parses typed note input → pitch class (0-11), or null if unrecognised.
    // Accepts: A B C D E F G + suffixes b/bb/flat/♭ (flat) or #/sharp/♯ (sharp).
    // Case-insensitive; handles "a flat", "Bb", "F#", "b sharp", "A♭", etc.
    function parseNoteInput(raw) {
      const s = raw.trim().toLowerCase()
        .replace(/♯/g, '#').replace(/♭/g, 'b')
        .replace(/\bsharp\b/g, '#').replace(/\bflat\b/g, 'b')
        .replace(/\s+/g, '');
      const NOTE_PC = { c:0, d:2, e:4, f:5, g:7, a:9, b:11 };
      if (!s) return null;
      const pc = NOTE_PC[s[0]];
      if (pc === undefined) return null;
      const suffix = s.slice(1);
      if (suffix === '')  return pc;
      if (suffix === '#') return (pc + 1) % 12;
      if (suffix === 'b') return (pc - 1 + 12) % 12;
      return null;
    }

    /* Build the 3-row answer grid: sharps / naturals / flats
       14-col grid, each button spans 2 cols. Naturals: C(1-2) D(3-4) E(5-6) F(7-8) G(9-10) A(11-12) B(13-14).
       Sharps/flats straddle natural borders: C#(2-3) D#(4-5) ··gap(6-7)·· F#(8-9) G#(10-11) A#(12-13).
       column-gap:0 so naturals touch; only gap is E-F (cols 6-7 = one natural width). */
    function srBuildChoices() {
      const choicesEl  = document.getElementById('staffReadChoices');
      const typeRow    = document.getElementById('staffReadTypeRow');
      const typeInput  = document.getElementById('staffReadTypeInput');
      const typeSubmit = document.getElementById('staffReadTypeSubmit');
      if (srAnswerMode === 'type') {
        choicesEl.innerHTML = '';
        choicesEl.style.display = 'none';
        typeRow.style.display   = 'flex';
        if (typeInput)  { typeInput.value = ''; typeInput.disabled = false; typeInput.focus(); }
        if (typeSubmit) typeSubmit.disabled = false;
        return;
      }
      // buttons mode
      typeRow.style.display    = 'none';
      choicesEl.style.display  = '';
      // gc = start column (1-based), each button spans gc / gc+2; gr = grid-row (1=sharps, 2=naturals, 3=flats)
      const NOTES = [
        { name:'C\u266f', pc:1,  gc:2,  gr:1 }, { name:'D\u266f', pc:3,  gc:4,  gr:1 },
        { name:'F\u266f', pc:6,  gc:8,  gr:1 }, { name:'G\u266f', pc:8,  gc:10, gr:1 },
        { name:'A\u266f', pc:10, gc:12, gr:1 },
        { name:'C', pc:0,  gc:1,  gr:2 }, { name:'D', pc:2,  gc:3,  gr:2 },
        { name:'E', pc:4,  gc:5,  gr:2 }, { name:'F', pc:5,  gc:7,  gr:2 },
        { name:'G', pc:7,  gc:9,  gr:2 }, { name:'A', pc:9,  gc:11, gr:2 },
        { name:'B', pc:11, gc:13, gr:2 },
        { name:'D\u266d', pc:1,  gc:2,  gr:3 }, { name:'E\u266d', pc:3,  gc:4,  gr:3 },
        { name:'G\u266d', pc:6,  gc:8,  gr:3 }, { name:'A\u266d', pc:8,  gc:10, gr:3 },
        { name:'B\u266d', pc:10, gc:12, gr:3 },
      ];

      const container = document.getElementById('staffReadChoices');
      container.innerHTML = '';
      for (const note of NOTES) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = note.name;
        btn.className = 'btn btn-secondary choice-btn' + (note.gr !== 2 ? ' accidental' : '');
        btn.dataset.pc = note.pc;
        btn.style.gridColumn = `${note.gc} / ${note.gc + 2}`;
        btn.style.gridRow    = String(note.gr);
        btn.addEventListener('click', () => srOnChoice(note.pc, btn));
        container.appendChild(btn);
      }
    }

    function srOnChoice(clickedPc, btn) {
      if (srState.answered) return;
      srState.answered = true;
      const targetPc = ((srState.targetMidi % 12) + 12) % 12;
      const correct  = clickedPc === targetPc;
      // Highlight all buttons with target pitch class as correct
      document.querySelectorAll('#staffReadChoices .choice-btn').forEach(b => {
        b.disabled = true;
        const bPc = parseInt(b.dataset.pc, 10);
        if (bPc === targetPc)      b.classList.add('correct');
        else if (b === btn && !correct) b.classList.add('wrong');
      });
      const resultEl = document.getElementById('staffReadResult');
      const noteName = srState.targetPos ? srState.targetPos.name : midiToFullName(srState.targetMidi);
      if (correct) {
        srState.score.correct++; srState.score.total++; srState.streak++;
        resultEl.textContent = 'Correct! \u2713 \u2014 ' + noteName;
        resultEl.className   = 'note-result result-correct';
      } else {
        srState.score.total++; srState.streak = 0;
        resultEl.textContent = 'Wrong. It was ' + noteName;
        resultEl.className   = 'note-result result-wrong';
      }
      srUpdateScore();
      document.getElementById('staffReadNextBtn').disabled = false;
      setTimeout(() => { if (srState.answered) srNext(); }, 1800);
    }

    function srOnTypeSubmit() {
      if (srState.answered || !srState.active) return;
      const input    = document.getElementById('staffReadTypeInput');
      const resultEl = document.getElementById('staffReadResult');
      const pc = parseNoteInput(input ? input.value : '');
      if (pc === null) {
        resultEl.textContent = 'Unrecognised — try e.g. "Bb", "F#", "A"';
        resultEl.className   = 'note-result result-detected';
        return;
      }
      if (input) input.disabled = true;
      document.getElementById('staffReadTypeSubmit').disabled = true;
      srOnChoice(pc, null);
    }

    function srNext() {
      const pick = srPickTarget();
      if (!pick) return;
      const { pos, keySig } = pick;
      srState.targetPos  = pos;
      srState.targetMidi = pos.midi;
      srState.keySig     = keySig;
      srState.answered   = false;
      drawStaff(pos.midi, currentClef, { keySig, letter: pos.letter, octave: pos.octave });
      srBuildChoices();
      document.getElementById('staffReadResult').textContent = '';
      document.getElementById('staffReadResult').className   = 'note-result';
      document.getElementById('staffReadNextBtn').disabled   = true;
      staffReplayNote(pos.midi);
    }

    function srUpdateScore() {
      const { correct, total } = srState.score;
      document.getElementById('staffReadScore').textContent  = 'Score: ' + correct + ' / ' + total;
      const s = srState.streak;
      document.getElementById('staffReadStreak').textContent = s > 2 ? '\uD83D\uDD25 ' + s + ' streak!' : '';
    }

    /* ── STAFF WRITING mode ───────────────────────────── */
    const swState = {
      active: false, targetPos: null, targetMidi: null,
      keySig: null, answered: false,
      score: { correct: 0, total: 0 }, streak: 0
    };
    let writeHoverPos = null;

    function swGetPool(keySig) {
      return applyKeySigToPositions(getClefPositions(), keySig);
    }

    function swPickTarget() {
      const keySig = getActiveKeySig();
      const pool   = swGetPool(keySig);
      if (!pool.length) return null;
      let pos;
      do {
        pos = pool[Math.floor(Math.random() * pool.length)];
      } while (pool.length > 1 && swState.targetPos && pos.dy === swState.targetPos.dy);
      return { pos, keySig };
    }

    function swStart() {
      const pick = swPickTarget();
      if (!pick) return;
      const { pos, keySig } = pick;
      swState.targetPos  = pos;
      swState.targetMidi = pos.midi;
      swState.keySig     = keySig;
      swState.answered   = false;
      document.getElementById('staffWritePrompt').textContent = pos.name;
      document.getElementById('staffWriteResult').textContent = '';
      document.getElementById('staffWriteResult').className   = 'note-result';
      document.getElementById('staffWriteStartBtn').textContent = 'New Note';
      document.getElementById('staffWriteNextBtn').disabled    = true;
      document.getElementById('staffWriteReplayBtn').disabled  = false;
      swState.active = true;
      drawStaff(null, currentClef, { keySig });
      swActivateOverlay();
      staffReplayNote(pos.midi);
    }

    function swActivateOverlay() {
      const card    = document.getElementById('staffCard');
      // SVG logical height is always 200 (set in _doDrawStaff)
      const W = card.clientWidth || 400;
      const H = 240;

      // Replace canvas to drop stale listeners
      const oldOverlay = document.getElementById('writeOverlay');
      const fresh = oldOverlay.cloneNode(false);
      oldOverlay.parentNode.replaceChild(fresh, oldOverlay);

      // Set logical size and matching CSS size so canvas coords == CSS pixels
      fresh.width       = W;
      fresh.height      = H;
      fresh.style.width  = W + 'px';
      fresh.style.height = H + 'px';
      fresh.classList.remove('hidden');

      function getMouseY(e) {
        return e.clientY - fresh.getBoundingClientRect().top;
      }

      fresh.addEventListener('mousemove', (e) => {
        if (swState.answered) return;
        writeHoverPos = posFromY(getMouseY(e));
        swDrawGhost(fresh, writeHoverPos, 'rgba(86,163,255,0.7)');
      });

      fresh.addEventListener('mouseleave', () => {
        writeHoverPos = null;
        swClearOverlay(fresh);
      });

      fresh.addEventListener('click', (e) => {
        if (swState.answered || !swState.active) return;
        swCommitAnswer(posFromY(getMouseY(e)), fresh);
      });
    }

    // Draw a single note-head + ledger lines onto ctx2d without clearing first
    function swPaintNote(ctx2d, W, pos, color, alpha) {
      const x = W * 0.42;
      const y = STAVE_Y + pos.dy;
      ctx2d.save();
      ctx2d.globalAlpha = alpha != null ? alpha : 0.85;
      ctx2d.strokeStyle = color;
      ctx2d.fillStyle   = color;
      ctx2d.lineWidth   = 1.5;
      // Ledger lines above staff (staff lines at dy=0,10,20,30,40)
      const topLedger = Math.ceil(Math.min(pos.dy, 0) / 10) * 10;
      for (let ldy = -10; ldy >= topLedger; ldy -= 10) {
        const ly = STAVE_Y + ldy;
        ctx2d.beginPath(); ctx2d.moveTo(x - 18, ly); ctx2d.lineTo(x + 18, ly); ctx2d.stroke();
      }
      // Ledger lines below staff
      const botLedger = Math.floor(Math.max(pos.dy, 40) / 10) * 10;
      for (let ldy = 50; ldy <= botLedger; ldy += 10) {
        const ly = STAVE_Y + ldy;
        ctx2d.beginPath(); ctx2d.moveTo(x - 18, ly); ctx2d.lineTo(x + 18, ly); ctx2d.stroke();
      }
      ctx2d.beginPath();
      ctx2d.ellipse(x, y, 12, 8, -0.25, 0, Math.PI * 2);
      ctx2d.fill();
      ctx2d.restore();
    }

    function swDrawGhost(canvas, pos, color) {
      swClearOverlay(canvas);
      if (!pos) return;
      swPaintNote(canvas.getContext('2d'), canvas.width, pos, color || 'rgba(86,163,255,0.7)', 0.75);
    }

    function swClearOverlay(canvas) {
      canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);
    }

    function swCommitAnswer(naturalPos, canvas) {
      swState.answered = true;
      // Compare by dy (staff line/space position) — key sig doesn't change position
      const correct = naturalPos.dy === swState.targetPos.dy;
      const ctx2d   = canvas.getContext('2d');
      swClearOverlay(canvas);

      if (correct) {
        swPaintNote(ctx2d, canvas.width, swState.targetPos, '#27ae60', 1);
      } else {
        swPaintNote(ctx2d, canvas.width, swState.targetPos, '#27ae60', 0.9);
        swPaintNote(ctx2d, canvas.width, naturalPos,        '#e74c3c', 0.85);
      }

      // Get keyed display name for the clicked position
      const clickedKeyed = applyKeySigToPositions([naturalPos], swState.keySig)[0];
      const resultEl = document.getElementById('staffWriteResult');
      if (correct) {
        swState.score.correct++; swState.score.total++; swState.streak++;
        resultEl.textContent = 'Correct! \u2713 \u2014 ' + swState.targetPos.name;
        resultEl.className   = 'note-result result-correct';
      } else {
        swState.score.total++; swState.streak = 0;
        resultEl.textContent = 'Wrong \u2014 ' + clickedKeyed.name + '. It was ' + swState.targetPos.name;
        resultEl.className   = 'note-result result-wrong';
      }
      swUpdateScore();
      document.getElementById('staffWriteNextBtn').disabled = false;
      setTimeout(() => { if (swState.answered) swNext(); }, 1800);
    }

    function swNext() {
      const pick = swPickTarget();
      if (!pick) return;
      const { pos, keySig } = pick;
      swState.targetPos  = pos;
      swState.targetMidi = pos.midi;
      swState.keySig     = keySig;
      swState.answered   = false;
      document.getElementById('staffWritePrompt').textContent = pos.name;
      document.getElementById('staffWriteResult').textContent = '';
      document.getElementById('staffWriteResult').className   = 'note-result';
      document.getElementById('staffWriteNextBtn').disabled   = true;
      drawStaff(null, currentClef, { keySig });
      swActivateOverlay();
      staffReplayNote(pos.midi);
    }

    function swUpdateScore() {
      const { correct, total } = swState.score;
      document.getElementById('staffWriteScore').textContent  = 'Score: ' + correct + ' / ' + total;
      const s = swState.streak;
      document.getElementById('staffWriteStreak').textContent = s > 2 ? '\uD83D\uDD25 ' + s + ' streak!' : '';
    }

    function enterStaffTab() {
      const fw = document.getElementById('fretboardWrap');
      if (fw) fw.style.display = 'none';
      drawStaff(null, currentClef, { keySig: getStaticKeySig() });
      applyStaffMode();
    }

    function leaveStaffTab() {
      const fw = document.getElementById('fretboardWrap');
      if (fw) fw.style.display = '';
      const overlay = document.getElementById('writeOverlay');
      if (overlay) overlay.classList.add('hidden');
    }

    function applyStaffMode() {
      const readPanel  = document.getElementById('staffReadingPanel');
      const writePanel = document.getElementById('staffWritingPanel');
      if (staffMode === 'reading') {
        readPanel.classList.remove('hidden');
        writePanel.classList.add('hidden');
        const overlay = document.getElementById('writeOverlay');
        if (overlay) overlay.classList.add('hidden');
        if (!srState.active) drawStaff(null, currentClef, { keySig: getStaticKeySig() });
      } else {
        readPanel.classList.add('hidden');
        writePanel.classList.remove('hidden');
        drawStaff(null, currentClef, { keySig: getStaticKeySig() });
        if (swState.active) swActivateOverlay();
      }
    }

    /* ═══════════════════════════════════════════════════════════
       METRONOME
    ═══════════════════════════════════════════════════════════ */
    function metroStart() {
      const ctx = getCtx();
      metroRunning = true; metroNextBeat = ctx.currentTime + 0.05;
      function schedule() {
        if (!metroRunning) return;
        const bpm = parseFloat(document.getElementById('metroBpm').value) || 90;
        const vol = (parseFloat(document.getElementById('metroVol').value) || 30) / 100;
        const beatInterval = 60 / bpm, lookahead = 0.1;
        while (metroNextBeat < ctx.currentTime + lookahead) {
          const t = metroNextBeat;
          const osc = ctx.createOscillator(), gain = ctx.createGain();
          osc.frequency.value = 1000;
          gain.gain.setValueAtTime(vol * 0.5, t);
          gain.gain.exponentialRampToValueAtTime(0.001, t + 0.035);
          osc.connect(gain); gain.connect(ctx.destination);
          osc.start(t); osc.stop(t + 0.04);
          const delay = Math.max(0, (t - ctx.currentTime) * 1000);
          setTimeout(() => {
            const beat = document.getElementById('metroBeat');
            if (beat) { beat.classList.add('on'); setTimeout(() => beat.classList.remove('on'), 80); }
          }, delay);
          metroNextBeat += beatInterval;
        }
      }
      metroInterval = setInterval(schedule, 50); schedule();
      document.getElementById('metroBtn').textContent = 'Stop Metronome';
    }

    function metroStop() {
      metroRunning = false; clearInterval(metroInterval); metroInterval = null;
      document.getElementById('metroBtn').textContent = 'Start Metronome';
      const beat = document.getElementById('metroBeat');
      if (beat) beat.classList.remove('on');
    }

    /* ═══════════════════════════════════════════════════════════
       TONE GENERATOR
    ═══════════════════════════════════════════════════════════ */
    function toneGetMidi() {
      return parseInt(document.getElementById('toneNote').value, 10) + (parseInt(document.getElementById('toneOctave').value, 10) + 1) * 12;
    }
    function toneUpdateFreqDisplay() {
      const freq = midiToFreq(toneGetMidi());
      document.getElementById('toneFreqDisp').textContent = freq.toFixed(1) + ' Hz';
      if (toneOscNode) toneOscNode.frequency.value = freq;
    }
    function toneToggle() {
      const btn = document.getElementById('toneBtn');
      if (toneOscNode) { toneOscNode.stop(); toneOscNode = null; toneGainNode = null; btn.textContent = 'Play Tone'; return; }
      const ctx = getCtx(), midi = toneGetMidi(), freq = midiToFreq(midi);
      const vol = (parseFloat(document.getElementById('toneVol').value) || 25) / 100;
      toneOscNode = ctx.createOscillator(); toneGainNode = ctx.createGain();
      const lp = ctx.createBiquadFilter(); lp.type = 'lowpass'; lp.frequency.value = Math.min(freq * 5, 2500);
      toneOscNode.type = 'sawtooth'; toneOscNode.frequency.value = freq; toneGainNode.gain.value = vol * 0.3;
      toneOscNode.connect(lp); lp.connect(toneGainNode); toneGainNode.connect(ctx.destination);
      toneOscNode.start(); btn.textContent = 'Stop Tone';
    }

    /* ═══════════════════════════════════════════════════════════
       FRETBOARD CANVAS
    ═══════════════════════════════════════════════════════════ */
    let fbTargetMidi = null, fbDetectedMidi = null, fbShapeData = null;

    /* ── Shape viewer helpers ───────────────────────────── */
    function shapeGetPattern(type) {
      if (type.startsWith('arp_')) return ARP_PATTERNS[type.slice(4)] || ARP_PATTERNS.major;
      return SCALE_PATTERNS[type] || SCALE_PATTERNS.major;
    }

    function shapeRefresh() {
      const root    = parseInt(document.getElementById('shapeRoot').value, 10);
      const type    = document.getElementById('shapeType').value;
      const pattern = shapeGetPattern(type);
      const rootPc  = ((root % 12) + 12) % 12;
      // pitch classes in this scale
      const pcs     = new Set(pattern.map(i => ((rootPc + i) % 12 + 12) % 12));
      // find all neck positions within standard bass range
      const positions = [];
      for (const s of BASS_STRINGS) {
        for (let fret = 0; fret <= 12; fret++) {
          const midi = s.midi + fret;
          const pc   = ((midi % 12) + 12) % 12;
          if (pcs.has(pc)) {
            positions.push({ stringIndex: BASS_STRINGS.indexOf(s), fret, midi });
          }
        }
      }
      fbShapeData = { rootPc, positions };
      fbTargetMidi = null;
      refreshFretboard();
      // update info label
      const rootName = NOTE_NAMES[rootPc];
      const typeLabel = document.getElementById('shapeType').selectedOptions[0]?.text || type;
      document.getElementById('shapeInfo').textContent =
        rootName + ' ' + typeLabel + ' — ' + pcs.size + ' unique pitch classes';
    }

    function drawFretboard(targetPositions, detectedMidi) {
      const canvas = document.getElementById('fretboard');
      if (!canvas) return;
      const dpr = window.devicePixelRatio || 1, dW = canvas.clientWidth, dH = canvas.clientHeight;
      if (canvas.width !== Math.round(dW * dpr) || canvas.height !== Math.round(dH * dpr)) {
        canvas.width = Math.round(dW * dpr); canvas.height = Math.round(dH * dpr);
      }
      const ctx = canvas.getContext('2d');
      ctx.save(); ctx.scale(dpr, dpr);
      const W = dW, H = dH, pad = 14;
      const lx = pad, rx = W - pad, ty = pad, by = H - pad;
      const rw = rx - lx, rh = by - ty, frets = 12, strs = 4;

      ctx.fillStyle = '#1c1f24'; ctx.fillRect(0, 0, W, H);
      ctx.lineWidth = 2;
      for (let s = 0; s < strs; s++) {
        const y = ty + (rh * s) / (strs - 1);
        ctx.strokeStyle = '#c8cbd1'; ctx.beginPath(); ctx.moveTo(lx, y); ctx.lineTo(rx, y); ctx.stroke();
      }
      for (let f = 0; f <= frets; f++) {
        const x = lx + (rw * f) / frets;
        ctx.strokeStyle = f === 0 ? '#e2a86f' : '#3a3f47'; ctx.lineWidth = f === 0 ? 4 : 1;
        ctx.beginPath(); ctx.moveTo(x, ty); ctx.lineTo(x, by); ctx.stroke();
      }
      ctx.fillStyle = '#596070';
      const cy = ty + rh / 2;
      for (const fret of INLAY_FRETS) {
        if (fret > frets) continue;
        const x = lx + (rw * (fret - 0.5)) / frets;
        if (fret === 12 || fret === 24) {
          const off = rh * 0.26;
          ctx.beginPath(); ctx.arc(x, cy - off, 5, 0, Math.PI * 2); ctx.fill();
          ctx.beginPath(); ctx.arc(x, cy + off, 5, 0, Math.PI * 2); ctx.fill();
        } else { ctx.beginPath(); ctx.arc(x, cy, 5, 0, Math.PI * 2); ctx.fill(); }
      }

      function dotY(si)   { return ty + (rh * (strs - 1 - si)) / (strs - 1); }
      function dotX(f)    { return lx + (rw * f) / frets; }
      function drawDots(positions, color, radius, labelColor) {
        for (const pos of positions) {
          const { stringIndex, fret: f, label } = pos;
          if (f < 0 || f > frets) continue;
          const x = dotX(f), y = dotY(stringIndex);
          ctx.fillStyle = color; ctx.beginPath(); ctx.arc(x, y, radius, 0, Math.PI * 2); ctx.fill();
          if (label) {
            ctx.fillStyle = labelColor || '#0b0e12'; ctx.font = 'bold 10px sans-serif';
            ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillText(label, x, y);
          }
        }
      }
      drawDots(targetPositions || [], '#3ddc84', 9, '#0b0e12');
      if (detectedMidi !== null && detectedMidi !== undefined) {
        const detPos = bassPositions(detectedMidi).map(p => ({
          stringIndex: BASS_STRINGS.findIndex(s => s.name === p.string), fret: p.fret, label: ''
        }));
        drawDots(detPos, '#56a3ff', 7, '#0b0e12');
      }
      // shape overlay (scale/arpeggio viewer)
      if (fbShapeData) {
        const toPos = p => ({ stringIndex: p.stringIndex, fret: p.fret, label: midiToName(p.midi) });
        const others = fbShapeData.positions.filter(p => ((p.midi % 12 + 12) % 12) !== fbShapeData.rootPc);
        const roots  = fbShapeData.positions.filter(p => ((p.midi % 12 + 12) % 12) === fbShapeData.rootPc);
        drawDots(others.map(toPos), '#28edc4', 9, '#0b0e12');
        drawDots(roots.map(toPos),  '#ff6b38', 9, '#0b0e12');
      }
      ctx.restore();
    }

    function midiToFretPositions(midi) {
      return bassPositions(midi).map(p => ({
        stringIndex: BASS_STRINGS.findIndex(s => s.name === p.string), fret: p.fret, label: midiToName(midi)
      }));
    }

    function refreshFretboard() {
      const targets = fbTargetMidi !== null ? midiToFretPositions(fbTargetMidi) : [];
      drawFretboard(targets, fbDetectedMidi);
    }

    /* ═══════════════════════════════════════════════════════════
       FEATURE 4 – FRETBOARD NOTE QUIZ
    ═══════════════════════════════════════════════════════════ */
    const fqState = {
      active: false,
      targetPc: null,
      correct: 0,
      total: 0,
      found: [],      // set of 'string-fret' keys already found this round
      allPos: [],     // all valid positions for targetPc
    };

    function fqAllPositions(pc) {
      const out = [];
      BASS_STRINGS.forEach((s, si) => {
        for (let fret = 0; fret <= 24; fret++) {
          if (((s.midi + fret) % 12 + 12) % 12 === pc) out.push({ si, fret, key: `${si}-${fret}` });
        }
      });
      return out;
    }

    function fqPickTarget() {
      fqState.targetPc = Math.floor(Math.random() * 12);
      fqState.found = [];
      fqState.allPos = fqAllPositions(fqState.targetPc);
      document.getElementById('fqTargetName').textContent = NOTE_NAMES[fqState.targetPc];
      document.getElementById('fqPrompt').style.display = '';
      document.getElementById('fqResult').textContent = '';
      document.getElementById('fqResult').className = 'result-label';
      document.getElementById('fqHint').textContent =
        `Found: 0 / ${fqState.allPos.length} — tap each ${NOTE_NAMES[fqState.targetPc]} on the fretboard.`;
      // Show target overlays on fretboard
      fbShapeData = {
        rootPc: fqState.targetPc,
        positions: fqState.allPos.map(p => ({ si: p.si, fret: p.fret })),
      };
      refreshFretboard();
    }

    function fqOnCanvasClick(evt) {
      if (!fqState.active || fqState.targetPc === null) return;
      const canvas = document.getElementById('fretboard');
      const rect = canvas.getBoundingClientRect();
      const x = evt.clientX - rect.left;
      const y = evt.clientY - rect.top;
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      const FRETS = 12;
      const STRINGS = 4;
      const padL = 28, padR = 12, padT = 14, padB = 14;
      const drawW = w - padL - padR;
      const drawH = h - padT - padB;
      const fretSpacing = drawW / FRETS;
      const stringSpacing = drawH / (STRINGS - 1);

      let closestSi = -1, closestFret = -1, minDist = Infinity;
      for (let si = 0; si < STRINGS; si++) {
        const sy = padT + si * stringSpacing;
        for (let fret = 1; fret <= FRETS; fret++) {
          const fx = padL + (fret - 0.5) * fretSpacing;
          const dist = Math.sqrt((x - fx) ** 2 + (y - sy) ** 2);
          if (dist < minDist) { minDist = dist; closestSi = si; closestFret = fret; }
        }
      }
      if (minDist > fretSpacing * 0.65) return;
      const stringObj = BASS_STRINGS[closestSi];
      const midi = stringObj.midi + closestFret;
      const pc = ((midi % 12) + 12) % 12;
      const key = `${closestSi}-${closestFret}`;

      if (pc !== fqState.targetPc) {
        fqState.total++;
        fqState.correct = Math.max(0, fqState.correct - 0); // no subtract, just mark wrong
        document.getElementById('fqResult').textContent = `✗ That's ${NOTE_NAMES[pc]}, not ${NOTE_NAMES[fqState.targetPc]}`;
        document.getElementById('fqResult').className = 'result-label wrong';
        fqUpdateScore();
        return;
      }
      if (fqState.found.includes(key)) return;
      fqState.found.push(key);
      fqState.total++;
      fqState.correct++;
      document.getElementById('fqResult').textContent = `✓ ${NOTE_NAMES[fqState.targetPc]} on ${stringObj.name} str fret ${closestFret}`;
      document.getElementById('fqResult').className = 'result-label correct';
      fqUpdateScore();
      document.getElementById('fqHint').textContent =
        `Found: ${fqState.found.length} / ${fqState.allPos.length} — keep tapping!`;

      if (fqState.found.length >= fqState.allPos.length) {
        setTimeout(() => {
          document.getElementById('fqResult').textContent = `All ${NOTE_NAMES[fqState.targetPc]}s found! Next…`;
          setTimeout(fqPickTarget, 900);
        }, 300);
      }
    }

    function fqUpdateScore() {
      document.getElementById('fqScore').textContent = `Score: ${fqState.correct} / ${fqState.total}`;
    }

    function fqStart() {
      fqState.active = true;
      fqState.correct = 0;
      fqState.total = 0;
      document.getElementById('fqStartBtn').textContent = 'Reset';
      fqPickTarget();
    }

    function initFretQuizPanel() {
      document.getElementById('fqStartBtn').addEventListener('click', fqStart);
      const canvas = document.getElementById('fretboard');
      canvas.addEventListener('click', fqOnCanvasClick);
    }

    /* ═══════════════════════════════════════════════════════════
       FEATURE 5 – CHORD PROGRESSION DRILL
    ═══════════════════════════════════════════════════════════ */
    const PROGRESSIONS = {
      'I-IV-V':    [0, 5, 7],
      'ii-V-I':    [2, 7, 0],
      'I-V-vi-IV': [0, 7, 9, 5],
      'blues12':   [0,0,0,0, 5,5,0,0, 7,5,0,7],
      'I-IV-I-V':  [0, 5, 0, 7],
    };
    const PROGR_STABLE = 6;

    const progrState = {
      active: false,
      offsets: [],
      keyPc: 0,
      idx: 0,
      correct: 0,
      total: 0,
      stableCount: 0,
      lastPc: null,
    };

    function progrBuild() {
      const type = document.getElementById('progrType').value;
      const keyPc = parseInt(document.getElementById('progrKey').value);
      progrState.offsets = PROGRESSIONS[type] || [0, 5, 7];
      progrState.keyPc = keyPc;
      progrState.idx = 0;
      progrState.stableCount = 0;
      progrState.lastPc = null;

      const row = document.getElementById('progrChordRow');
      row.innerHTML = progrState.offsets.map((off, i) => {
        const pc = (keyPc + off) % 12;
        return `<span class="chord-chip${i === 0 ? ' active' : ''}" data-idx="${i}">${NOTE_NAMES[pc]}</span>`;
      }).join('');
      row.style.display = 'flex';
      document.getElementById('progrResult').textContent = '';
      document.getElementById('progrResult').className = 'result-label';
    }

    function progrUpdateChips() {
      document.querySelectorAll('#progrChordRow .chord-chip').forEach((chip, i) => {
        chip.className = 'chord-chip' + (i < progrState.idx ? ' done' : i === progrState.idx ? ' active' : '');
      });
    }

    function progrAdvance() {
      progrState.idx++;
      progrState.stableCount = 0;
      progrState.lastPc = null;
      if (progrState.idx >= progrState.offsets.length) {
        document.getElementById('progrResult').textContent = '✓ Progression complete!';
        document.getElementById('progrResult').className = 'result-label correct';
        progrState.correct++;
        progrState.total++;
        fqUpdateProgrScore();
        progrUpdateChips();
        setTimeout(() => { progrState.idx = 0; progrState.stableCount = 0; progrUpdateChips(); document.getElementById('progrResult').textContent = ''; }, 1200);
      } else {
        progrUpdateChips();
      }
    }

    function fqUpdateProgrScore() {
      document.getElementById('progrScore').textContent = `Score: ${progrState.correct} / ${progrState.total}`;
    }

    function updateProgrDetect(result) {
      if (!progrState.active || progrState.idx >= progrState.offsets.length) return;
      const targetPc = (progrState.keyPc + progrState.offsets[progrState.idx]) % 12;
      if (!result) { progrState.stableCount = 0; progrState.lastPc = null; return; }
      const pc = ((Math.round(freqToMidi(result.freq)) % 12) + 12) % 12;
      if (pc === progrState.lastPc) {
        progrState.stableCount++;
        if (progrState.stableCount >= PROGR_STABLE) {
          if (pc === targetPc) {
            document.getElementById('progrResult').textContent = `✓ ${NOTE_NAMES[pc]}`;
            document.getElementById('progrResult').className = 'result-label correct';
            progrAdvance();
          }
          progrState.stableCount = 0;
        }
      } else {
        progrState.lastPc = pc;
        progrState.stableCount = 1;
      }
    }

    function progrStart() {
      progrState.active = true;
      progrState.correct = 0;
      progrState.total = 0;
      document.getElementById('progrStartBtn').textContent = 'Reset';
      progrBuild();
    }

    function initProgrPanel() {
      document.getElementById('progrStartBtn').addEventListener('click', progrStart);
    }

    /* ═══════════════════════════════════════════════════════════
       FEATURE 6 – EAR TRAINING: INTERVAL ID
    ═══════════════════════════════════════════════════════════ */
    const earState = {
      active: false,
      direction: 'asc',
      rootMidi: null,
      targetSemi: null,
      correct: 0,
      total: 0,
    };

    function earPlayPairNotes(root, semi, dir) {
      if (dir === 'harm') {
        playNote(root, 1.2); playNote(root + semi, 1.2);
      } else if (dir === 'asc') {
        playNote(root, 0.7);
        setTimeout(() => playNote(root + semi, 0.7), 600);
      } else {
        playNote(root + semi, 0.7);
        setTimeout(() => playNote(root, 0.7), 600);
      }
    }

    function earPlayPair() {
      const root = 36 + Math.floor(Math.random() * 13); // C2–C3
      const idx = Math.floor(Math.random() * INTERVALS.length);
      const [, semi] = INTERVALS[idx];
      earState.rootMidi = root;
      earState.targetSemi = semi;
      earPlayPairNotes(root, semi, earState.direction);
      document.getElementById('earPromptRow').style.display = '';
      document.getElementById('earResult').textContent = '';
      document.getElementById('earResult').className = 'result-label';
      earBuildChoices();
    }

    function earBuildChoices() {
      const container = document.getElementById('earChoices');
      container.innerHTML = INTERVALS.map(([name, semi]) =>
        `<button class="choice-btn" data-semi="${semi}" type="button">${name}</button>`
      ).join('');
      container.querySelectorAll('.choice-btn').forEach(btn => {
        btn.addEventListener('click', () => earOnChoice(parseInt(btn.dataset.semi)));
      });
    }

    function earOnChoice(semi) {
      earState.total++;
      const correct = semi === earState.targetSemi;
      if (correct) earState.correct++;
      const res = document.getElementById('earResult');
      const correctName = INTERVALS.find(([,s]) => s === earState.targetSemi)?.[0] ?? '?';
      res.textContent = correct
        ? `✓ Correct! ${correctName}`
        : `✗ It was ${correctName}`;
      res.className = 'result-label ' + (correct ? 'correct' : 'wrong');
      document.getElementById('earScore').textContent = `Score: ${earState.correct} / ${earState.total}`;
      // Highlight correct answer
      document.querySelectorAll('#earChoices .choice-btn').forEach(btn => {
        const s = parseInt(btn.dataset.semi);
        if (s === earState.targetSemi) btn.style.background = 'color-mix(in srgb,var(--accent),transparent 55%)';
        if (s === semi && !correct) btn.style.background = 'color-mix(in srgb,var(--accent-2),transparent 55%)';
      });
      setTimeout(() => earPlayPair(), 1500);
    }

    function initEarPanel() {
      document.getElementById('earStartBtn').addEventListener('click', () => {
        if (window.Tone) Tone.start();
        earState.active = true;
        earState.correct = 0;
        earState.total = 0;
        document.getElementById('earStartBtn').textContent = 'Next';
        earPlayPair();
      });
      document.getElementById('earReplayBtn').addEventListener('click', () => {
        if (window.Tone) Tone.start();
        if (earState.rootMidi !== null && earState.targetSemi !== null) {
          earPlayPairNotes(earState.rootMidi, earState.targetSemi, earState.direction);
        }
      });
      document.querySelectorAll('#earDirToggle .seg-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('#earDirToggle .seg-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          earState.direction = btn.dataset.dir;
        });
      });
    }

    /* ═══════════════════════════════════════════════════════════
       FEATURE 7 – CIRCLE OF FIFTHS + DIATONIC CHORDS
    ═══════════════════════════════════════════════════════════ */
    const COF_MAJOR = ['C','G','D','A','E','B','F#/Gb','Db','Ab','Eb','Bb','F'];
    const COF_MINOR = ['Am','Em','Bm','F#m','C#m','G#m','D#m/Ebm','Bbm','Fm','Cm','Gm','Dm'];
    const COF_PCS   = [0,7,2,9,4,11,6,1,8,3,10,5];
    const COF_COLORS_OUTER = '#1e4278';
    const COF_COLORS_INNER = '#2a1250';
    const DIATONIC_QUALITIES = ['maj','min','min','maj','maj','min','dim'];
    const DIATONIC_ROMAN     = ['I','ii','iii','IV','V','vi','vii°'];

    let cofSelectedIdx = 0;

    function cofWedgePath(cx, cy, r1, r2, startAngle, endAngle) {
      const toRad = a => a * Math.PI / 180;
      const cos1s = Math.cos(toRad(startAngle)), sin1s = Math.sin(toRad(startAngle));
      const cos1e = Math.cos(toRad(endAngle)),   sin1e = Math.sin(toRad(endAngle));
      return [
        `M ${cx + r1*cos1s} ${cy + r1*sin1s}`,
        `A ${r1} ${r1} 0 0 1 ${cx + r1*cos1e} ${cy + r1*sin1e}`,
        `L ${cx + r2*cos1e} ${cy + r2*sin1e}`,
        `A ${r2} ${r2} 0 0 0 ${cx + r2*cos1s} ${cy + r2*sin1s}`,
        'Z'
      ].join(' ');
    }

    function cofBuildSvg() {
      const SIZE = 320, cx = SIZE/2, cy = SIZE/2;
      const R1 = 130, R2 = 100, R3 = 70, Rc = 42;
      const sliceAngle = 360 / 12;
      let svg = `<svg viewBox="0 0 ${SIZE} ${SIZE}" xmlns="http://www.w3.org/2000/svg">`;
      for (let i = 0; i < 12; i++) {
        const start = i * sliceAngle - 90 - sliceAngle/2;
        const end   = start + sliceAngle;
        const mid   = (start + end) / 2 * Math.PI / 180;
        const outerR = (R1 + R2) / 2;
        const innerR = (R2 + R3) / 2;
        const isSelected = i === cofSelectedIdx;
        // Outer ring (major)
        svg += `<path d="${cofWedgePath(cx,cy,R1,R2,start,end)}"
          fill="${COF_COLORS_OUTER}" stroke="color-mix(in srgb,#b8ceee,transparent 65%)"
          stroke-width="1" class="cof-wedge${isSelected?' selected':''}"
          data-idx="${i}" data-ring="major"/>`;
        svg += `<text x="${cx + outerR*Math.cos(mid)}" y="${cy + outerR*Math.sin(mid)}"
          text-anchor="middle" dominant-baseline="central" fill="#eef5ff"
          font-size="13" font-weight="700" font-family="Inter,sans-serif"
          style="pointer-events:none">${COF_MAJOR[i]}</text>`;
        // Inner ring (relative minor)
        svg += `<path d="${cofWedgePath(cx,cy,R2,R3,start,end)}"
          fill="${COF_COLORS_INNER}" stroke="color-mix(in srgb,#b8ceee,transparent 65%)"
          stroke-width="1" class="cof-wedge${isSelected?' selected':''}"
          data-idx="${i}" data-ring="minor"/>`;
        svg += `<text x="${cx + innerR*Math.cos(mid)}" y="${cy + innerR*Math.sin(mid)}"
          text-anchor="middle" dominant-baseline="central"
          fill="color-mix(in srgb,#b8ceee,transparent 20%)"
          font-size="10" font-family="Inter,sans-serif"
          style="pointer-events:none">${COF_MINOR[i]}</text>`;
      }
      // Center circle
      svg += `<circle cx="${cx}" cy="${cy}" r="${Rc}" fill="#0c1729" stroke="color-mix(in srgb,#b8ceee,transparent 65%)" stroke-width="1"/>`;
      svg += `<text x="${cx}" y="${cy}" text-anchor="middle" dominant-baseline="central"
        fill="var(--accent)" font-size="15" font-weight="700" font-family="Inter,sans-serif"
        style="pointer-events:none">${COF_MAJOR[cofSelectedIdx]}</text>`;
      svg += '</svg>';
      return svg;
    }

    function cofScaleNotes(rootPc) {
      return SCALE_PATTERNS.major.slice(0, 7).map(s => NOTE_NAMES[(rootPc + s) % 12]);
    }

    function cofSelectKey(idx) {
      cofSelectedIdx = idx;
      const rootPc = COF_PCS[idx];
      document.getElementById('cofKeyLabel').textContent = COF_MAJOR[idx];
      document.getElementById('cofSvgWrap').innerHTML = cofBuildSvg();
      // Re-bind clicks after re-render
      document.querySelectorAll('#cofSvgWrap .cof-wedge').forEach(el => {
        el.addEventListener('click', () => cofSelectKey(parseInt(el.dataset.idx)));
      });
      // Details
      const scaleNotes = cofScaleNotes(rootPc);
      const rows = DIATONIC_ROMAN.map((roman, i) => {
        const notePc = (rootPc + SCALE_PATTERNS.major[i]) % 12;
        return `<tr><td>${roman}</td><td>${NOTE_NAMES[notePc]}${DIATONIC_QUALITIES[i] === 'min' ? 'm' : DIATONIC_QUALITIES[i] === 'dim' ? '°' : ''}</td><td>${DIATONIC_QUALITIES[i]}</td></tr>`;
      }).join('');
      document.getElementById('cofDetails').innerHTML = `
        <p style="color:var(--muted);font-size:0.82rem;margin:0 0 0.5rem;">
          <strong style="color:var(--text)">${COF_MAJOR[idx]} major</strong>
          — ${scaleNotes.join(' · ')}
        </p>
        <table><thead><tr>
          <th>Degree</th><th>Chord</th><th>Quality</th>
        </tr></thead><tbody>${rows}</tbody></table>`;
    }

    function initTheoryPanel() {
      document.getElementById('cofSvgWrap').innerHTML = cofBuildSvg();
      document.querySelectorAll('#cofSvgWrap .cof-wedge').forEach(el => {
        el.addEventListener('click', () => cofSelectKey(parseInt(el.dataset.idx)));
      });
      cofSelectKey(0);
    }

    /* ═══════════════════════════════════════════════════════════
       UI INIT
    ═══════════════════════════════════════════════════════════ */
    function populateNoteSelects() {
      ['scaleRoot','arpRoot','shapeRoot','intRoot','progrKey','toneNote'].forEach(id => {
        const sel = document.getElementById(id);
        if (!sel) return;
        NOTE_NAMES.forEach((n, i) => { const o = document.createElement('option'); o.value = i; o.textContent = n; sel.appendChild(o); });
      });
      const intTypeSel = document.getElementById('intType');
      if (intTypeSel) {
        INTERVALS.forEach(([name, semi]) => { const o = document.createElement('option'); o.value = semi; o.textContent = name; intTypeSel.appendChild(o); });
      }
    }

    function initTabs() {
      document.querySelectorAll('.mode-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.mode-tab').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const tab = btn.dataset.tab;
          currentTab = tab;
          document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
          const panel = document.getElementById(tab + 'Panel');
          if (panel) panel.classList.remove('hidden');
          if (tab === 'staff') { enterStaffTab(); fbShapeData = null; fqState.active = false; }
          else if (tab === 'shape') { leaveStaffTab(); fbTargetMidi = null; fqState.active = false; shapeRefresh(); }
          else if (tab === 'fretquiz') { leaveStaffTab(); fbTargetMidi = null; fbShapeData = null; fqState.active = false; refreshFretboard(); }
          else if (tab === 'theory') { leaveStaffTab(); fbTargetMidi = null; fbShapeData = null; refreshFretboard(); initTheoryPanel(); }
          else { leaveStaffTab(); fbTargetMidi = null; fbShapeData = null; fqState.active = false; refreshFretboard(); }
        });
      });
    }

    function initMicBtn() {
      const btn = document.getElementById('micBtn');
      btn.addEventListener('click', async () => {
        if (window.Tone) Tone.start();
        if (micStream) {
          stopMic(); btn.textContent = 'Enable Microphone';
          noteState.active = false; scaleState.active = false; arpState.active = false; intState.active = false;
          metroStop(); if (toneOscNode) toneToggle();
        } else {
          btn.textContent = 'Connecting\u2026'; btn.disabled = true;
          const ok = await startMic();
          btn.disabled = false; btn.textContent = ok ? 'Disable Microphone' : 'Enable Microphone';
        }
      });
    }

    function initClefToggle() {
      document.querySelectorAll('#clefToggle .seg-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('#clefToggle .seg-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentClef = btn.dataset.clef;
          staffCurrentClef = currentClef;
          srState.active = false; srState.targetPos = null; srState.targetMidi = null;
          swState.active = false; swState.targetPos = null; swState.targetMidi = null;
          document.getElementById('staffWritePrompt').textContent  = '--';
          document.getElementById('staffReadStartBtn').textContent  = 'Start';
          document.getElementById('staffWriteStartBtn').textContent = 'Start';
          const overlay = document.getElementById('writeOverlay');
          if (overlay) overlay.classList.add('hidden');
          drawStaff(null, currentClef, { keySig: getStaticKeySig() });
        });
      });
    }

    function initStaffKeySelect() {
      const sel = document.getElementById('staffKeySelect');
      if (!sel) return;
      sel.addEventListener('change', function () {
        currentKey = this.value;
        srState.active = false; srState.targetPos = null; srState.targetMidi = null;
        swState.active = false; swState.targetPos = null; swState.targetMidi = null;
        document.getElementById('staffWritePrompt').textContent  = '--';
        document.getElementById('staffReadStartBtn').textContent  = 'Start';
        document.getElementById('staffWriteStartBtn').textContent = 'Start';
        document.getElementById('staffReadResult').textContent   = '';
        document.getElementById('staffWriteResult').textContent  = '';
        const overlay = document.getElementById('writeOverlay');
        if (overlay) overlay.classList.add('hidden');
        drawStaff(null, currentClef, { keySig: getStaticKeySig() });
      });
    }

    function initNoteLabelToggle() {
      const btn = document.getElementById('noteLabelToggle');
      if (!btn) return;
      btn.addEventListener('click', function () {
        noteLabelsEnabled = !noteLabelsEnabled;
        this.classList.toggle('active', noteLabelsEnabled);
        // Redraw with current state to show/hide labels
        drawStaff(staffCurrentMidi, staffCurrentClef, staffCurrentDrawOpts);
      });
    }

    function initStaffModeToggle() {
      document.querySelectorAll('#staffModeToggle .seg-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('#staffModeToggle .seg-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          staffMode = btn.dataset.mode;
          applyStaffMode();
        });
      });
    }

    function initStaffPanel() {
      document.getElementById('staffReadStartBtn').addEventListener('click', srStart);
      document.getElementById('staffReadNextBtn').addEventListener('click', () => { if (srState.active) srNext(); });
      document.getElementById('staffReadReplayBtn').addEventListener('click', () => { if (window.Tone) Tone.start(); staffReplayNote(srState.targetMidi); });
      document.getElementById('staffReadResetBtn').addEventListener('click', () => {
        srState.score = { correct: 0, total: 0 }; srState.streak = 0; srUpdateScore();
        document.getElementById('staffReadResult').textContent = '';
        document.getElementById('staffReadScore').textContent = 'Score: 0 / 0';
        document.getElementById('staffReadStreak').textContent = '';
      });
      document.getElementById('staffWriteStartBtn').addEventListener('click', swStart);
      document.getElementById('staffWriteNextBtn').addEventListener('click', () => { if (swState.active) swNext(); });
      document.getElementById('staffWriteReplayBtn').addEventListener('click', () => { if (window.Tone) Tone.start(); staffReplayNote(swState.targetMidi); });

      // Answer mode toggle (Buttons / Type)
      document.querySelectorAll('#srAnswerToggle .seg-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('#srAnswerToggle .seg-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          srAnswerMode = btn.dataset.srmode;
          srBuildChoices();
        });
      });
      document.getElementById('staffReadTypeSubmit')?.addEventListener('click', srOnTypeSubmit);
      document.getElementById('staffReadTypeInput')?.addEventListener('keydown', e => {
        if (e.key === 'Enter') { e.preventDefault(); srOnTypeSubmit(); }
      });
    }

    function initNotePanel() {
      document.getElementById('noteStartBtn').addEventListener('click', noteStart);
      document.getElementById('noteNextBtn').addEventListener('click', () => {
        if (!noteState.active && noteState.targetMidi) noteState.active = true;
        noteNext();
      });
      document.getElementById('noteResetBtn').addEventListener('click', () => {
        noteState.score = { correct: 0, total: 0 }; noteState.streak = 0; updateNoteScore(); setNoteResult('', '');
      });
    }

    function initScalesPanel() {
      document.getElementById('scaleStartBtn').addEventListener('click', scaleStart);
      document.getElementById('scaleSkipBtn').addEventListener('click', scaleSkip);
    }

    function initArpeggiosPanel() {
      document.getElementById('arpStartBtn').addEventListener('click', arpStart);
      document.getElementById('arpSkipBtn').addEventListener('click', arpSkip);
    }

    function initShapePanel() {
      document.getElementById('shapeRoot').addEventListener('change', shapeRefresh);
      document.getElementById('shapeType').addEventListener('change', shapeRefresh);
    }

    function initIntervalsPanel() {
      document.getElementById('intStartBtn').addEventListener('click', intStart);
      document.getElementById('intNextBtn').addEventListener('click', intStart);
    }

    function initToolsPanel() {
      document.getElementById('metroBtn').addEventListener('click', () => { if (metroRunning) metroStop(); else metroStart(); });
      document.getElementById('metroBpm').addEventListener('input', function () { document.getElementById('metroBpmVal').textContent = this.value; });
      document.getElementById('metroVol').addEventListener('input', function () { document.getElementById('metroVolVal').textContent = this.value + '%'; });
      document.getElementById('toneBtn').addEventListener('click', toneToggle);
      document.getElementById('toneNote').addEventListener('change', toneUpdateFreqDisplay);
      document.getElementById('toneOctave').addEventListener('change', toneUpdateFreqDisplay);
      document.getElementById('toneVol').addEventListener('input', function () {
        document.getElementById('toneVolVal').textContent = this.value + '%';
        if (toneGainNode) toneGainNode.gain.value = (this.value / 100) * 0.3;
      });
    }

    /* ═══════════════════════════════════════════════════════════
       BOOT
    ═══════════════════════════════════════════════════════════ */
    document.addEventListener('DOMContentLoaded', function () {
      populateNoteSelects();
      initTabs();
      initMicBtn();
      initClefToggle();
      initStaffModeToggle();
      initStaffPanel();
      initStaffKeySelect();
      initNoteLabelToggle();
      initNotePanel();
      initScalesPanel();
      initArpeggiosPanel();
      initShapePanel();
      initIntervalsPanel();
      initFretQuizPanel();
      initProgrPanel();
      initEarPanel();
      initTheoryPanel();
      initToolsPanel();

      document.getElementById('instrSelect')?.addEventListener('change', function () {
        if (window.Tone) Tone.start();
        loadSampler(this.value);
      });
      loadSampler(document.getElementById('instrSelect')?.value || 'bass');

      refreshFretboard();
      // Pre-load VexFlow
      withVF(() => {});

      const ro = new ResizeObserver(() => {
        refreshFretboard();
        if (currentTab === 'staff') drawStaff(staffCurrentMidi, staffCurrentClef, staffCurrentDrawOpts);
        const overlay = document.getElementById('writeOverlay');
        if (overlay && !overlay.classList.contains('hidden')) {
          overlay.width = document.getElementById('staffCard').clientWidth || 400;
        }
      });
      const canvas = document.getElementById('fretboard');
      if (canvas) ro.observe(canvas);
      const staffCard = document.getElementById('staffCard');
      if (staffCard) ro.observe(staffCard);
    });

  })();
  </script>

</Layout>
